    <mxCell id="entry" value="&lt;b&gt;/validate-component-&lt;br&gt;onboarding-jira&lt;/b&gt;&lt;br&gt;&lt;br&gt;Jira issue URL or key&lt;br&gt;e.g. RHOAIENG-1234" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#333333;strokeWidth=2;arcSize=10;verticalAlign=top;spacingTop=5;fontSize=11;fontFamily=Inter,Helvetica,Arial,sans-serif;" vertex="1" parent="1">
