direction: right

*.style.border-radius: 8
*.style.font-size: 13
*.style.fill: "#f5f5f5"
*.style.stroke: "#333333"

# --- Skills ---

create-jira: |md
  **/create-component-onboarding-jira**

  - Interactive Q&A (ODH vs RHOAI)
  - Generate component_onboarding_details.yaml
  - Validate against JSON Schema
  - Dockerfile digest check (RHOAI)
  - Create or update Jira ticket
| {
  shape: rectangle
  style.fill: "#e8e8e8"
  style.stroke: "#333333"
  style.stroke-width: 2
  style.double-border: true
}

validate-jira: |md
  **/validate-component-onboarding-jira**

  - Fetch Jira issue details
  - Download YAML attachment
  - Schema + branch cross-validation
  - Dockerfile digest check (RHOAI)
  - Update Jira labels and status
| {
  shape: rectangle
  style.fill: "#e8e8e8"
  style.stroke: "#333333"
  style.stroke-width: 2
  style.double-border: true
}

# --- External Services ---

jira: |md
  **Jira**
  RHOAIENG project
| {
  shape: rectangle
  style.fill: "#f5f5f5"
  style.stroke: "#333333"
  style.stroke-width: 2
  style.stroke-dash: 3
}

github: |md
  **GitHub**
  component repo
| {
  shape: rectangle
  style.fill: "#f5f5f5"
  style.stroke: "#333333"
  style.stroke-width: 2
  style.stroke-dash: 3
}

schema: |md
  **JSON Schema**
  component_onboarding_details
| {
  shape: rectangle
  style.fill: "#f5f5f5"
  style.stroke: "#333333"
  style.stroke-width: 2
  style.stroke-dash: 3
}

# --- Flow ---

create-jira -> validate-jira: "next step"
create-jira -> jira: "create / update ticket\nattach YAML"
validate-jira -> jira: "fetch details\nupdate labels"
create-jira -> github: "fetch README\ncheck Dockerfile digests" {
  style.stroke-dash: 3
}
validate-jira -> github: "check Dockerfile digests" {
  style.stroke-dash: 3
}
create-jira -> schema: "validate YAML"
validate-jira -> schema: "validate YAML"
