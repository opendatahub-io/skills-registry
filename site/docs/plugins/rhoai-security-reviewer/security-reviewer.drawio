    <mxCell id="fetch-strat" value="&lt;b&gt;Fetch STRAT from Jira&lt;/b&gt;&lt;br&gt;&lt;i&gt;MCP call&lt;/i&gt;&lt;br&gt;&lt;br&gt;mcp__atlassian__getJiraIssue&lt;br&gt;summary, description, priority&lt;br&gt;labels, status, comments&lt;br&gt;full STRAT content in markdown" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e8e8e8;strokeColor=#333333;strokeWidth=2;arcSize=10;verticalAlign=top;spacingTop=5;fontSize=11;fontFamily=Inter,Helvetica,Arial,sans-serif;" vertex="1" parent="1">
