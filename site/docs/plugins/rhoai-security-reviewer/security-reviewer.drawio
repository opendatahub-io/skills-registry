    <mxCell id="phase-a" value="&lt;b&gt;Phase A: Discovery&lt;/b&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ececec;strokeColor=#333333;strokeWidth=2;container=1;collapsible=0;verticalAlign=top;spacingTop=5;fontSize=12;fontStyle=1;fontFamily=Inter,Helvetica,Arial,sans-serif;" vertex="1" parent="1">
      <mxGeometry x="915" y="160" width="385" height="235" as="geometry"/>
    </mxCell>
    <mxCell id="catalog" value="&lt;b&gt;A.1 Risk Pattern Catalog&lt;/b&gt;&lt;br&gt;&lt;i&gt;LLM analysis&lt;/i&gt;&lt;br&gt;&lt;br&gt;check ALL 39 patterns against&lt;br&gt;threat surface inventory&lt;br&gt;APPLICABLE or NOT-APPLICABLE&lt;br&gt;10 categories: AUTH, DATA,&lt;br&gt;CRYPTO, NET, SUPPLY, INFRA,&lt;br&gt;TENANT, AGENT, MCP, UPSTREAM&lt;br&gt;cite threat surface items" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e8e8e8;strokeColor=#333333;strokeWidth=2;arcSize=10;verticalAlign=top;spacingTop=5;fontSize=11;fontFamily=Inter,Helvetica,Arial,sans-serif;" vertex="1" parent="phase-a">
      <mxGeometry x="15" y="35" width="170" height="185" as="geometry"/>
    </mxCell>
    <mxCell id="creative" value="&lt;b&gt;A.2 Creative Exploration&lt;/b&gt;&lt;br&gt;&lt;i&gt;LLM analysis&lt;/i&gt;&lt;br&gt;&lt;br&gt;cross-component attack chains&lt;br&gt;novel attack surfaces&lt;br&gt;emergent combination risks&lt;br&gt;unvalidated assumptions&lt;br&gt;choices blocking future controls" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e8e8e8;strokeColor=#333333;strokeWidth=2;arcSize=10;verticalAlign=top;spacingTop=5;fontSize=11;fontFamily=Inter,Helvetica,Arial,sans-serif;" vertex="1" parent="phase-a">
