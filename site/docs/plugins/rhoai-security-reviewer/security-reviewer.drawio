    <mxCell id="phase-b" value="&lt;b&gt;Phase B: Filter and Classify&lt;/b&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ececec;strokeColor=#333333;strokeWidth=2;container=1;collapsible=0;verticalAlign=top;spacingTop=5;fontSize=12;fontStyle=1;fontFamily=Inter,Helvetica,Arial,sans-serif;" vertex="1" parent="1">
      <mxGeometry x="1350" y="130" width="580" height="295" as="geometry"/>
    </mxCell>
    <mxCell id="relevance-gate" value="&lt;b&gt;B.1 Relevance Gate&lt;/b&gt;&lt;br&gt;&lt;i&gt;LLM analysis&lt;/i&gt;&lt;br&gt;&lt;br&gt;what specific STRAT content&lt;br&gt;creates this concern?&lt;br&gt;already addressed by existing&lt;br&gt;security infrastructure?&lt;br&gt;DROP if cannot answer both" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e8e8e8;strokeColor=#333333;strokeWidth=2;arcSize=10;verticalAlign=top;spacingTop=5;fontSize=11;fontFamily=Inter,Helvetica,Arial,sans-serif;" vertex="1" parent="phase-b">
      <mxGeometry x="15" y="35" width="165" height="155" as="geometry"/>
    </mxCell>
    <mxCell id="severity-tree" value="&lt;b&gt;B.2 Severity Decision Tree&lt;/b&gt;&lt;br&gt;&lt;i&gt;LLM classification&lt;/i&gt;&lt;br&gt;&lt;br&gt;Critical: no auth, no isolation,&lt;br&gt;lethal trifecta, irreversible arch&lt;br&gt;High: auth bypass, insecure creds,&lt;br&gt;cluster RBAC, vulnerable upstream&lt;br&gt;Medium: real concern, below High&lt;br&gt;NFR Gap: missing spec, not flaw" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e8e8e8;strokeColor=#333333;strokeWidth=2;arcSize=10;verticalAlign=top;spacingTop=5;fontSize=11;fontFamily=Inter,Helvetica,Arial,sans-serif;" vertex="1" parent="phase-b">
      <mxGeometry x="200" y="35" width="175" height="175" as="geometry"/>
    </mxCell>
    <mxCell id="org-constraints" value="&lt;b&gt;B.3 Org Constraints&lt;/b&gt;&lt;br&gt;&lt;br&gt;FIPS 140-3 compliance&lt;br&gt;TLS profile compliance (ML-KEM)&lt;br&gt;OpenShift Gateway API only&lt;br&gt;approved auth patterns only&lt;br&gt;namespace-scoped RBAC&lt;br&gt;image provenance&lt;br&gt;upstream-first policy" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#333333;strokeWidth=2;arcSize=10;verticalAlign=top;spacingTop=5;fontSize=11;fontFamily=Inter,Helvetica,Arial,sans-serif;" vertex="1" parent="phase-b">
      <mxGeometry x="395" y="35" width="170" height="185" as="geometry"/>
