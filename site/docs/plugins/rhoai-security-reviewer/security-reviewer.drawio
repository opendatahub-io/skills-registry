    <mxCell id="entry" value="&lt;b&gt;security-reviewer&lt;/b&gt;&lt;br&gt;&lt;br&gt;STRAT key (RHAISTRAT-NNN)&lt;br&gt;--reviewer N (1, 2, or 3)&lt;br&gt;--threat-surface path&lt;br&gt;--tier light/standard/deep" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#333333;strokeWidth=2;arcSize=10;verticalAlign=top;spacingTop=5;fontSize=11;fontFamily=Inter,Helvetica,Arial,sans-serif;" vertex="1" parent="1">
