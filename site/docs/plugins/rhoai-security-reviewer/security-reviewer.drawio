      <mxGeometry x="345" y="100" width="130" height="45" as="geometry"/>
    </mxCell>
    <mxCell id="read-arch" value="&lt;b&gt;Read Architecture Context&lt;/b&gt;&lt;br&gt;&lt;br&gt;PLATFORM.md overview&lt;br&gt;component-specific files&lt;br&gt;existing security controls&lt;br&gt;.context/architecture-context/" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#333333;strokeWidth=2;arcSize=10;verticalAlign=top;spacingTop=5;fontSize=11;fontFamily=Inter,Helvetica,Arial,sans-serif;" vertex="1" parent="1">
      <mxGeometry x="690" y="195" width="175" height="130" as="geometry"/>
