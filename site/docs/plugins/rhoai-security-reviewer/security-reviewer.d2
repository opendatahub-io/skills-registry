direction: right

*.style.border-radius: 8
*.style.font-size: 13
*.style.fill: "#f5f5f5"
*.style.stroke: "#333333"

# --- Entry ---

entry: |md
  **security-reviewer**

  - STRAT key (RHAISTRAT-NNN)
  - --reviewer N (1, 2, or 3)
  - --threat-surface path
  - --tier light/standard/deep
| {
  shape: rectangle
  style.fill: "#f5f5f5"
  style.stroke: "#333333"
  style.stroke-width: 2
}

# --- Step 1: Read Threat Surface ---

read-threat: |md
  **Read Threat Surface**

  - structured inventory file
  - endpoints, services, data flows
  - credentials, CRDs, trust boundaries
  - RBAC changes, agent/MCP surfaces
| {
  shape: rectangle
  style.fill: "#f5f5f5"
  style.stroke: "#333333"
  style.stroke-width: 2
}

# --- Step 2: Fetch STRAT ---

fetch-strat: |md
  **Fetch STRAT from Jira**
  MCP call

  - mcp\_\_atlassian\_\_getJiraIssue
  - summary, description, priority
  - labels, status, comments
  - full STRAT content in markdown
| {
  shape: rectangle
  style.fill: "#e8e8e8"
  style.stroke: "#333333"
  style.stroke-width: 2
  style.double-border: true
}

jira: |md
  **Jira (Atlassian MCP)**
| {
  shape: rectangle
  style.fill: "#f5f5f5"
  style.stroke: "#333333"
  style.stroke-width: 2
  style.stroke-dash: 3
}

# --- Step 3: Architecture Context (conditional) ---

read-arch: |md
  **Read Architecture Context**

  - PLATFORM.md overview
  - component-specific files
  - existing security controls
  - .context/architecture-context/
| {
  shape: rectangle
  style.fill: "#f5f5f5"
  style.stroke: "#333333"
  style.stroke-width: 2
}

# --- Phase A: Discovery (container) ---

phase-a: "Phase A: Discovery" {
  style.fill: "#ececec"
  style.stroke: "#333333"
  style.stroke-width: 2

  catalog: |md
    **A.1 Risk Pattern Catalog**
    LLM analysis

    - check ALL 39 patterns against
      threat surface inventory
    - APPLICABLE or NOT-APPLICABLE
    - 10 categories: AUTH, DATA,
      CRYPTO, NET, SUPPLY, INFRA,
      TENANT, AGENT, MCP, UPSTREAM
    - cite threat surface items
      and STRAT text
  | {
    shape: rectangle
    style.fill: "#e8e8e8"
    style.stroke: "#333333"
    style.stroke-width: 2
    style.double-border: true
  }

  creative: |md
    **A.2 Creative Exploration**
    LLM analysis

    - cross-component attack chains
    - novel attack surfaces
    - emergent combination risks
    - unvalidated assumptions
    - choices blocking future controls
  | {
    shape: rectangle
    style.fill: "#e8e8e8"
    style.stroke: "#333333"
    style.stroke-width: 2
    style.double-border: true
  }

  catalog -> creative: "after all 39 patterns"
}

# --- Phase B: Filter and Classify (container) ---

phase-b: "Phase B: Filter and Classify" {
  style.fill: "#ececec"
  style.stroke: "#333333"
  style.stroke-width: 2

  relevance-gate: |md
    **B.1 Relevance Gate**
    LLM analysis

    - what specific STRAT content
      creates this concern?
    - already addressed by existing
      security infrastructure?
    - DROP if cannot answer both
  | {
    shape: rectangle
    style.fill: "#e8e8e8"
    style.stroke: "#333333"
    style.stroke-width: 2
    style.double-border: true
  }

  severity-tree: |md
    **B.2 Severity Decision Tree**
    LLM classification

    - Critical: no auth, no isolation,
      lethal trifecta, irreversible arch
    - High: auth bypass, insecure creds,
      cluster RBAC, vulnerable upstream
    - Medium: real concern, below High
    - NFR Gap: missing spec, not flaw
  | {
    shape: rectangle
    style.fill: "#e8e8e8"
    style.stroke: "#333333"
    style.stroke-width: 2
    style.double-border: true
  }

  org-constraints: |md
    **B.3 Org Constraints**

    - FIPS 140-3 compliance
    - TLS profile compliance (ML-KEM)
    - OpenShift Gateway API only
    - approved auth patterns only
    - namespace-scoped RBAC
    - image provenance
    - upstream-first policy
  | {
    shape: rectangle
    style.fill: "#f5f5f5"
    style.stroke: "#333333"
    style.stroke-width: 2
  }

  relevance-gate -> severity-tree: "passed"
  severity-tree -> org-constraints
}

# --- Dropped findings ---

dropped: |md
  **Dropped Findings**

  - recorded with reason
| {
  shape: rectangle
  style.fill: "#f5f5f5"
  style.stroke: "#333333"
  style.stroke-width: 2
  style.stroke-dash: 3
}

# --- Catalog callout ---

catalog-patterns: |code
  39 Risk Patterns
  ────────────────────
  AUTH-01..06     (6)
  DATA-01..04     (4)
  CRYPTO-01..04   (4)
  NET-01..03      (3)
  SUPPLY-01..04   (4)
  INFRA-01..03    (3)
  TENANT-01..03   (3)
  AGENT-01..05    (5)
  MCP-01..04      (4)
  UPSTREAM-01..04  (3)
| {
  shape: rectangle
  style.fill: "#f5f5f5"
  style.stroke: "#bbbbbb"
  style.stroke-width: 1
  style.font-size: 10
}

# --- Output ---

output: |md
  **Write Review File**

  - artifacts/security-reviews/
  - catalog check results (39)
  - creative findings
  - relevance gate pass/drop
  - security risks with severity
  - NFR gaps, org violations
| {
  shape: rectangle
  style.fill: "#f5f5f5"
  style.stroke: "#333333"
  style.stroke-width: 2
}

# --- Output callout ---

output-format: |code
  STRAT-reviewer-N.md
  ────────────────────
  strat_key: RHAISTRAT-NNN
  reviewer: N
  finding_count:
    security_risks: N
    nfr_gaps: N
    dropped: N
  ────────────────────
  Catalog Check Results
  Creative Exploration
  Relevance Gate Results
  Security Risks (RISK-001..)
  NFR Gaps
  Org Constraint Violations
| {
  shape: rectangle
  style.fill: "#f5f5f5"
  style.stroke: "#bbbbbb"
  style.stroke-width: 1
  style.font-size: 10
}

# --- Flow ---

entry -> read-threat
read-threat -> fetch-strat: "threat surface\ninventory"
fetch-strat -> jira: "MCP call" {
  style.stroke-dash: 3
}
fetch-strat -> read-arch: "standard / deep"
fetch-strat -> phase-a: "light (skip arch)"
read-arch -> phase-a: "existing controls"
phase-a -> phase-b: "all findings"
phase-b.relevance-gate -> dropped: "dropped" {
  style.stroke-dash: 3
}
phase-b -> output

# --- Callout edges ---

phase-a.catalog -> catalog-patterns: "" {
  style.stroke: "#bbbbbb"
  style.stroke-dash: 4
  style.stroke-width: 1
}

output -> output-format: "" {
  style.stroke: "#bbbbbb"
  style.stroke-dash: 4
  style.stroke-width: 1
}
