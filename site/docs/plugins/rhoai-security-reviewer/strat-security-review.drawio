    <mxCell id="tier" value="&lt;b&gt;Determine Tier&lt;/b&gt;&lt;br&gt;&lt;br&gt;Deep: 3+ surface hints,&lt;br&gt;auth+crypto, agentic/MCP&lt;br&gt;Standard: 1-2 hints, M effort&lt;br&gt;Light: none-apparent,&lt;br&gt;S effort, UI/docs only" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#333333;strokeWidth=2;arcSize=10;verticalAlign=top;spacingTop=5;fontSize=11;fontFamily=Inter,Helvetica,Arial,sans-serif;" vertex="1" parent="1">
