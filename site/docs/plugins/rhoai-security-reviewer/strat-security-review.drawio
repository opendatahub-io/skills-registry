    <mxCell id="confidence" value="&lt;b&gt;Assign Confidence&lt;/b&gt;&lt;br&gt;&lt;br&gt;3/3 reviewers: HIGH&lt;br&gt;2/3 reviewers: MEDIUM&lt;br&gt;1/3 reviewers: LOW&lt;br&gt;severity: majority vote&lt;br&gt;or median if all differ" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#333333;strokeWidth=2;arcSize=10;verticalAlign=top;spacingTop=5;fontSize=11;fontFamily=Inter,Helvetica,Arial,sans-serif;" vertex="1" parent="1">
