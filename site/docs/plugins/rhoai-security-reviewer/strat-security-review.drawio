    <mxCell id="cluster" value="&lt;b&gt;Cluster &amp; Match&lt;/b&gt;&lt;br&gt;&lt;br&gt;match on 2-of-3 criteria:&lt;br&gt;pattern ID, threat surface&lt;br&gt;item, category + section&lt;br&gt;err toward separate findings" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e8e8e8;strokeColor=#333333;strokeWidth=2;arcSize=10;verticalAlign=top;spacingTop=5;fontSize=11;fontFamily=Inter,Helvetica,Arial,sans-serif;double=1;" vertex="1" parent="1">
