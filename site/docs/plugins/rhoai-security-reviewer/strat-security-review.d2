direction: right

*.style.border-radius: 8
*.style.font-size: 13
*.style.fill: "#f5f5f5"
*.style.stroke: "#333333"

# --- Entry ---

entry: |md
  **/strat-security-review**

  - RHAISTRAT-NNN
  - --force (overwrite)
| {
  shape: rectangle
  style.fill: "#f5f5f5"
  style.stroke: "#333333"
  style.stroke-width: 2
}

# --- External: Jira ---

jira: |md
  **Jira**
  (Atlassian MCP)
| {
  shape: rectangle
  style.fill: "#f5f5f5"
  style.stroke: "#333333"
  style.stroke-width: 2
  style.stroke-dash: 3
}

# --- Phase 1: Threat Surface Extraction ---

fetch: |md
  **Fetch STRAT**

  - mcp__atlassian__getJiraIssue
  - summary, description,
    priority, labels, comments
  - technical approach, NFRs,
    affected components
| {
  shape: rectangle
  style.fill: "#f5f5f5"
  style.stroke: "#333333"
  style.stroke-width: 2
}

check-existing: |md
  **Idempotency Check**

  - review already exists?
  - stop if no --force
| {
  shape: rectangle
  style.fill: "#f5f5f5"
  style.stroke: "#333333"
  style.stroke-width: 2
}

stop: |md
  **Stop**

  - review exists
  - no --force flag
| {
  shape: rectangle
  style.fill: "#f5f5f5"
  style.stroke: "#333333"
  style.stroke-width: 2
}

tier: |md
  **Determine Tier**

  - Deep: 3+ surface hints,
    auth+crypto, agentic/MCP
  - Standard: 1-2 hints,
    M effort
  - Light: none-apparent,
    S effort, UI/docs only
| {
  shape: rectangle
  style.fill: "#f5f5f5"
  style.stroke: "#333333"
  style.stroke-width: 2
}

extract: |md
  **Extract Threat Surface**
  (mechanical inventory)

  - endpoints / APIs
  - services / containers
  - data flows, credentials
  - CRDs, trust boundaries
  - RBAC, external deps
  - agent / MCP surfaces
| {
  shape: rectangle
  style.fill: "#f5f5f5"
  style.stroke: "#333333"
  style.stroke-width: 2
}

# --- Phase 2: Spawn Reviewers ---

reviewers: Spawn Reviewers (parallel, isolated) {
  style.fill: "#ececec"
  style.stroke: "#333333"
  style.stroke-width: 2

  r1: |md
    **Reviewer 1**
    context: fork

    - independent analysis
    - catalog pattern check
    - risk + NFR findings
  | {
    shape: rectangle
    style.fill: "#e8e8e8"
    style.stroke: "#333333"
    style.stroke-width: 2
    style.double-border: true
  }

  r2: |md
    **Reviewer 2**
    context: fork

    - independent analysis
    - catalog pattern check
    - risk + NFR findings
  | {
    shape: rectangle
    style.fill: "#e8e8e8"
    style.stroke: "#333333"
    style.stroke-width: 2
    style.double-border: true
  }

  r3: |md
    **Reviewer 3**
    context: fork

    - independent analysis
    - catalog pattern check
    - risk + NFR findings
  | {
    shape: rectangle
    style.fill: "#e8e8e8"
    style.stroke: "#333333"
    style.stroke-width: 2
    style.double-border: true
  }
}

# --- External: /security-reviewer ---

security-reviewer: |md
  **/security-reviewer**
  (invoked 3x, isolated)
| {
  shape: rectangle
  style.fill: "#f5f5f5"
  style.stroke: "#333333"
  style.stroke-width: 2
  style.stroke-dash: 3
}

# --- Phase 3: Consensus Synthesis ---

collect: |md
  **Collect Findings**

  - read all 3 reviewer files
  - extract risks, NFR gaps
  - catalog pattern IDs
  - constraint violations
| {
  shape: rectangle
  style.fill: "#f5f5f5"
  style.stroke: "#333333"
  style.stroke-width: 2
}

cluster: |md
  **Cluster & Match**

  - match on 2-of-3 criteria:
    pattern ID, threat surface
    item, category + section
  - err toward separate findings
| {
  shape: rectangle
  style.fill: "#e8e8e8"
  style.stroke: "#333333"
  style.stroke-width: 2
  style.double-border: true
}

confidence: |md
  **Assign Confidence**

  - 3/3 reviewers: HIGH
  - 2/3 reviewers: MEDIUM
  - 1/3 reviewers: LOW
  - severity: majority vote
    or median if all differ
| {
  shape: rectangle
  style.fill: "#f5f5f5"
  style.stroke: "#333333"
  style.stroke-width: 2
}

verdict: |md
  **Resolve Verdict**

  - Critical + HIGH/MED: FAIL
  - Critical + LOW: CONCERNS
  - High/Medium any: CONCERNS
  - 5+ NFR gaps: CONCERNS
  - else: PASS
| {
  shape: rectangle
  style.fill: "#f5f5f5"
  style.stroke: "#333333"
  style.stroke-width: 2
}

# --- Phase 4: Output ---

write-output: |md
  **Write Artifacts**

  - full review .md
    (consensus + confidence)
  - requirements .md
    (amendments, NFRs)
| {
  shape: rectangle
  style.fill: "#f5f5f5"
  style.stroke: "#333333"
  style.stroke-width: 2
}

attach: |md
  **Attach & Label**

  - attach requirements
    to Jira ticket
  - add verdict label:
    strat-security-pass /
    concerns / fail
| {
  shape: rectangle
  style.fill: "#f5f5f5"
  style.stroke: "#333333"
  style.stroke-width: 2
}

# --- Light Tier Short-Circuit ---

light-pass: |md
  **Light PASS**
  (short-circuit)

  - compact verdict
  - no reviewers spawned
| {
  shape: rectangle
  style.fill: "#f5f5f5"
  style.stroke: "#333333"
  style.stroke-width: 2
}

# --- Callout: Intermediate Files ---

artifacts-callout: |md
  artifacts/security-reviews/
    STRAT-NNN-threat-surface.md
    STRAT-NNN-reviewer-1.md
    STRAT-NNN-reviewer-2.md
    STRAT-NNN-reviewer-3.md
  artifacts/security-requirements/
    STRAT-NNN-security-requirements.md
| {
  shape: rectangle
  style.fill: "#f5f5f5"
  style.stroke: "#bbbbbb"
  style.stroke-width: 1
  style.font: mono
  style.font-size: 10
}

# --- Edges: Phase 1 ---

entry -> fetch
fetch -> jira: {
  style.stroke-dash: 3
}
fetch -> check-existing: "STRAT content"
check-existing -> stop: "exists, no --force"
check-existing -> tier: "new or --force"
tier -> extract
extract -> reviewers: "Standard / Deep"
extract -> light-pass: "Light +\nzero threats"

# --- Edges: Phase 2 ---

reviewers.r1 -> security-reviewer: {
  style.stroke-dash: 3
}
reviewers.r2 -> security-reviewer: {
  style.stroke-dash: 3
}
reviewers.r3 -> security-reviewer: {
  style.stroke-dash: 3
}

reviewers -> collect: "reviewer-1/2/3.md"

# --- Edges: Phase 3 ---

collect -> cluster
cluster -> confidence: "finding clusters"
confidence -> verdict

# --- Edges: Phase 4 ---

verdict -> write-output
write-output -> attach: "review.md +\nrequirements.md"
attach -> jira: {
  style.stroke-dash: 3
}

light-pass -> attach

# --- Callout edge ---

write-output -> artifacts-callout: {
  style.stroke: "#bbbbbb"
  style.stroke-dash: 4
  style.stroke-width: 1
}
