<mxGraphModel adaptiveColors="auto">
  <root>
    <mxCell id="0"/>
    <mxCell id="1" parent="0"/>
    <mxCell id="jira" value="&lt;b&gt;Jira&lt;/b&gt;&lt;br&gt;(RHAISTRAT)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e8e8e8;strokeColor=#333333;strokeWidth=2;arcSize=10;dashed=1;dashPattern=8 4;verticalAlign=middle;fontSize=11;fontFamily=Inter,Helvetica,Arial,sans-serif;" vertex="1" parent="1">
      <mxGeometry x="30" y="110" width="110" height="60" as="geometry"/>
    </mxCell>
    <mxCell id="strat-security-review" value="&lt;b&gt;/strat-security-review&lt;/b&gt;&lt;br&gt;&lt;br&gt;fetch STRAT from Jira, check idempotency&lt;br&gt;determine review tier (light/standard/deep)&lt;br&gt;extract threat surface inventory mechanically&lt;br&gt;spawn 3 independent reviewers (parallel, isolated)&lt;br&gt;synthesize consensus with confidence tagging" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#333333;strokeWidth=2;arcSize=10;verticalAlign=top;spacingTop=5;fontSize=11;fontFamily=Inter,Helvetica,Arial,sans-serif;" vertex="1" parent="1">
      <mxGeometry x="190" y="60" width="260" height="160" as="geometry"/>
    </mxCell>
    <mxCell id="security-reviewer" value="&lt;b&gt;security-reviewer&lt;/b&gt;&lt;br&gt;&lt;i&gt;LLM sub-agent (x3, forked)&lt;/i&gt;&lt;br&gt;&lt;br&gt;check 39 risk patterns against threat surface&lt;br&gt;creative exploration for novel attack surfaces&lt;br&gt;apply relevance gate (STRAT evidence required)&lt;br&gt;classify severity via decision tree&lt;br&gt;check RHOAI organizational constraints" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e8e8e8;strokeColor=#333333;strokeWidth=2;arcSize=10;verticalAlign=top;spacingTop=5;fontSize=11;fontFamily=Inter,Helvetica,Arial,sans-serif;double=1;" vertex="1" parent="1">
      <mxGeometry x="500" y="53" width="260" height="175" as="geometry"/>
    </mxCell>
    <mxCell id="output-node" value="&lt;b&gt;Output&lt;/b&gt;&lt;br&gt;&lt;br&gt;security-review.md (full consensus)&lt;br&gt;security-requirements.md (attached to Jira)&lt;br&gt;verdict label: pass / concerns / fail" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#333333;strokeWidth=2;arcSize=10;verticalAlign=top;spacingTop=5;fontSize=11;fontFamily=Inter,Helvetica,Arial,sans-serif;" vertex="1" parent="1">
      <mxGeometry x="810" y="75" width="250" height="130" as="geometry"/>
    </mxCell>
    <mxCell id="e1" value="STRAT content" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#333333;strokeWidth=1.5;html=1;fontStyle=2;fontSize=11;fontFamily=Inter,Helvetica,Arial,sans-serif;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;" edge="1" source="jira" target="strat-security-review" parent="1">
      <mxGeometry relative="1" as="geometry">
      </mxGeometry>
    </mxCell>
    <mxCell id="e2" value="threat-surface.md + tier" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#333333;strokeWidth=1.5;html=1;fontStyle=2;fontSize=11;fontFamily=Inter,Helvetica,Arial,sans-serif;exitX=1;exitY=0.35;exitDx=0;exitDy=0;entryX=0;entryY=0.4;entryDx=0;entryDy=0;" edge="1" source="strat-security-review" target="security-reviewer" parent="1">
      <mxGeometry relative="1" as="geometry">
        <Array as="points">
          <mxPoint x="475" y="116"/>
          <mxPoint x="475" y="123"/>
        </Array>
      </mxGeometry>
    </mxCell>
    <mxCell id="e3" value="reviewer-N.md (x3)" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#333333;strokeWidth=1.5;dashed=1;dashPattern=8 4;html=1;fontStyle=2;fontSize=11;fontFamily=Inter,Helvetica,Arial,sans-serif;exitX=0.5;exitY=0;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;" edge="1" source="security-reviewer" target="strat-security-review" parent="1">
      <mxGeometry relative="1" as="geometry">
