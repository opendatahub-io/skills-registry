        </Array>
      </mxGeometry>
    </mxCell>
    <mxCell id="e5" value="attach requirements + verdict label" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#333333;strokeWidth=1.5;dashed=1;dashPattern=8 4;html=1;fontStyle=2;fontSize=11;fontFamily=Inter,Helvetica,Arial,sans-serif;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=1;entryDx=0;entryDy=0;" edge="1" source="output-node" target="jira" parent="1">
      <mxGeometry relative="1" as="geometry">
