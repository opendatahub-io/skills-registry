direction: right

*.style.border-radius: 8
*.style.font-size: 13
*.style.fill: "#f5f5f5"
*.style.stroke: "#333333"

# --- Entry ---

entry: |md
  **/autofix-research**

  - spike ticket investigation
  - no associated repository
  - allowed: Read, Write,
    Glob, Grep
| {
  shape: rectangle
  style.fill: "#f5f5f5"
  style.stroke: "#333333"
  style.stroke-width: 2
}

# --- Step 1: Parse ---

parse: |md
  **Parse Ticket**

  - read ticket.json
  - extract research question
  - note constraints, scope
  - identify references, prior art
  - expected deliverable
| {
  shape: rectangle
  style.fill: "#f5f5f5"
  style.stroke: "#333333"
  style.stroke-width: 2
}

# --- Step 2: Investigate ---

investigate: |md
  **Investigate**
  LLM analysis

  - search docs, prior issues
  - check upstream changelogs
  - read ARCHITECTURE.md
    if available
  - synthesize findings
| {
  shape: rectangle
  style.fill: "#e8e8e8"
  style.stroke: "#333333"
  style.stroke-width: 2
  style.double-border: true
}

# --- Step 3: Write Verdict ---

verdict: |md
  **Write Verdict**

  - .autofix-verdict.json
  - verdict: "research"
  - summary + observations
  - risks and blockers
| {
  shape: rectangle
  style.fill: "#f5f5f5"
  style.stroke: "#333333"
  style.stroke-width: 2
}

# --- Callout: verdict structure ---

verdict-detail: |md
  .autofix-verdict.json
  ─────────────────────
  verdict: "research"
  reason: "..."
  summary: "..."
  files_changed: []
  risks: [...]
  blockers: [...]
  upstream_consideration: "..."
  observations: [
    "finding 1",
    "finding 2",
    ...
  ]
| {
  shape: rectangle
  style.fill: "#f5f5f5"
  style.stroke: "#bbbbbb"
  style.stroke-width: 1
  style.font: mono
  style.font-size: 10
}

# --- Guardrails annotation ---

guardrails: |md
  **Guardrails**

  - untrusted ticket input
  - no command execution
  - HTTPS URLs only
  - no raw ticket in shell
| {
  shape: rectangle
  style.fill: "#fff3cd"
  style.stroke: "#856404"
  style.stroke-width: 1
  style.font-size: 11
}

# --- Flow ---

entry -> parse: ".autofix-context/\nticket.json"
parse -> investigate: "research question\n+ constraints"
investigate -> verdict: "findings"

# Callout connection
verdict -> verdict-detail: {
  style.stroke: "#bbbbbb"
  style.stroke-dash: 4
  style.stroke-width: 1
}

# Guardrails annotation connection
investigate -> guardrails: {
  style.stroke: "#856404"
  style.stroke-dash: 4
  style.stroke-width: 1
}
