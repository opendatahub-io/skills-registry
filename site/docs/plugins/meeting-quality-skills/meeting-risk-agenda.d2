direction: right

*.style.border-radius: 8
*.style.font-size: 13
*.style.fill: "#f5f5f5"
*.style.stroke: "#333333"

# --- Entry ---

entry: |md
  **/meeting-risk-agenda**

  - meeting title (optional)
  - update document content
  - optional attendee list
| {
  shape: rectangle
  style.fill: "#f5f5f5"
  style.stroke: "#333333"
  style.stroke-width: 2
}

# --- Parse Updates ---

parse-updates: |md
  **Parse Updates**

  - read all updates in document
  - handle Google Doc or pasted text
  - detect Jira content (issue keys)
| {
  shape: rectangle
  style.fill: "#f5f5f5"
  style.stroke: "#333333"
  style.stroke-width: 2
}

# --- Risk Analysis ---

risk-analysis: |md
  **Risk Signal Detection**
  LLM analysis

  - scan for "blocked", "stuck",
    "waiting", "dependency"
  - detect lack of progress
  - flag unclear ownership
  - extract owner names
| {
  shape: rectangle
  style.fill: "#e8e8e8"
  style.stroke: "#333333"
  style.stroke-width: 2
  style.double-border: true
}

# --- Classify ---

classify: |md
  **Classify Updates**

  - Blocked: hard blockers found
  - At Risk: warning signals
  - No Issues: on track
| {
  shape: rectangle
  style.fill: "#f5f5f5"
  style.stroke: "#333333"
  style.stroke-width: 2
}

# --- Generate Agenda ---

generate-agenda: |md
  **Generate Agenda**

  - blocked items first
  - at-risk items second
  - no-issues deprioritized
  - suggest skip if no risks found
| {
  shape: rectangle
  style.fill: "#f5f5f5"
  style.stroke: "#333333"
  style.stroke-width: 2
}

# --- Callout: output format ---

output-format: |md
  Meeting Focus
  ─────────────────
  Blocked
    - Item (Owner)

  At Risk
    - Item (Owner)

  No Issues (skip)
    - Summary count
| {
  shape: rectangle
  style.fill: "#f5f5f5"
  style.stroke: "#bbbbbb"
  style.stroke-width: 1
  style.font: mono
  style.font-size: 10
}

# --- Flow ---

entry -> parse-updates
parse-updates -> risk-analysis
risk-analysis -> classify
classify -> generate-agenda

generate-agenda -> output-format: {
  style.stroke: "#bbbbbb"
  style.stroke-dash: 4
  style.stroke-width: 1
}
