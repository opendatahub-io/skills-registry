    <mxCell id="entry" value="&lt;b&gt;strategy-scope-review&lt;/b&gt;&lt;br&gt;&lt;br&gt;&lt;RHAISTRAT-NNNN&gt; or all&lt;br&gt;context: fork &amp;middot; model opus&lt;br&gt;invoked by /strategy-review&lt;br&gt;tools: Read, Grep, Glob" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#333333;strokeWidth=2;verticalAlign=top;spacingTop=5;fontSize=11;fontFamily=Inter,Helvetica,Arial,sans-serif;arcSize=16;absoluteArcSize=1;" vertex="1" parent="1">
