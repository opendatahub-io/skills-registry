<mxGraphModel adaptiveColors="auto">
  <root>
    <mxCell id="0"/>
    <mxCell id="1" parent="0"/>
    <mxCell id="entry" value="&lt;b&gt;/knowledge.repo&lt;/b&gt;&lt;br&gt;&lt;br&gt;--days N (default: 7)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#333333;strokeWidth=2;arcSize=10;verticalAlign=top;spacingTop=5;fontSize=11;fontFamily=Inter,Helvetica,Arial,sans-serif;" vertex="1" parent="1">
      <mxGeometry x="30" y="115" width="140" height="80" as="geometry"/>
    </mxCell>
    <mxCell id="setup" value="&lt;b&gt;Setup&lt;/b&gt;&lt;br&gt;&lt;br&gt;detect forge (GitHub/GitLab)&lt;br&gt;create artifacts/ dirs&lt;br&gt;list context files&lt;br&gt;(CLAUDE.md, AGENTS.md)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#333333;strokeWidth=2;arcSize=10;verticalAlign=top;spacingTop=5;fontSize=11;fontFamily=Inter,Helvetica,Arial,sans-serif;" vertex="1" parent="1">
      <mxGeometry x="220" y="95" width="185" height="120" as="geometry"/>
    </mxCell>
    <mxCell id="fetch" value="&lt;b&gt;Fetch PRs&lt;/b&gt;&lt;br&gt;&lt;br&gt;fetch-prs.py via CLI&lt;br&gt;merged PRs in date range&lt;br&gt;truncate diffs &gt; 5000 lines&lt;br&gt;save to artifacts/pr-data/" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#333333;strokeWidth=2;arcSize=10;verticalAlign=top;spacingTop=5;fontSize=11;fontFamily=Inter,Helvetica,Arial,sans-serif;" vertex="1" parent="1">
      <mxGeometry x="455" y="85" width="175" height="140" as="geometry"/>
    </mxCell>
    <mxCell id="forge-cli" value="&lt;b&gt;Forge CLI&lt;/b&gt;&lt;br&gt;gh / glab" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e8e8e8;strokeColor=#333333;strokeWidth=2;arcSize=10;dashed=1;dashPattern=8 4;verticalAlign=middle;fontSize=11;fontFamily=Inter,Helvetica,Arial,sans-serif;" vertex="1" parent="1">
      <mxGeometry x="490" y="30" width="105" height="40" as="geometry"/>
    </mxCell>
    <mxCell id="extract" value="&lt;b&gt;Extract Knowledge&lt;/b&gt;&lt;br&gt;Haiku agents (parallel)&lt;br&gt;&lt;br&gt;one agent per PR&lt;br&gt;waves of 10, 30s poll&lt;br&gt;5 min timeout per wave&lt;br&gt;output: pr-extractions/{id}.md" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e8e8e8;strokeColor=#333333;strokeWidth=4;arcSize=10;verticalAlign=top;spacingTop=5;fontSize=11;fontFamily=Inter,Helvetica,Arial,sans-serif;" vertex="1" parent="1">
      <mxGeometry x="680" y="75" width="200" height="160" as="geometry"/>
    </mxCell>
    <mxCell id="synthesize" value="&lt;b&gt;Synthesize Changes&lt;/b&gt;&lt;br&gt;Opus agent&lt;br&gt;&lt;br&gt;cross-PR reasoning&lt;br&gt;edit context files in place&lt;br&gt;match existing style/structure" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e8e8e8;strokeColor=#333333;strokeWidth=4;arcSize=10;verticalAlign=top;spacingTop=5;fontSize=11;fontFamily=Inter,Helvetica,Arial,sans-serif;" vertex="1" parent="1">
      <mxGeometry x="930" y="85" width="185" height="140" as="geometry"/>
    </mxCell>
    <mxCell id="review" value="&lt;b&gt;Review Diff&lt;/b&gt;&lt;br&gt;Opus agent&lt;br&gt;&lt;br&gt;context-isolated from&lt;br&gt;synthesis rationale&lt;br&gt;receives diff + raw&lt;br&gt;extractions only&lt;br&gt;verdict: PASS or REVISE" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e8e8e8;strokeColor=#333333;strokeWidth=4;arcSize=10;verticalAlign=top;spacingTop=5;fontSize=11;fontFamily=Inter,Helvetica,Arial,sans-serif;" vertex="1" parent="1">
      <mxGeometry x="1165" y="75" width="200" height="150" as="geometry"/>
    </mxCell>
    <mxCell id="revise" value="&lt;b&gt;Revise Changes&lt;/b&gt;&lt;br&gt;Opus agent&lt;br&gt;&lt;br&gt;apply review feedback&lt;br&gt;single revision pass&lt;br&gt;no re-review loop" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e8e8e8;strokeColor=#333333;strokeWidth=4;arcSize=10;verticalAlign=top;spacingTop=5;fontSize=11;fontFamily=Inter,Helvetica,Arial,sans-serif;" vertex="1" parent="1">
      <mxGeometry x="1195" y="280" width="170" height="120" as="geometry"/>
    </mxCell>
    <mxCell id="artifacts" value="&lt;b&gt;Finalize Artifacts&lt;/b&gt;&lt;br&gt;&lt;br&gt;git diff &gt; proposed-updates.patch&lt;br&gt;git checkout -- . (reset tree)&lt;br&gt;write run-report.json" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#333333;strokeWidth=2;arcSize=10;verticalAlign=top;spacingTop=5;fontSize=11;fontFamily=Inter,Helvetica,Arial,sans-serif;" vertex="1" parent="1">
      <mxGeometry x="1430" y="150" width="200" height="120" as="geometry"/>
    </mxCell>
    <mxCell id="early-exit" value="&lt;b&gt;Early Exit&lt;/b&gt;&lt;br&gt;&lt;br&gt;no context files&lt;br&gt;no merged PRs&lt;br&gt;no knowledge items&lt;br&gt;no changes proposed" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#999999;strokeWidth=1;arcSize=10;verticalAlign=top;spacingTop=5;fontSize=11;fontFamily=Inter,Helvetica,Arial,sans-serif;" vertex="1" parent="1">
      <mxGeometry x="590" y="420" width="165" height="130" as="geometry"/>
    </mxCell>
    <mxCell id="report-callout" value="run-report.json&lt;br&gt;forge, repo, date_range&lt;br&gt;prs_scanned, prs_with_knowledge&lt;br&gt;knowledge_items: {high, med, low}&lt;br&gt;changes_proposed&lt;br&gt;review_verdict&lt;br&gt;patch_file" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#bbbbbb;strokeWidth=1;arcSize=6;verticalAlign=top;spacingTop=5;align=left;spacingLeft=8;fontSize=10;fontFamily=JetBrains Mono,Courier New,monospace;" vertex="1" parent="1">
      <mxGeometry x="1430" y="325" width="210" height="170" as="geometry"/>
