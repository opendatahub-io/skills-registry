    <mxCell id="entry" value="&lt;b&gt;/feasibility-review&lt;/b&gt;&lt;br&gt;&lt;i&gt;forked sub-agent (opus)&lt;/i&gt;&lt;br&gt;&lt;br&gt;Tools: Read, Grep, Glob&lt;br&gt;artifacts/strat-tasks/&lt;br&gt;artifacts/rfe-tasks/" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#333333;strokeWidth=2;arcSize=10;verticalAlign=top;spacingTop=5;fontSize=11;fontFamily=Inter,Helvetica,Arial,sans-serif;" vertex="1" parent="1">
