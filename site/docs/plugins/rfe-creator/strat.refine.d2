direction: right

*.style.border-radius: 8
*.style.font-size: 13
*.style.fill: "#f5f5f5"
*.style.stroke: "#333333"

# --- Entry ---

entry: |md
  **/strat.refine**

  - Read strat-tasks/
  - YAML frontmatter
  - Business need (fixed)
| {
  shape: rectangle
  style.fill: "#f5f5f5"
  style.stroke: "#333333"
  style.stroke-width: 2
}

# --- Check for prior reviews ---

check-reviews: |md
  **Check Reviews**

  - strat-reviews/ exist?
  - Determines mode:
    initial vs revision
| {
  shape: rectangle
  style.fill: "#f5f5f5"
  style.stroke: "#333333"
  style.stroke-width: 2
}

# --- Architecture context ---

arch-context: |md
  **Architecture Context**

  - .context/architecture-context/
  - PLATFORM.md + components
  - Ground in real architecture
| {
  shape: rectangle
  style.fill: "#f5f5f5"
  style.stroke: "#333333"
  style.stroke-width: 2
  style.stroke-dash: 3
}

# --- Initial refinement ---

initial: |md
  **Initial Refinement**
  forked LLM agent

  - Technical approach
  - Affected components
  - Dependencies, NFRs
  - Effort estimate (S/M/L/XL)
  - Risks and open questions
| {
  shape: rectangle
  style.fill: "#e8e8e8"
  style.stroke: "#333333"
  style.stroke-width: 2
  style.double-border: true
}

# --- Revision mode ---

revision: |md
  **Revision Mode**
  forked LLM agent

  - Read review feedback
  - Address reviewer concerns
  - Preserve working parts
  - Flag disagreements
  - Document changes
| {
  shape: rectangle
  style.fill: "#e8e8e8"
  style.stroke: "#333333"
  style.stroke-width: 2
  style.double-border: true
}

# --- Output ---

output: |md
  **Write Output**

  - Update strat-tasks/ files
  - status -> Refined
  - Preserve business need
| {
  shape: rectangle
  style.fill: "#f5f5f5"
  style.stroke: "#333333"
  style.stroke-width: 2
}

# --- Downstream ---

strat-review: |md
  **/strat.review**
| {
  shape: rectangle
  style.fill: "#f5f5f5"
  style.stroke: "#333333"
  style.stroke-width: 2
  style.stroke-dash: 3
}

# --- Edges ---

entry -> check-reviews

check-reviews -> initial: "no reviews"
check-reviews -> revision: "reviews exist"

check-reviews -> arch-context: "load context" {
  style.stroke-dash: 3
}

arch-context -> initial: {
  style.stroke-dash: 3
}

initial -> output
revision -> output

output -> strat-review: "downstream" {
  style.stroke-dash: 3
}
