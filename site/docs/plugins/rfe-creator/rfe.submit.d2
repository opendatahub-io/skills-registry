direction: right

*.style.border-radius: 8
*.style.font-size: 13
*.style.fill: "#f5f5f5"
*.style.stroke: "#333333"

# --- Entry ---

entry: |md
  **/rfe.submit**

  - submit reviewed RFEs
  - create or update Jira
  - non-interactive
| {
  shape: rectangle
  style.fill: "#f5f5f5"
  style.stroke: "#333333"
  style.stroke-width: 2
}

# --- Credential Check ---

check-creds: |md
  **Check Credentials**

  - JIRA_SERVER
  - JIRA_USER
  - JIRA_TOKEN
  - abort if missing
| {
  shape: rectangle
  style.fill: "#f5f5f5"
  style.stroke: "#333333"
  style.stroke-width: 2
}

# --- Submission Container ---

submit: Submit {
  style.fill: "#ececec"
  style.stroke: "#333333"
  style.stroke-width: 2

  split: |md
    **Split Submissions**

    - archived parents first
    - split_submit.py
    - archive, create, link
  | {
    shape: rectangle
    style.fill: "#f5f5f5"
    style.stroke: "#333333"
    style.stroke-width: 2
  }

  create-update: |md
    **Create / Update**

    - new RFEs: create ticket
    - existing: update fields
    - rename RFE-NNN to RHAIRFE
  | {
    shape: rectangle
    style.fill: "#f5f5f5"
    style.stroke: "#333333"
    style.stroke-width: 2
  }

  labels: |md
    **Apply Labels**

    - auto-created / auto-revised
    - split-original / split-result
    - needs-attention
    - rubric-pass
    - feasibility-pass/fail/unknown
  | {
    shape: rectangle
    style.fill: "#f5f5f5"
    style.stroke: "#333333"
    style.stroke-width: 2
  }

  split -> create-update
  create-update -> labels
}

# --- Jira API (external) ---

jira: |md
  **Jira REST API**

  - RHAIRFE project
  - Basic Auth
| {
  shape: rectangle
  style.fill: "#f5f5f5"
  style.stroke: "#333333"
  style.stroke-width: 2
  style.stroke-dash: 3
}

# --- Report ---

report: |md
  **Report Results**

  - rebuild rfes.md index
  - show created/updated keys
  - suggest --dry-run on error
| {
  shape: rectangle
  style.fill: "#f5f5f5"
  style.stroke: "#333333"
  style.stroke-width: 2
}

# --- Upstream (external) ---

rfe-review: |md
  **/rfe.review**
| {
  shape: rectangle
  style.fill: "#f5f5f5"
  style.stroke: "#333333"
  style.stroke-width: 2
  style.stroke-dash: 3
}

# --- Flow ---

rfe-review -> entry: "reviewed artifacts" {
  style.stroke-dash: 3
}

entry -> check-creds
check-creds -> submit: "credentials set"
submit -> report: "artifacts/rfes.md"

# Jira connection from submission container
submit.create-update -> jira: "create / update\ntickets"
submit.labels -> jira: "add / swap\nlabels"
submit.split -> jira: "archive, create,\nlink, close"
