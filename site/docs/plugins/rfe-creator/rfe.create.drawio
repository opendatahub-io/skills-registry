    <mxCell id="parse" value="&lt;b&gt;Parse &amp; Persist&lt;/b&gt;&lt;br&gt;&lt;br&gt;strip --headless flag&lt;br&gt;init split-config.yaml&lt;br&gt;write IDs to disk&lt;br&gt;verify task files exist" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#333333;strokeWidth=2;arcSize=10;verticalAlign=top;spacingTop=5;fontSize=11;fontFamily=Inter,Helvetica,Arial,sans-serif;" vertex="1" parent="1">
