direction: right

*.style.border-radius: 8
*.style.font-size: 13
*.style.fill: "#f5f5f5"
*.style.stroke: "#333333"

# --- Entry ---

entry: |md
  **/rfe.speedrun**

  - --input \<YAML\>
  - --headless
  - --dry-run
  - --announce-complete
  - --batch-size N
| {
  shape: rectangle
  style.fill: "#f5f5f5"
  style.stroke: "#333333"
  style.stroke-width: 2
}

# --- Step 0: Parse & Persist ---

parse: |md
  **Parse & Persist Flags**

  - clean temp state
  - persist config to disk
  - pin batch_size (default 5)
  - determine mode A/B/C
| {
  shape: rectangle
  style.fill: "#f5f5f5"
  style.stroke: "#333333"
  style.stroke-width: 2
}

# --- Phase 1: Create (mode fan-out) ---

create: "Phase 1: Create" {
  style.fill: "#ececec"
  style.stroke: "#333333"
  style.stroke-width: 2

  mode-a: |md
    **Batch YAML**
    (Mode A)

    - read YAML input file
    - pre-allocate N IDs
    - launch N agents in parallel
    - each agent calls /rfe.create
    - retry any missing
  | {
    shape: rectangle
    style.fill: "#e8e8e8"
    style.stroke: "#333333"
    style.stroke-width: 2
    style.double-border: true
  }

  mode-b: |md
    **Existing RFE**
    (Mode B)

    - Jira key(s) from args
    - skip creation entirely
  | {
    shape: rectangle
    style.fill: "#f5f5f5"
    style.stroke: "#333333"
    style.stroke-width: 2
  }

  mode-c: |md
    **Single Idea**
    (Mode C)

    - invoke /rfe.create once
    - clarifying Qs if interactive
  | {
    shape: rectangle
    style.fill: "#e8e8e8"
    style.stroke: "#333333"
    style.stroke-width: 2
    style.double-border: true
  }
}

# --- Persist IDs ---

persist-ids: |md
  **Persist ID List**

  - write all IDs to disk
  - survives context compression
| {
  shape: rectangle
  style.fill: "#f5f5f5"
  style.stroke: "#333333"
  style.stroke-width: 2
}

# --- Phase 2: Auto-fix ---

autofix: |md
  **/rfe.auto-fix**

  - re-read config + IDs from disk
  - assess, review, auto-revise
  - split oversized RFEs
  - retry queue + report
  - pass --batch-size from config
| {
  shape: rectangle
  style.fill: "#f5f5f5"
  style.stroke: "#333333"
  style.stroke-width: 2
  style.stroke-dash: 3
}

# --- Phase 3: Submit ---

collect: |md
  **Collect Passing IDs**

  - re-read config + IDs
  - collect_recommendations.py
  - parse SUBMIT= line
| {
  shape: rectangle
  style.fill: "#f5f5f5"
  style.stroke: "#333333"
  style.stroke-width: 2
}

submit: |md
  **/rfe.submit**

  - create/update in Jira
  - confirmation table (interactive)
  - skip confirmation (headless)
| {
  shape: rectangle
  style.fill: "#f5f5f5"
  style.stroke: "#333333"
  style.stroke-width: 2
  style.stroke-dash: 3
}

# --- Phase 4: Summary ---

summary: |md
  **Summary**

  - created / passed / failed / split
  - submitted Jira tickets
  - run report + review report
  - announce-complete marker (CI)
| {
  shape: rectangle
  style.fill: "#f5f5f5"
  style.stroke: "#333333"
  style.stroke-width: 2
}

# --- Flow ---

entry -> parse

parse -> create.mode-a: "--input"
parse -> create.mode-b: "Jira key"
parse -> create.mode-c: "free text"

create.mode-a -> persist-ids
create.mode-b -> persist-ids
create.mode-c -> persist-ids

persist-ids -> autofix: "speedrun-all-ids.txt"

autofix -> collect

collect -> submit: "passing IDs"
collect -> summary: "none pass" {
  style.stroke-dash: 3
}

submit -> summary
