direction: right

*.style.border-radius: 8
*.style.font-size: 13
*.style.fill: "#f5f5f5"
*.style.stroke: "#333333"

# --- Entry ---

entry: |md
  **rfe-feasibility-review**
  internal sub-agent

  - receives RFE ID
  - model: opus
  - not user-invocable
| {
  shape: rectangle
  style.fill: "#f5f5f5"
  style.stroke: "#333333"
  style.stroke-width: 2
}

# --- Read RFE ---

read-rfe: |md
  **Read RFE Task**

  - artifacts/rfe-tasks/{ID}.md
  - {ID}-comments.md (if exists)
  - stakeholder context, prior
    decisions, related work
| {
  shape: rectangle
  style.fill: "#f5f5f5"
  style.stroke: "#333333"
  style.stroke-width: 2
}

# --- Architecture Context ---

arch-context: |md
  **Load Architecture Context**

  - read LATEST_VERSION for
    release directory name
  - PLATFORM.md + component docs
  - identify which components
    the RFE touches
| {
  shape: rectangle
  style.fill: "#f5f5f5"
  style.stroke: "#333333"
  style.stroke-width: 2
}

# --- Architecture Overlays ---

overlays: |md
  **Apply Overlays**

  - scan overlays/*.md files
  - filter: status=active,
    matching release + components
  - corrections override
    generated architecture docs
| {
  shape: rectangle
  style.fill: "#f5f5f5"
  style.stroke: "#333333"
  style.stroke-width: 2
}

# --- Prior Review ---

prior-review: |md
  **Check Prior Review**

  - rfe-review-report.md
  - what concerns addressed?
  - what concerns remain?
  - new issues from revisions?
| {
  shape: rectangle
  style.fill: "#f5f5f5"
  style.stroke: "#333333"
  style.stroke-width: 2
}

# --- Feasibility Assessment ---

assess: |md
  **Feasibility Assessment**
  LLM (opus)

  - technically feasible?
  - architectural conflicts?
  - strategy alignment?
  - scope realistic?
  - hidden complexities?
| {
  shape: rectangle
  style.fill: "#e8e8e8"
  style.stroke: "#333333"
  style.stroke-width: 2
  style.double-border: true
}

# --- Output ---

write-output: |md
  **Write Assessment**

  - rfe-reviews/{ID}-feasibility.md
  - verdict: feasible /
    infeasible / indeterminate
  - strategy considerations
    for /strat.refine
  - blockers + scope assessment
| {
  shape: rectangle
  style.fill: "#f5f5f5"
  style.stroke: "#333333"
  style.stroke-width: 2
}

# --- Callout: output format ---

output-format: |md
  {ID}-feasibility.md
  ────────────────────
  Feasibility: feasible
  Strategy: [items]
  Blockers: none
  Scope: appropriate
| {
  shape: rectangle
  style.fill: "#f5f5f5"
  style.stroke: "#bbbbbb"
  style.stroke-width: 1
  style.font: mono
  style.font-size: 10
}

# --- External: architecture-context repo ---

arch-repo: |md
  **architecture-context**
  (external repo)
| {
  shape: rectangle
  style.fill: "#f5f5f5"
  style.stroke: "#333333"
  style.stroke-width: 2
  style.stroke-dash: 3
}

# --- Edges ---

entry -> read-rfe: "{ID}"

read-rfe -> arch-context
read-rfe -> prior-review: "if re-review" {
  style.stroke-dash: 3
}

arch-repo -> arch-context: {
  style.stroke-dash: 3
}

arch-context -> overlays
overlays -> assess

prior-review -> assess: {
  style.stroke-dash: 3
}

assess -> write-output: "verdict"

write-output -> output-format: {
  style.stroke: "#bbbbbb"
  style.stroke-dash: 4
  style.stroke-width: 1
}
