direction: right

# -- Global styles --
*.style.border-radius: 8
*.style.font-size: 13
*.style.fill: "#f5f5f5"
*.style.stroke: "#333333"

# ================================================================
#  Entry
# ================================================================

entry: |md
  **scope-review**
  internal skill (fork)

  - model: opus
  - tools: Read, Grep, Glob
| {
  shape: rectangle
  style.fill: "#f5f5f5"
  style.stroke: "#333333"
  style.stroke-width: 2
}

# ================================================================
#  Read Inputs
# ================================================================

read-inputs: |md
  **Read Inputs**

  - strategy artifacts
    from strat-tasks/
  - source RFEs
    from rfe-tasks/
  - cross-reference
    strategies against RFEs
| {
  shape: rectangle
  style.fill: "#f5f5f5"
  style.stroke: "#333333"
  style.stroke-width: 2
}

# ================================================================
#  Check for Prior Reviews
# ================================================================

check-prior: |md
  **Prior Reviews?**

  - check strat-reviews/
  - read existing reviews
    for strategies under
    review (if re-review)
| {
  shape: rectangle
  style.fill: "#f5f5f5"
  style.stroke: "#333333"
  style.stroke-width: 2
}

# ================================================================
#  Assess Each Strategy (LLM)
# ================================================================

assess: |md
  **Assess Each Strategy**
  LLM analysis (opus)

  - right-sized? (feature
    scope, not task/bundle)
  - effort matches scope?
  - scope clearly bounded?
  - delivers complete
    capability?
  - scope risks? (flag traps
    like "all necessary")
  - strategy vs RFE alignment
| {
  shape: rectangle
  style.fill: "#e8e8e8"
  style.stroke: "#333333"
  style.stroke-width: 2
  style.double-border: true
}

# ================================================================
#  Re-Review Delta (conditional)
# ================================================================

re-review-delta: |md
  **Re-Review Delta**
  LLM analysis (opus)

  - concerns addressed
    from prior review?
  - concerns still
    remaining?
  - new issues introduced
    by revisions?
| {
  shape: rectangle
  style.fill: "#e8e8e8"
  style.stroke: "#333333"
  style.stroke-width: 2
  style.double-border: true
}

# ================================================================
#  Output Report
# ================================================================

output: |md
  **Scope Report**

  - scope assessment
  - effort vs scope
  - RFE coverage
  - scope risks
  - recommendation
| {
  shape: rectangle
  style.fill: "#f5f5f5"
  style.stroke: "#333333"
  style.stroke-width: 2
}

# ================================================================
#  Output Format Callout
# ================================================================

output-format: |md
  ### STRAT-NNN: title
  **Scope**: right-sized / too large / ...
  **Effort**: matched / under / over
  **RFE coverage**: full / partial / exceeds
  **Scope risks**: list or none
  **Recommendation**: approve / split /
    tighten scope / expand
| {
  shape: rectangle
  style.fill: "#f5f5f5"
  style.stroke: "#bbbbbb"
  style.stroke-width: 1
  style.font: mono
  style.font-size: 10
}

# ================================================================
#  Recommendation Outcomes
# ================================================================

approve: |md
  **Approve**

  - right-sized
  - scope bounded
| {
  shape: rectangle
  style.fill: "#f5f5f5"
  style.stroke: "#333333"
  style.stroke-width: 2
}

split: |md
  **Split into N**

  - too large
  - concrete boundaries
    for each sub-strategy
| {
  shape: rectangle
  style.fill: "#f5f5f5"
  style.stroke: "#333333"
  style.stroke-width: 2
}

tighten: |md
  **Tighten Scope**

  - unbounded scope
  - flag scope traps
| {
  shape: rectangle
  style.fill: "#f5f5f5"
  style.stroke: "#333333"
  style.stroke-width: 2
}

expand-rfe: |md
  **Expand to RFE**

  - partial coverage
  - gaps vs acceptance
    criteria listed
| {
  shape: rectangle
  style.fill: "#f5f5f5"
  style.stroke: "#333333"
  style.stroke-width: 2
}

# ================================================================
#  Edges
# ================================================================

entry -> read-inputs
read-inputs -> check-prior: "strat-tasks/ + rfe-tasks/"
check-prior -> assess: "first review"
check-prior -> re-review-delta: "re-review" {
  style.stroke-dash: 3
}
re-review-delta -> assess

assess -> output

output -> output-format: {
  style.stroke: "#bbbbbb"
  style.stroke-dash: 4
  style.stroke-width: 1
}

# Recommendation fan-out
output -> approve: "right-sized"
output -> split: "too large"
output -> tighten: "unbounded"
output -> expand-rfe: "partial RFE"
