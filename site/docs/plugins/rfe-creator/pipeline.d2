direction: right

*.style.border-radius: 8
*.style.font-size: 13
*.style.fill: "#f5f5f5"
*.style.stroke: "#333333"

# --- RFE Pipeline ---

rfe-pipeline: RFE Pipeline {
  style.fill: "#ececec"
  style.stroke: "#333333"
  style.stroke-width: 2

  create: |md
    **/rfe.create**

    - Problem statement → RFE
    - Loads assess-rfe rubric
    - Clarifying questions
    - Size from acceptance criteria
    - YAML frontmatter output
  | {shape: rectangle; style.fill: "#e8e8e8"; style.stroke: "#333333"; style.stroke-width: 2; style.double-border: true}

  review: |md
    **/rfe.review**

    - Parallel assess + feasibility agents
    - Rubric scoring (5 criteria)
    - Auto-revise failing RFEs
    - Re-assess up to 2 cycles
  | {shape: rectangle; style.fill: "#e8e8e8"; style.stroke: "#333333"; style.stroke-width: 2; style.double-border: true}

  split: |md
    **/rfe.split**

    - Decompose oversized RFEs
    - Generate child RFEs
    - Self-correct right-sizing (1 cycle)
    - Coverage validation
  | {shape: rectangle; style.fill: "#e8e8e8"; style.stroke: "#333333"; style.stroke-width: 2; style.double-border: true}

  submit: |md
    **/rfe.submit**

    - Deterministic Python scripts
    - Create or update Jira tickets
    - Auto-apply pipeline labels
    - Supports --dry-run
  | {style.fill: "#f5f5f5"; style.stroke: "#333333"; style.stroke-width: 2}

  create -> review: "rfe-tasks/"
  review -> split: "oversized"
  split -> review: "child RFEs" {style.stroke-dash: 3}
  review -> submit: "passing RFEs"
}

# --- Orchestrators ---

speedrun: |md
  **/rfe.speedrun**

  - End-to-end orchestrator
  - Batch YAML, Jira key, or idea
  - create → auto-fix → submit
  - --headless, --dry-run
| {
  shape: rectangle
  style.fill: "#f5f5f5"
  style.stroke: "#333333"
  style.stroke-width: 2
}

auto-fix: |md
  **/rfe.auto-fix**

  - Pipeline state machine
  - JQL fetch or explicit IDs
  - Batched dispatch loop
  - Resume on interruption
| {
  shape: rectangle
  style.fill: "#f5f5f5"
  style.stroke: "#333333"
  style.stroke-width: 2
}

speedrun -> rfe-pipeline.create: "Phase 1"
speedrun -> auto-fix: "Phase 2"
speedrun -> rfe-pipeline.submit: "Phase 3"
auto-fix -> rfe-pipeline.review: "batch IDs"
auto-fix -> rfe-pipeline.split: "oversized RFEs"

# --- Review Sub-Agents ---

review-agents: Review Sub-Agents {
  style.fill: "#ececec"
  style.stroke: "#333333"
  style.stroke-width: 2

  rfe-feasibility: |md
    **rfe-feasibility-review**

    - feasible / infeasible / indeterminate
    - checks platform architecture
    - reads Jira comment history
  | {shape: rectangle; style.fill: "#e8e8e8"; style.stroke: "#333333"; style.stroke-width: 2; style.double-border: true}
}

rfe-pipeline.review -> review-agents.rfe-feasibility: "per-RFE agent"

# --- Strategy Review Sub-Agents ---

strat-reviewers: Strategy Reviewers {
  style.fill: "#ececec"
  style.stroke: "#333333"
  style.stroke-width: 2

  arch: |md
    **architecture-review**

    - dependency correctness
    - integration patterns
    - component boundaries
  | {shape: rectangle; style.fill: "#e8e8e8"; style.stroke: "#333333"; style.stroke-width: 2; style.double-border: true}

  feasibility-strat: |md
    **feasibility-review**

    - technical feasibility
    - effort credibility
    - hidden dependencies
  | {shape: rectangle; style.fill: "#e8e8e8"; style.stroke: "#333333"; style.stroke-width: 2; style.double-border: true}

  scope: |md
    **scope-review**

    - right-sizing
    - effort vs scope match
    - scope trap detection
  | {shape: rectangle; style.fill: "#e8e8e8"; style.stroke: "#333333"; style.stroke-width: 2; style.double-border: true}

  testability: |md
    **testability-review**

    - testable criteria
    - missing edge cases
    - test complexity
  | {shape: rectangle; style.fill: "#e8e8e8"; style.stroke: "#333333"; style.stroke-width: 2; style.double-border: true}
}

# --- Utility ---

update-deps: |md
  **/rfe-creator.update-deps**

  - Re-fetch assess-rfe skills
  - Re-fetch architecture context
| {
  shape: rectangle
  style.fill: "#f5f5f5"
  style.stroke: "#333333"
  style.stroke-width: 2
}

# --- External Services ---

jira: |md
  **Jira**
  RHAIRFE / RHAISTRAT
| {
  shape: rectangle
  style.fill: "#f5f5f5"
  style.stroke: "#333333"
  style.stroke-width: 2
  style.stroke-dash: 3
}

assess-rfe-plugin: |md
  **assess-rfe**
  scoring rubric
| {
  shape: rectangle
  style.fill: "#f5f5f5"
  style.stroke: "#333333"
  style.stroke-width: 2
  style.stroke-dash: 3
}

arch-context: |md
  **architecture-context**
  platform docs
| {
  shape: rectangle
  style.fill: "#f5f5f5"
  style.stroke: "#333333"
  style.stroke-width: 2
  style.stroke-dash: 3
}

# --- External connections ---

rfe-pipeline.review -> jira: "fetch RFEs"
rfe-pipeline.submit -> jira: "create / update"
rfe-pipeline.review -> assess-rfe-plugin: "rubric scoring"
rfe-pipeline.create -> assess-rfe-plugin: "bootstrap rubric"
review-agents.rfe-feasibility -> arch-context: "platform context"
strat-reviewers -> arch-context: "ground in platform"
update-deps -> assess-rfe-plugin: "re-fetch"
update-deps -> arch-context: "re-fetch"
