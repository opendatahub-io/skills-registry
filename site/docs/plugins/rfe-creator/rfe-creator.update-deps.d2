direction: right

*.style.border-radius: 8
*.style.font-size: 13
*.style.fill: "#f5f5f5"
*.style.stroke: "#333333"

# --- Entry ---

entry: |md
  **/rfe-creator.update-deps**

  - Force update all vendored
    dependencies
  - Purge caches, re-fetch
  - No LLM invocation
| {
  shape: rectangle
  style.fill: "#f5f5f5"
  style.stroke: "#333333"
  style.stroke-width: 2
}

# --- Step 1: Update assess-rfe ---

update-assess: Update assess-rfe {
  style.fill: "#ececec"
  style.stroke: "#333333"
  style.stroke-width: 2

  clean: |md
    **Purge Cached**

    - rm .context/assess-rfe
    - rm .claude/skills/assess-rfe
    - rm .claude/skills/export-rubric
  | {
    style.fill: "#f5f5f5"
    style.stroke: "#333333"
    style.stroke-width: 2
  }

  bootstrap: |md
    **Bootstrap**

    - git clone / pull repo
    - copy skills + agents
    - patch PLUGIN_ROOT path
    - export rubric
  | {
    style.fill: "#f5f5f5"
    style.stroke: "#333333"
    style.stroke-width: 2
  }

  clean -> bootstrap
}

# --- Step 2: Update architecture context ---

update-arch: Update arch context {
  style.fill: "#ececec"
  style.stroke: "#333333"
  style.stroke-width: 2

  clean: |md
    **Purge Cached**

    - rm .context/
      architecture-context
  | {
    style.fill: "#f5f5f5"
    style.stroke: "#333333"
    style.stroke-width: 2
  }

  fetch: |md
    **Fetch Latest**

    - detect latest RHOAI
      version via GitHub API
    - sparse checkout:
      architecture/ + overlays/
    - write LATEST_VERSION
  | {
    style.fill: "#f5f5f5"
    style.stroke: "#333333"
    style.stroke-width: 2
  }

  clean -> fetch
}

# --- Step 3: Report ---

report: |md
  **Report**

  - list updated deps
  - versions fetched
| {
  shape: rectangle
  style.fill: "#f5f5f5"
  style.stroke: "#333333"
  style.stroke-width: 2
}

# --- External ---

assess-rfe-repo: |md
  **opendatahub-io/assess-rfe**
  GitHub
| {
  shape: rectangle
  style.fill: "#f5f5f5"
  style.stroke: "#333333"
  style.stroke-width: 2
  style.stroke-dash: 3
}

arch-repo: |md
  **opendatahub-io/**
  **architecture-context**
  GitHub
| {
  shape: rectangle
  style.fill: "#f5f5f5"
  style.stroke: "#333333"
  style.stroke-width: 2
  style.stroke-dash: 3
}

github-api: |md
  **GitHub API**
  version detection
| {
  shape: rectangle
  style.fill: "#f5f5f5"
  style.stroke: "#333333"
  style.stroke-width: 2
  style.stroke-dash: 3
}

# --- Edges ---

entry -> update-assess.clean
update-assess.bootstrap -> update-arch.clean
update-arch.fetch -> report

# External edges
update-assess.bootstrap -> assess-rfe-repo: "git clone/pull" {
  style.stroke-dash: 3
}
update-arch.fetch -> github-api: "latest rhoai-*" {
  style.stroke-dash: 3
}
update-arch.fetch -> arch-repo: "sparse checkout" {
  style.stroke-dash: 3
}
