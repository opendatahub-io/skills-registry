direction: right

*.style.border-radius: 8
*.style.font-size: 13
*.style.fill: "#f5f5f5"
*.style.stroke: "#333333"

# --- Entry ---

entry: |md
  **testability-review**

  - fork context (read-only)
  - model: opus
  - tools: Read, Grep, Glob
  - internal (not user-invocable)
| {
  shape: rectangle
  style.fill: "#f5f5f5"
  style.stroke: "#333333"
  style.stroke-width: 2
}

# --- Read Inputs ---

read-inputs: |md
  **Read Inputs**

  - artifacts/strat-tasks/
  - strategy sections + criteria
  - artifacts/rfe-tasks/
  - original acceptance criteria
  - cross-reference basis
| {
  shape: rectangle
  style.fill: "#f5f5f5"
  style.stroke: "#333333"
  style.stroke-width: 2
}

# --- Check Prior Reviews ---

check-prior: |md
  **Check Prior Reviews**

  - artifacts/strat-reviews/
  - detect re-review scenario
  - read prior concerns
| {
  shape: rectangle
  style.fill: "#f5f5f5"
  style.stroke: "#333333"
  style.stroke-width: 2
}

# --- Assess Testability (container) ---

assess: Assess Testability {
  style.fill: "#ececec"
  style.stroke: "#333333"
  style.stroke-width: 2

  criteria: |md
    **Criteria Testability**

    - concrete vs vague tests
    - "users can do X" = testable
    - "system is reliable" = not
  | {
    shape: rectangle
    style.fill: "#e8e8e8"
    style.stroke: "#333333"
    style.stroke-width: 2
    style.double-border: true
  }

  measurable: |md
    **Success Measurability**

    - baselines defined?
    - ">80% reduction" — from what?
    - quantifiable targets
  | {
    shape: rectangle
    style.fill: "#e8e8e8"
    style.stroke: "#333333"
    style.stroke-width: 2
    style.double-border: true
  }

  edge-cases: |md
    **Edge Case Analysis**

    - failure modes
    - boundary conditions
    - concurrent access
    - large-scale scenarios
    - backwards compatibility
  | {
    shape: rectangle
    style.fill: "#e8e8e8"
    style.stroke: "#333333"
    style.stroke-width: 2
    style.double-border: true
  }

  test-strategy: |md
    **Test Strategy**

    - unit / integration / e2e
    - external dependencies
    - multi-cluster scenarios
    - non-functional requirements
    - performance, security
  | {
    shape: rectangle
    style.fill: "#e8e8e8"
    style.stroke: "#333333"
    style.stroke-width: 2
    style.double-border: true
  }

  criteria -> measurable
  measurable -> edge-cases
  edge-cases -> test-strategy
}

# --- Re-review Delta ---

re-review: |md
  **Re-review Delta**

  - concerns addressed?
  - concerns remaining?
  - new issues introduced?
| {
  shape: rectangle
  style.fill: "#e8e8e8"
  style.stroke: "#333333"
  style.stroke-width: 2
  style.double-border: true
}

# --- Output ---

output: |md
  **Write Review**

  - per-strategy verdict
  - testability rating
  - missing edge cases
  - untestable criteria list
  - test complexity rating
  - recommendation: approve /
    revise / add test plan
| {
  shape: rectangle
  style.fill: "#f5f5f5"
  style.stroke: "#333333"
  style.stroke-width: 2
}

# --- Output Callout ---

output-format: |md
  STRAT-NNN: title
  Testability: testable / partial
  Missing edge cases: [list]
  Untestable criteria: [list]
  Test complexity: low / mod / high
  Recommendation: approve / revise
| {
  shape: rectangle
  style.fill: "#f5f5f5"
  style.stroke: "#bbbbbb"
  style.stroke-width: 1
  style.font: mono
  style.font-size: 10
}

# --- Flow ---

entry -> read-inputs
entry -> check-prior

read-inputs -> assess

check-prior -> assess: "first review"
check-prior -> re-review: "prior reviews exist" {
  style.stroke-dash: 3
}

assess -> output
re-review -> output: "merge findings" {
  style.stroke-dash: 3
}

output -> output-format: {
  style.stroke: "#bbbbbb"
  style.stroke-dash: 4
  style.stroke-width: 1
}
