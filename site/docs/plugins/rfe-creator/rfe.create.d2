direction: right

*.style.border-radius: 8
*.style.font-size: 13
*.style.fill: "#f5f5f5"
*.style.stroke: "#333333"

# --- Entry ---

entry: |md
  **/rfe.create**

  - --headless
  - --priority \<value\>
  - --labels \<csv\>
  - --rfe-id \<ID\>
| {
  shape: rectangle
  style.fill: "#f5f5f5"
  style.stroke: "#333333"
  style.stroke-width: 2
}

# --- Load Rubric ---

load-rubric: |md
  **Load Rubric**

  - check artifacts/rfe-rubric.md
  - bootstrap assess-rfe if missing
  - invoke /export-rubric
  - shape questions from criteria
| {
  shape: rectangle
  style.fill: "#f5f5f5"
  style.stroke: "#333333"
  style.stroke-width: 2
}

export-rubric: |md
  **/export-rubric**
  (assess-rfe plugin)
| {
  shape: rectangle
  style.fill: "#f5f5f5"
  style.stroke: "#333333"
  style.stroke-width: 2
  style.stroke-dash: 3
}

# --- Clarifying Questions ---

clarify: |md
  **Clarifying Questions**
  LLM

  - 2-5 targeted questions
  - customers, justification
  - user problem, scope
  - success criteria
  - adapt to rubric criteria
| {
  shape: rectangle
  style.fill: "#e8e8e8"
  style.stroke: "#333333"
  style.stroke-width: 2
  style.double-border: true
}

# --- Generate RFEs ---

generate: |md
  **Generate RFEs**
  LLM

  - read rfe-template.md
  - WHAT/WHY only, no HOW
  - one RFE per business need
  - size by acceptance criteria
    (S/M/L/XL)
  - Jira priority values
| {
  shape: rectangle
  style.fill: "#e8e8e8"
  style.stroke: "#333333"
  style.stroke-width: 2
  style.double-border: true
}

# --- Write Artifacts ---

write: |md
  **Write Artifacts**

  - next_rfe_id.py allocates IDs
  - write RFE-NNN.md files
  - frontmatter.py set metadata
  - rebuild-index
| {
  shape: rectangle
  style.fill: "#f5f5f5"
  style.stroke: "#333333"
  style.stroke-width: 2
}

# --- Artifact callout ---

artifact-tree: |md
  artifacts/rfe-tasks/RFE-NNN.md
  ---
  rfe_id: RFE-001
  title: "..."
  priority: Normal
  size: M
  status: Draft
  ---
  ## Summary
  ## Business Justification
  ## Acceptance Criteria
| {
  shape: rectangle
  style.fill: "#f5f5f5"
  style.stroke: "#bbbbbb"
  style.stroke-width: 1
  style.font: mono
  style.font-size: 10
}

# --- Output ---

output: |md
  **Output**

  - artifacts/rfe-tasks/RFE-NNN.md
  - suggest /rfe.review
  - suggest re-run /rfe.create
| {
  shape: rectangle
  style.fill: "#f5f5f5"
  style.stroke: "#333333"
  style.stroke-width: 2
}

# --- Downstream ---

rfe-review: |md
  **/rfe.review**
| {
  shape: rectangle
  style.fill: "#f5f5f5"
  style.stroke: "#333333"
  style.stroke-width: 2
  style.stroke-dash: 3
}

# --- Flow ---

entry -> load-rubric

load-rubric -> export-rubric: "rubric missing" {
  style.stroke-dash: 3
}
export-rubric -> load-rubric: "rfe-rubric.md" {
  style.stroke-dash: 3
}

load-rubric -> clarify
load-rubric -> generate: "--headless\n(skip questions)"

clarify -> generate: "PM answers"

generate -> write: "RFE-NNN.md\nper business need"

write -> artifact-tree: {
  style.stroke: "#bbbbbb"
  style.stroke-dash: 4
  style.stroke-width: 1
}

write -> output

output -> rfe-review: "next step" {
  style.stroke-dash: 3
}
