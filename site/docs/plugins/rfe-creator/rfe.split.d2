direction: right

*.style.border-radius: 8
*.style.font-size: 13
*.style.fill: "#f5f5f5"
*.style.stroke: "#333333"

# --- Entry ---

entry: |md
  **/rfe.split**

  - RFE IDs (1+)
  - --headless
| {
  shape: rectangle
  style.fill: "#f5f5f5"
  style.stroke: "#333333"
  style.stroke-width: 2
}

# --- Step 0: Parse ---

parse: |md
  **Parse & Persist**

  - strip --headless flag
  - init split-config.yaml
  - write IDs to disk
  - verify task files exist
| {
  shape: rectangle
  style.fill: "#f5f5f5"
  style.stroke: "#333333"
  style.stroke-width: 2
}

# --- Step 1: Split Agents ---

split-agents: |md
  **Launch Split Agents**
  LLM agents (opus, parallel)

  - load RFE + review scores
  - check right-sized threshold
  - decompose into children
  - coverage check + write status
| {
  shape: rectangle
  style.fill: "#e8e8e8"
  style.stroke: "#333333"
  style.stroke-width: 2
  style.double-border: true
}

# --- Jira (external, referenced by split agent) ---

jira: |md
  **Jira / MCP**
| {
  shape: rectangle
  style.fill: "#f5f5f5"
  style.stroke: "#333333"
  style.stroke-width: 2
  style.stroke-dash: 3
}

# --- assess-rfe (external, rubric source) ---

assess-rfe: |md
  **assess-rfe**
  (rubric plugin)
| {
  shape: rectangle
  style.fill: "#f5f5f5"
  style.stroke: "#333333"
  style.stroke-width: 2
  style.stroke-dash: 3
}

# --- Step 2: Collect Children ---

collect: |md
  **Collect Children**

  - re-read parent IDs from disk
  - read split-status files
  - no-split -> set revise
  - collect child IDs
| {
  shape: rectangle
  style.fill: "#f5f5f5"
  style.stroke: "#333333"
  style.stroke-width: 2
}

# --- Review (external skill) ---

rfe-review: |md
  **/rfe.review**

  - inline Skill invocation
  - --headless --caller split
  - full review pipeline
| {
  shape: rectangle
  style.fill: "#f5f5f5"
  style.stroke: "#333333"
  style.stroke-width: 2
  style.stroke-dash: 3
}

# --- Step 3: Self-Correction ---

correct: |md
  **Right-sizing Check**
  (max 1 cycle)

  - read right_sized scores
  - re-split if score < 2/2
  - re-review new children
  - increment cycle counter
| {
  shape: rectangle
  style.fill: "#e8e8e8"
  style.stroke: "#333333"
  style.stroke-width: 2
  style.double-border: true
}

# --- Step 4: Finalize ---

finalize: |md
  **Finalize**

  - rebuild frontmatter index
  - re-read flags from disk
| {
  shape: rectangle
  style.fill: "#f5f5f5"
  style.stroke: "#333333"
  style.stroke-width: 2
}

# --- Output: Headless ---

headless-out: |md
  **Headless Return**

  - return to /rfe.auto-fix
  - resume batch loop
| {
  shape: rectangle
  style.fill: "#f5f5f5"
  style.stroke: "#333333"
  style.stroke-width: 2
}

# --- Output: Interactive ---

interactive-out: |md
  **Interactive Summary**

  - parent archived, children listed
  - coverage report
  - suggest /rfe.submit
| {
  shape: rectangle
  style.fill: "#f5f5f5"
  style.stroke: "#333333"
  style.stroke-width: 2
}

# --- External: rfe.auto-fix ---

rfe-autofix: |md
  **/rfe.auto-fix**
| {
  shape: rectangle
  style.fill: "#f5f5f5"
  style.stroke: "#333333"
  style.stroke-width: 2
  style.stroke-dash: 3
}

# --- Split-status callout ---

split-status-callout: |md
  split-status.yaml
  action: split / no-split
  reason: "..."
  children: [RFE-001, ...]
| {
  shape: rectangle
  style.fill: "#f5f5f5"
  style.stroke: "#bbbbbb"
  style.stroke-width: 1
  style.font: mono
  style.font-size: 10
}

# --- Flow ---

entry -> parse

parse -> split-agents: "per ID"

split-agents -> assess-rfe: "rubric" {
  style.stroke-dash: 3
}

split-agents -> jira: "comments" {
  style.stroke-dash: 3
}

split-agents -> collect: "split-status"

split-agents -> split-status-callout: {
  style.stroke: "#bbbbbb"
  style.stroke-dash: 4
  style.stroke-width: 1
}

collect -> rfe-review: "child IDs"

rfe-review -> correct

correct -> split-agents: "re-split child" {
  style.stroke-dash: 3
}

correct -> finalize: "done / max cycles"

finalize -> headless-out: "--headless"
finalize -> interactive-out: "interactive"

headless-out -> rfe-autofix: "resume" {
  style.stroke-dash: 3
}
