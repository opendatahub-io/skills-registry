direction: right

*.style.border-radius: 8
*.style.font-size: 13
*.style.fill: "#f5f5f5"
*.style.stroke: "#333333"

# --- Entry ---

entry: |md
  **/rfe.split**

  - RFE IDs (1+)
  - --headless
| {
  shape: rectangle
  style.fill: "#f5f5f5"
  style.stroke: "#333333"
  style.stroke-width: 2
}

# --- Parse ---

parse: |md
  **Parse & Persist**

  - persist split-config.yaml
  - write IDs to disk
  - verify task files exist
| {
  shape: rectangle
  style.fill: "#f5f5f5"
  style.stroke: "#333333"
  style.stroke-width: 2
}

# --- Split Agents ---

split-agents: |md
  **Split Agents**
  LLM (opus, per ID)

  - load RFE + review
  - decompose to children
  - coverage check
  - write split-status
| {
  shape: rectangle
  style.fill: "#e8e8e8"
  style.stroke: "#333333"
  style.stroke-width: 2
  style.double-border: true
}

# --- Collect ---

collect: |md
  **Collect Children**

  - read split-status files
  - collect_children.py
  - no-split -> revise
| {
  shape: rectangle
  style.fill: "#f5f5f5"
  style.stroke: "#333333"
  style.stroke-width: 2
}

# --- Review ---

rfe-review: |md
  **/rfe.review**

  - inline Skill call
  - --headless --caller split
  - full review pipeline
| {
  shape: rectangle
  style.fill: "#f5f5f5"
  style.stroke: "#333333"
  style.stroke-width: 2
  style.stroke-dash: 3
}

# --- Self-Correction ---

correct: |md
  **Self-Correct**
  (max 1 cycle)

  - check right_sized < 2
  - re-split offending child
  - re-review new children
| {
  shape: rectangle
  style.fill: "#e8e8e8"
  style.stroke: "#333333"
  style.stroke-width: 2
  style.double-border: true
}

# --- Finalize ---

finalize: |md
  **Finalize**

  - rebuild-index
  - headless or summary
| {
  shape: rectangle
  style.fill: "#f5f5f5"
  style.stroke: "#333333"
  style.stroke-width: 2
}

# --- Outputs ---

headless-out: |md
  **Headless Return**

  - return to /rfe.auto-fix
| {
  shape: rectangle
  style.fill: "#f5f5f5"
  style.stroke: "#333333"
  style.stroke-width: 2
}

interactive-out: |md
  **Summary**

  - suggest /rfe.submit
| {
  shape: rectangle
  style.fill: "#f5f5f5"
  style.stroke: "#333333"
  style.stroke-width: 2
}

# --- Flow ---

entry -> parse

parse -> split-agents

split-agents -> collect: "split-status"

collect -> rfe-review: "children found"

rfe-review -> correct

correct -> split-agents: "re-split child" {
  style.stroke-dash: 3
}

correct -> finalize: "done / max cycles"

finalize -> headless-out: "--headless"
finalize -> interactive-out: "interactive"
