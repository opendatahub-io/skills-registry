      <mxGeometry x="410" y="30" width="225" height="465" as="geometry"/>
    </mxCell>
    <mxCell id="mode-a" value="&lt;b&gt;Batch YAML&lt;/b&gt;&lt;br&gt;(Mode A)&lt;br&gt;&lt;br&gt;read YAML input file&lt;br&gt;pre-allocate N IDs&lt;br&gt;launch N agents in parallel&lt;br&gt;each agent calls /rfe.create&lt;br&gt;retry any missing" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e8e8e8;strokeColor=#333333;strokeWidth=2;arcSize=10;verticalAlign=top;spacingTop=5;fontSize=11;fontFamily=Inter,Helvetica,Arial,sans-serif;" vertex="1" parent="create">
      <mxGeometry x="20" y="40" width="185" height="160" as="geometry"/>
