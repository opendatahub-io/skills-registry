<mxGraphModel adaptiveColors="auto">
  <root>
    <mxCell id="0"/>
    <mxCell id="1" parent="0"/>
    <mxCell id="entry" value="&lt;b&gt;architecture-review&lt;/b&gt;&lt;br&gt;&lt;i&gt;(fork sub-agent, opus)&lt;/i&gt;&lt;br&gt;&lt;br&gt;reads strategy artifacts&lt;br&gt;cross-refs source RFEs&lt;br&gt;not user-invocable" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#333333;strokeWidth=2;arcSize=10;verticalAlign=top;spacingTop=5;fontSize=11;fontFamily=Inter,Helvetica,Arial,sans-serif;" vertex="1" parent="1">
