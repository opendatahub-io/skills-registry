direction: right

*.style.border-radius: 8
*.style.font-size: 13
*.style.fill: "#f5f5f5"
*.style.stroke: "#333333"

# --- Entry ---

entry: |md
  **/strat.review**

  - Adversarial review
    orchestrator
  - Reads strat-tasks/
  - Detects re-review mode
| {
  shape: rectangle
  style.fill: "#f5f5f5"
  style.stroke: "#333333"
  style.stroke-width: 2
}

# --- Verify artifacts ---

verify: |md
  **Verify Artifacts**

  - Read artifacts/strat-tasks/
  - Strategy section present?
  - Check strat-reviews/
  - Detect re-review mode
| {
  shape: rectangle
  style.fill: "#f5f5f5"
  style.stroke: "#333333"
  style.stroke-width: 2
}

# --- Fetch architecture context ---

arch-context: |md
  **Fetch Arch Context**

  - fetch-architecture-context.sh
  - .context/architecture-context/
  - PLATFORM.md + components
| {
  shape: rectangle
  style.fill: "#f5f5f5"
  style.stroke: "#333333"
  style.stroke-width: 2
  style.stroke-dash: 3
}

# --- Parallel forked reviewers ---

feasibility: |md
  **Feasibility Review**
  forked LLM agent

  - Can we build this?
  - Effort estimates credible?
  - Proposed approach viable?
| {
  shape: rectangle
  style.fill: "#e8e8e8"
  style.stroke: "#333333"
  style.stroke-width: 2
  style.double-border: true
}

testability: |md
  **Testability Review**
  forked LLM agent

  - Acceptance criteria testable?
  - Edge cases identified?
  - Gaps in test coverage?
| {
  shape: rectangle
  style.fill: "#e8e8e8"
  style.stroke: "#333333"
  style.stroke-width: 2
  style.double-border: true
}

scope-rev: |md
  **Scope Review**
  forked LLM agent

  - Each strategy right-sized?
  - Effort matches scope?
  - Over/under-scoped?
| {
  shape: rectangle
  style.fill: "#e8e8e8"
  style.stroke: "#333333"
  style.stroke-width: 2
  style.double-border: true
}

architecture: |md
  **Architecture Review**
  forked LLM agent

  - Dependencies correct?
  - Integration patterns valid?
  - Skipped if no context
| {
  shape: rectangle
  style.fill: "#e8e8e8"
  style.stroke: "#333333"
  style.stroke-width: 2
  style.double-border: true
}

# --- Write reviews ---

write-reviews: |md
  **Write Review Files**

  - strat-reviews/{id}-review.md
  - frontmatter.py set per strategy
  - Preserve disagreements
  - Consolidate findings
| {
  shape: rectangle
  style.fill: "#f5f5f5"
  style.stroke: "#333333"
  style.stroke-width: 2
}

# --- Advise user ---

advise-approved: |md
  **All Approved**

  - Ready for /strat.prioritize
| {
  shape: rectangle
  style.fill: "#f5f5f5"
  style.stroke: "#333333"
  style.stroke-width: 2
}

advise-revision: |md
  **Needs Revision**

  - List specific issues
  - Edit strategies, re-run
| {
  shape: rectangle
  style.fill: "#f5f5f5"
  style.stroke: "#333333"
  style.stroke-width: 2
}

advise-reject: |md
  **Fundamental Problems**

  - Revisit the RFE
  - Re-run /strat.refine
| {
  shape: rectangle
  style.fill: "#f5f5f5"
  style.stroke: "#333333"
  style.stroke-width: 2
}

# --- Downstream ---

strat-prioritize: |md
  **/strat.prioritize**
| {
  shape: rectangle
  style.fill: "#f5f5f5"
  style.stroke: "#333333"
  style.stroke-width: 2
  style.stroke-dash: 3
}

# --- Edges ---

entry -> verify

verify -> arch-context: "strategies exist"

arch-context -> feasibility: "fork"
arch-context -> testability: "fork"
arch-context -> scope-rev: "fork"
arch-context -> architecture: "fork (if context)" {
  style.stroke-dash: 3
}

feasibility -> write-reviews
testability -> write-reviews
scope-rev -> write-reviews
architecture -> write-reviews: {
  style.stroke-dash: 3
}

write-reviews -> advise-approved: "all pass"
write-reviews -> advise-revision: "some fail"
write-reviews -> advise-reject: "fundamental issues"

advise-approved -> strat-prioritize: "downstream" {
  style.stroke-dash: 3
}
