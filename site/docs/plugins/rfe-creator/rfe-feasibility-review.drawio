<mxGraphModel adaptiveColors="auto">
  <root>
    <mxCell id="0"/>
    <mxCell id="1" parent="0"/>
    <mxCell id="entry" value="&lt;b&gt;rfe-feasibility-review&lt;/b&gt;&lt;br&gt;&lt;i&gt;internal sub-agent&lt;/i&gt;&lt;br&gt;&lt;br&gt;receives RFE ID&lt;br&gt;model: opus&lt;br&gt;not user-invocable" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#333333;strokeWidth=2;arcSize=10;verticalAlign=top;spacingTop=5;fontSize=11;fontFamily=Inter,Helvetica,Arial,sans-serif;" vertex="1" parent="1">
      <mxGeometry x="30" y="155" width="170" height="130" as="geometry"/>
    </mxCell>
    <mxCell id="read-rfe" value="&lt;b&gt;Read RFE Task&lt;/b&gt;&lt;br&gt;&lt;br&gt;artifacts/rfe-tasks/{ID}.md&lt;br&gt;{ID}-comments.md (if exists)&lt;br&gt;stakeholder context, prior&lt;br&gt;decisions, related work" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#333333;strokeWidth=2;arcSize=10;verticalAlign=top;spacingTop=5;fontSize=11;fontFamily=Inter,Helvetica,Arial,sans-serif;" vertex="1" parent="1">
      <mxGeometry x="250" y="165" width="170" height="110" as="geometry"/>
    </mxCell>
    <mxCell id="arch-context" value="&lt;b&gt;Load Architecture Context&lt;/b&gt;&lt;br&gt;&lt;br&gt;read LATEST_VERSION for&lt;br&gt;release directory name&lt;br&gt;PLATFORM.md + component docs&lt;br&gt;identify components RFE touches" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#333333;strokeWidth=2;arcSize=10;verticalAlign=top;spacingTop=5;fontSize=11;fontFamily=Inter,Helvetica,Arial,sans-serif;" vertex="1" parent="1">
      <mxGeometry x="470" y="100" width="180" height="120" as="geometry"/>
    </mxCell>
    <mxCell id="prior-review" value="&lt;b&gt;Check Prior Review&lt;/b&gt;&lt;br&gt;&lt;br&gt;rfe-review-report.md&lt;br&gt;what concerns addressed?&lt;br&gt;what concerns remain?&lt;br&gt;new issues from revisions?" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#333333;strokeWidth=2;arcSize=10;verticalAlign=top;spacingTop=5;fontSize=11;fontFamily=Inter,Helvetica,Arial,sans-serif;" vertex="1" parent="1">
      <mxGeometry x="470" y="270" width="170" height="130" as="geometry"/>
    </mxCell>
    <mxCell id="overlays-node" value="&lt;b&gt;Apply Overlays&lt;/b&gt;&lt;br&gt;&lt;br&gt;scan overlays/*.md files&lt;br&gt;filter: status=active,&lt;br&gt;matching release + components&lt;br&gt;corrections override arch docs" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#333333;strokeWidth=2;arcSize=10;verticalAlign=top;spacingTop=5;fontSize=11;fontFamily=Inter,Helvetica,Arial,sans-serif;" vertex="1" parent="1">
      <mxGeometry x="700" y="100" width="170" height="120" as="geometry"/>
    </mxCell>
    <mxCell id="assess" value="&lt;b&gt;Feasibility Assessment&lt;/b&gt;&lt;br&gt;&lt;i&gt;LLM (opus)&lt;/i&gt;&lt;br&gt;&lt;br&gt;technically feasible?&lt;br&gt;architectural conflicts?&lt;br&gt;strategy alignment?&lt;br&gt;scope realistic?&lt;br&gt;hidden complexities?" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e8e8e8;strokeColor=#333333;strokeWidth=2;arcSize=10;verticalAlign=top;spacingTop=5;fontSize=11;fontFamily=Inter,Helvetica,Arial,sans-serif;" vertex="1" parent="1">
      <mxGeometry x="920" y="130" width="180" height="160" as="geometry"/>
    </mxCell>
    <mxCell id="write-output" value="&lt;b&gt;Write Assessment&lt;/b&gt;&lt;br&gt;&lt;br&gt;rfe-reviews/{ID}-feasibility.md&lt;br&gt;verdict: feasible /&lt;br&gt;infeasible / indeterminate&lt;br&gt;strategy considerations&lt;br&gt;for /strat.refine&lt;br&gt;blockers + scope assessment" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#333333;strokeWidth=2;arcSize=10;verticalAlign=top;spacingTop=5;fontSize=11;fontFamily=Inter,Helvetica,Arial,sans-serif;" vertex="1" parent="1">
      <mxGeometry x="1150" y="140" width="180" height="140" as="geometry"/>
    </mxCell>
    <mxCell id="arch-repo" value="&lt;b&gt;architecture-context&lt;/b&gt;&lt;br&gt;(external repo)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e8e8e8;strokeColor=#333333;strokeWidth=2;arcSize=10;dashed=1;dashPattern=8 4;verticalAlign=middle;fontSize=11;fontFamily=Inter,Helvetica,Arial,sans-serif;" vertex="1" parent="1">
      <mxGeometry x="495" y="30" width="130" height="45" as="geometry"/>
