<mxGraphModel adaptiveColors="auto">
  <root>
    <mxCell id="0"/>
    <mxCell id="1" parent="0"/>
    <mxCell id="prepare" value="&lt;b&gt;ui_prepare.py&lt;/b&gt;&lt;br&gt;&lt;i&gt;(terminal, before skill)&lt;/i&gt;&lt;br&gt;&lt;br&gt;--test-plan-pr or --test-plan&lt;br&gt;--tc filter, --priority&lt;br&gt;resolve creds, launch browser&lt;br&gt;write ui_context.json" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#333333;strokeWidth=2;arcSize=10;dashed=1;dashPattern=8 4;verticalAlign=top;spacingTop=5;fontSize=11;fontFamily=Inter,Helvetica,Arial,sans-serif;" vertex="1" parent="1">
      <mxGeometry x="30" y="240" width="160" height="140" as="geometry"/>
    </mxCell>
    <mxCell id="entry" value="&lt;b&gt;/test-plan.ui-verify&lt;/b&gt;&lt;br&gt;&lt;br&gt;(no arguments)&lt;br&gt;invoked after ui_prepare.py" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#333333;strokeWidth=2;arcSize=10;verticalAlign=top;spacingTop=5;fontSize=11;fontFamily=Inter,Helvetica,Arial,sans-serif;" vertex="1" parent="1">
      <mxGeometry x="240" y="265" width="145" height="90" as="geometry"/>
    </mxCell>
    <mxCell id="read-ctx" value="&lt;b&gt;Read Context&lt;/b&gt;&lt;br&gt;&lt;br&gt;ui_read_ctx.py&lt;br&gt;parse ui_context.json&lt;br&gt;read js-patterns.md&lt;br&gt;extract test_cases array" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#333333;strokeWidth=2;arcSize=10;verticalAlign=top;spacingTop=5;fontSize=11;fontFamily=Inter,Helvetica,Arial,sans-serif;" vertex="1" parent="1">
      <mxGeometry x="435" y="255" width="150" height="110" as="geometry"/>
    </mxCell>
    <mxCell id="cluster" value="&lt;b&gt;ODH / RHOAI Cluster&lt;/b&gt;&lt;br&gt;&lt;i&gt;(live, via Playwright CDP)&lt;/i&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#333333;strokeWidth=2;arcSize=10;dashed=1;dashPattern=8 4;verticalAlign=middle;fontSize=11;fontFamily=Inter,Helvetica,Arial,sans-serif;" vertex="1" parent="1">
      <mxGeometry x="850" y="30" width="155" height="55" as="geometry"/>
    </mxCell>
    <mxCell id="tc-loop" value="&lt;b&gt;Phase 2: Execute Test Cases&lt;/b&gt;  &lt;i&gt;(for each TC)&lt;/i&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ececec;strokeColor=#333333;strokeWidth=2;container=1;collapsible=0;verticalAlign=top;spacingTop=5;fontSize=12;fontStyle=0;fontFamily=Inter,Helvetica,Arial,sans-serif;" vertex="1" parent="1">
      <mxGeometry x="635" y="130" width="685" height="360" as="geometry"/>
    </mxCell>
    <mxCell id="preconditions" value="&lt;b&gt;2A — Preconditions&lt;/b&gt;&lt;br&gt;&lt;br&gt;check tc[&quot;preconditions&quot;]&lt;br&gt;oc verify if cluster-state&lt;br&gt;ui_block.py if not met" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#333333;strokeWidth=2;arcSize=10;verticalAlign=top;spacingTop=5;fontSize=11;fontFamily=Inter,Helvetica,Arial,sans-serif;" vertex="1" parent="tc-loop">
      <mxGeometry x="20" y="45" width="150" height="100" as="geometry"/>
    </mxCell>
    <mxCell id="reset" value="&lt;b&gt;2B — Reset&lt;/b&gt;&lt;br&gt;&lt;br&gt;goto TARGET_URL (base)&lt;br&gt;goto TARGET_URL + route&lt;br&gt;clears filters, React state" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#333333;strokeWidth=2;arcSize=10;verticalAlign=top;spacingTop=5;fontSize=11;fontFamily=Inter,Helvetica,Arial,sans-serif;" vertex="1" parent="tc-loop">
      <mxGeometry x="195" y="45" width="140" height="100" as="geometry"/>
    </mxCell>
    <mxCell id="execute" value="&lt;b&gt;2C — Execute Steps&lt;/b&gt;&lt;br&gt;&lt;i&gt;LLM-driven&lt;/i&gt;&lt;br&gt;&lt;br&gt;ui_interact.py click/fill&lt;br&gt;scroll, goto, expand, wait&lt;br&gt;--in-row for table scoping&lt;br&gt;complete all steps first" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e8e8e8;strokeColor=#333333;strokeWidth=2;arcSize=10;verticalAlign=top;spacingTop=5;fontSize=11;fontFamily=Inter,Helvetica,Arial,sans-serif;double=1;" vertex="1" parent="tc-loop">
      <mxGeometry x="360" y="45" width="145" height="115" as="geometry"/>
    </mxCell>
    <mxCell id="assert" value="&lt;b&gt;2D — Assert&lt;/b&gt;&lt;br&gt;&lt;i&gt;LLM-driven&lt;/i&gt;&lt;br&gt;&lt;br&gt;ui_assert.py per Expected Result&lt;br&gt;--js with DOM evaluation&lt;br&gt;--screenshot with highlights&lt;br&gt;--click-before for ephemeral UI&lt;br&gt;--inspect for diagnostics" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e8e8e8;strokeColor=#333333;strokeWidth=2;arcSize=10;verticalAlign=top;spacingTop=5;fontSize=11;fontFamily=Inter,Helvetica,Arial,sans-serif;double=1;" vertex="1" parent="tc-loop">
      <mxGeometry x="530" y="45" width="140" height="130" as="geometry"/>
    </mxCell>
    <mxCell id="end-tc" value="&lt;b&gt;2E — End TC&lt;/b&gt;&lt;br&gt;&lt;br&gt;log verdict (PASS/FAIL)&lt;br&gt;ui_block.py --incomplete&lt;br&gt;on crash or disconnect" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#333333;strokeWidth=2;arcSize=10;verticalAlign=top;spacingTop=5;fontSize=11;fontFamily=Inter,Helvetica,Arial,sans-serif;" vertex="1" parent="tc-loop">
