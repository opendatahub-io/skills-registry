direction: right

*.style.border-radius: 8
*.style.font-size: 13
*.style.fill: "#f5f5f5"
*.style.stroke: "#333333"

# --- Entry ---

entry: |md
  **/test-plan.score**

  - feature_dir (required)
| {
  shape: rectangle
  style.fill: "#f5f5f5"
  style.stroke: "#333333"
  style.stroke-width: 2
}

# --- Read ---

read-plan: |md
  **Read Plan & Strategy**

  - TestPlan.md
  - frontmatter.py read
  - extract source_key
  - Jira strategy or local file
| {
  shape: rectangle
  style.fill: "#f5f5f5"
  style.stroke: "#333333"
  style.stroke-width: 2
}

# --- Score ---

score-agent: |md
  **Score Agent**
  LLM (forked)

  - 5-criterion rubric (0-2)
  - Specificity, Grounding
  - Scope Fidelity
  - Actionability, Consistency
  - calibration examples
  - grounding cross-ref table
| {
  shape: rectangle
  style.fill: "#e8e8e8"
  style.stroke: "#333333"
  style.stroke-width: 2
  style.double-border: true
}

# --- Results ---

results: |md
  **Present Results**

  - score table (5 criteria)
  - total /10
  - verdict: Ready/Revise/Rework
  - grounding cross-reference
| {
  shape: rectangle
  style.fill: "#f5f5f5"
  style.stroke: "#333333"
  style.stroke-width: 2
}

# --- External ---

jira: |md
  **Jira**
  source strategy
| {
  shape: rectangle
  style.fill: "#f5f5f5"
  style.stroke: "#333333"
  style.stroke-width: 2
  style.stroke-dash: 3
}

# --- Edges ---

entry -> read-plan
read-plan -> score-agent: "strategy text"
score-agent -> results

read-plan -> jira
