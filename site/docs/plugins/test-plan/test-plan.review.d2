direction: right

*.style.border-radius: 8
*.style.font-size: 13
*.style.fill: "#f5f5f5"
*.style.stroke: "#333333"

# --- Entry ---

entry: |md
  **/test-plan.review**

  - feature directory path
  - auto-detect from session
| {
  shape: rectangle
  style.fill: "#f5f5f5"
  style.stroke: "#333333"
  style.stroke-width: 2
}

# --- Step 0: Read Inputs ---

read-plan: |md
  **Read Test Plan**

  - read TestPlan.md
  - extract source_key
  - frontmatter.py read
| {
  shape: rectangle
  style.fill: "#f5f5f5"
  style.stroke: "#333333"
  style.stroke-width: 2
}

jira: |md
  **Jira**
| {
  shape: rectangle
  style.fill: "#f5f5f5"
  style.stroke: "#333333"
  style.stroke-width: 2
  style.stroke-dash: 3
}

fetch-strategy: |md
  **Fetch Strategy**

  - MCP getJiraIssue(source_key)
  - fallback: local strat-tasks/ file
  - degraded mode if unavailable
| {
  shape: rectangle
  style.fill: "#f5f5f5"
  style.stroke: "#333333"
  style.stroke-width: 2
}

# --- Step 2: Score ---

score: |md
  **Score Agent**
  forked LLM

  - 5-criterion rubric (0-2 each)
  - specificity, grounding,
    scope fidelity
  - actionability, consistency
  - grounding cross-ref table
  - calibration examples
| {
  shape: rectangle
  style.fill: "#e8e8e8"
  style.stroke: "#333333"
  style.stroke-width: 2
  style.double-border: true
}

# --- Step 3: Review ---

review: |md
  **Review Agent**
  forked LLM

  - write TestPlanReview.md
  - set frontmatter scores + verdict
  - 6 consistency cross-checks
  - section-by-section feedback
| {
  shape: rectangle
  style.fill: "#e8e8e8"
  style.stroke: "#333333"
  style.stroke-width: 2
  style.double-border: true
}

# --- Step 4: Check ---

check-scores: |md
  **Check Criteria**

  - read review frontmatter
  - all scores = 2?
| {
  shape: rectangle
  style.fill: "#f5f5f5"
  style.stroke: "#333333"
  style.stroke-width: 2
}

# --- Revision Loop ---

revision-loop: "Revision Loop (max 2 cycles)" {
  style.fill: "#ececec"
  style.stroke: "#333333"
  style.stroke-width: 2

  filter: |md
    **Filter for Revision**

    - filter_for_revision.py
    - skip if no actionable items
  | {
    shape: rectangle
    style.fill: "#f5f5f5"
    style.stroke: "#333333"
    style.stroke-width: 2
  }

  revise: |md
    **Revise Agent**
    forked LLM

    - edit only failing sections
    - criterion-to-section mapping
    - anti-hallucination constraints
    - set auto_revised flag
  | {
    shape: rectangle
    style.fill: "#e8e8e8"
    style.stroke: "#333333"
    style.stroke-width: 2
    style.double-border: true
  }

  check-revised: |md
    **Check Revised**

    - read auto_revised flag
    - stop if no changes made
    - increment cycle counter
  | {
    shape: rectangle
    style.fill: "#f5f5f5"
    style.stroke: "#333333"
    style.stroke-width: 2
  }

  save-state: |md
    **Save State**

    - preserve_review_state.py save
    - preserve before_scores
    - delete old review file
  | {
    shape: rectangle
    style.fill: "#f5f5f5"
    style.stroke: "#333333"
    style.stroke-width: 2
  }

  re-score: |md
    **Re-Score**
    forked LLM

    - score agent on revised plan
    - fresh rubric assessment
  | {
    shape: rectangle
    style.fill: "#e8e8e8"
    style.stroke: "#333333"
    style.stroke-width: 2
    style.double-border: true
  }

  re-review: |md
    **Re-Review**
    forked LLM

    - review agent, first_pass=false
    - write new TestPlanReview.md
  | {
    shape: rectangle
    style.fill: "#e8e8e8"
    style.stroke: "#333333"
    style.stroke-width: 2
    style.double-border: true
  }

  restore-state: |md
    **Restore State**

    - preserve_review_state.py restore
    - merge before_scores back
    - append revision history
  | {
    shape: rectangle
    style.fill: "#f5f5f5"
    style.stroke: "#333333"
    style.stroke-width: 2
  }

  re-check: |md
    **Re-Check**

    - all scores = 2?
    - cycles remaining?
  | {
    shape: rectangle
    style.fill: "#f5f5f5"
    style.stroke: "#333333"
    style.stroke-width: 2
  }

  # Internal edges
  filter -> revise: "actionable items"
  revise -> check-revised
  check-revised -> save-state: "revised = true\ncycles < 2"
  save-state -> re-score
  re-score -> re-review
  re-review -> restore-state
  restore-state -> re-check
}

# --- Step 5: Results ---

results: |md
  **Present Results**

  - score summary table (5 criteria)
  - delta if score changed
  - verdict: Ready / Revise / Rework
  - next-step guidance
| {
  shape: rectangle
  style.fill: "#f5f5f5"
  style.stroke: "#333333"
  style.stroke-width: 2
}

# --- Downstream ---

create-cases: |md
  **/test-plan.create-cases**
| {
  shape: rectangle
  style.fill: "#f5f5f5"
  style.stroke: "#333333"
  style.stroke-width: 2
  style.stroke-dash: 3
}

resolve-feedback: |md
  **/test-plan.resolve-feedback**
| {
  shape: rectangle
  style.fill: "#f5f5f5"
  style.stroke: "#333333"
  style.stroke-width: 2
  style.stroke-dash: 3
}

# --- Rubric callout ---

rubric-detail: |md
  TestPlanReview.md
  scores:
    specificity: 0-2
    grounding: 0-2
    scope_fidelity: 0-2
    actionability: 0-2
    consistency: 0-2
  verdict: Ready/Revise/Rework
  total: 0-10
| {
  shape: rectangle
  style.fill: "#f5f5f5"
  style.stroke: "#bbbbbb"
  style.stroke-width: 1
  style.font: mono
  style.font-size: 10
}

# --- Main Flow ---

entry -> read-plan
read-plan -> fetch-strategy: "source_key"
fetch-strategy -> jira: {
  style.stroke-dash: 3
}
fetch-strategy -> score: "strategy text"
score -> review: "assessment"
review -> check-scores: "TestPlanReview.md"

check-scores -> results: "all = 2 (pass)"
check-scores -> revision-loop.filter: "any < 2 (fail)"

revision-loop.filter -> results: "SKIP" {
  style.stroke-dash: 3
}
revision-loop.check-revised -> results: "revised = false" {
  style.stroke-dash: 3
}
revision-loop.re-check -> results: "all = 2 OR\ncycles exhausted"
revision-loop.re-check -> revision-loop.filter: "still failing" {
  style.stroke-dash: 3
}

# Downstream suggestions
results -> create-cases: "verdict: Ready" {
  style.stroke-dash: 3
}
results -> resolve-feedback: "open PR exists" {
  style.stroke-dash: 3
}

# Callout connection
review -> rubric-detail: {
  style.stroke: "#bbbbbb"
  style.stroke-dash: 4
  style.stroke-width: 1
}
