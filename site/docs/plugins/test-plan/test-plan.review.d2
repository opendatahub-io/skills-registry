direction: right

# ── Global Styles ──────────────────────────────────────
*.style.border-radius: 8
*.style.font-size: 14

# ── Entry ──────────────────────────────────────────────
entry: |md
  ### Parse Arguments
  - Extract feature directory path
  - Auto-detect from session context
  - Locate TestPlan.md
| {
  style: {
    fill: "#e8f5e9"
    stroke: "#2e7d32"
  }
}

# ── Step 0: Read Inputs ───────────────────────────────
read-plan: |md
  ### Read Test Plan
  - Read `TestPlan.md` content
  - Extract `source_key` from frontmatter
  - `frontmatter.py read`
| {
  style: {
    fill: "#e3f2fd"
    stroke: "#1565c0"
  }
}

fetch-strategy: |md
  ### Fetch Source Strategy
  - Jira MCP: `getJiraIssue(source_key)`
  - Fallback: local `strat-tasks/` file
  - Degraded: warn and proceed without
| {
  style: {
    fill: "#fff3e0"
    stroke: "#e65100"
    stroke-dash: 3
  }
}

# ── Step 2: Score ──────────────────────────────────────
score: |md
  ### Score Agent (fork)
  - Apply 5-criterion rubric (0-2 each)
  - Specificity, Grounding, Scope Fidelity
  - Actionability, Consistency
  - Grounding cross-reference table
  - Read calibration examples
| {
  style: {
    fill: "#f3e5f5"
    stroke: "#6a1b9a"
    double-border: true
  }
}

# ── Step 3: Review ─────────────────────────────────────
review: |md
  ### Review Agent (fork)
  - Write `TestPlanReview.md`
  - Set frontmatter scores and verdict
  - Consistency cross-checks (6 checks)
  - Section-by-section feedback
| {
  style: {
    fill: "#f3e5f5"
    stroke: "#6a1b9a"
    double-border: true
  }
}

# ── Step 4: Check & Decide ─────────────────────────────
check-scores: |md
  ### Check Criteria
  - Read review frontmatter
  - All scores = 2?
  - `frontmatter.py read`
| {
  style: {
    fill: "#fff9c4"
    stroke: "#f57f17"
    shape: diamond
  }
}

# ── Revision Loop Container ───────────────────────────
revision-loop: "Revision Loop (max 2 cycles)" {
  style: {
    fill: "#fafafa"
    stroke: "#757575"
    stroke-dash: 5
    border-radius: 12
  }

  filter: |md
    ### Filter for Revision
    - `filter_for_revision.py`
    - Skip if no actionable items
  | {
    style: {
      fill: "#e3f2fd"
      stroke: "#1565c0"
    }
  }

  revise: |md
    ### Revise Agent (fork)
    - Edit only failing sections
    - Criterion-to-section mapping
    - Anti-hallucination constraints
    - Set `auto_revised` flag
  | {
    style: {
      fill: "#f3e5f5"
      stroke: "#6a1b9a"
      double-border: true
    }
  }

  check-revised: |md
    ### Check auto_revised
    - Read frontmatter flag
    - Stop if no changes made
    - Increment cycle counter
  | {
    style: {
      fill: "#fff9c4"
      stroke: "#f57f17"
      shape: diamond
    }
  }

  save-state: |md
    ### Save State
    - `preserve_review_state.py save`
    - Preserve before_scores
    - Delete old review file
  | {
    style: {
      fill: "#e3f2fd"
      stroke: "#1565c0"
    }
  }

  re-score: |md
    ### Re-Score (fork)
    - Score agent on revised plan
    - Fresh rubric assessment
  | {
    style: {
      fill: "#f3e5f5"
      stroke: "#6a1b9a"
      double-border: true
    }
  }

  re-review: |md
    ### Re-Review (fork)
    - Review agent, first_pass=false
    - Write new TestPlanReview.md
  | {
    style: {
      fill: "#f3e5f5"
      stroke: "#6a1b9a"
      double-border: true
    }
  }

  restore-state: |md
    ### Restore State
    - `preserve_review_state.py restore`
    - Merge before_scores back
    - Append revision history
  | {
    style: {
      fill: "#e3f2fd"
      stroke: "#1565c0"
    }
  }

  re-check: |md
    ### Re-Check Criteria
    - All scores = 2?
    - Cycles remaining?
  | {
    style: {
      fill: "#fff9c4"
      stroke: "#f57f17"
      shape: diamond
    }
  }

  # ── Internal edges ──
  filter -> revise: "actionable items"
  revise -> check-revised
  check-revised -> save-state: "revised = true\ncycles < 2"
  save-state -> re-score
  re-score -> re-review
  re-review -> restore-state
  restore-state -> re-check
}

# ── Step 5: Present Results ────────────────────────────
results: |md
  ### Present Results
  - Score summary table (5 criteria)
  - Delta if score changed
  - Verdict: Ready / Revise / Rework
  - Next-step guidance
| {
  style: {
    fill: "#e8f5e9"
    stroke: "#2e7d32"
  }
}

# ── Main Flow Edges ───────────────────────────────────
entry -> read-plan
read-plan -> fetch-strategy
fetch-strategy -> score
score -> review
review -> check-scores

check-scores -> results: "all = 2\n(pass)" {
  style.stroke: "#2e7d32"
}
check-scores -> revision-loop.filter: "any < 2\n(fail)" {
  style.stroke: "#c62828"
}

revision-loop.filter -> results: "SKIP" {
  style: {
    stroke: "#757575"
    stroke-dash: 3
  }
}
revision-loop.check-revised -> results: "revised = false" {
  style: {
    stroke: "#757575"
    stroke-dash: 3
  }
}
revision-loop.re-check -> results: "all = 2 OR\ncycles exhausted" {
  style.stroke: "#2e7d32"
}
revision-loop.re-check -> revision-loop.filter: "still failing\ncycles remain" {
  style: {
    stroke: "#e65100"
    stroke-dash: 3
  }
}
