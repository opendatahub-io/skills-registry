direction: right

*.style.border-radius: 8
*.style.font-size: 13
*.style.fill: "#f5f5f5"
*.style.stroke: "#333333"

# --- Entry ---

entry: |md
  **/test-plan.create-cases**

  - [FEATURE_SOURCE]
  - --output-dir PATH
| {
  shape: rectangle
  style.fill: "#f5f5f5"
  style.stroke: "#333333"
  style.stroke-width: 2
}

# --- Pre-flight (container) ---

preflight: Pre-flight {
  style.fill: "#ececec"
  style.stroke: "#333333"
  style.stroke-width: 2

  deps: |md
    **Check Deps**

    - frontmatter.py schema
    - fail if PyYAML missing
  | {
    shape: rectangle
    style.fill: "#f5f5f5"
    style.stroke: "#333333"
    style.stroke-width: 2
  }

  resolve: |md
    **Resolve Source**

    - session auto-detect
    - argument provided
    - interactive fallback
  | {
    shape: rectangle
    style.fill: "#f5f5f5"
    style.stroke: "#333333"
    style.stroke-width: 2
  }

  locate: |md
    **Locate Feature Dir**

    - repo.py locate-feature-dir
    - local path / GH branch / PR
    - validate against skill repo
  | {
    shape: rectangle
    style.fill: "#f5f5f5"
    style.stroke: "#333333"
    style.stroke-width: 2
  }

  deps -> resolve
  resolve -> locate: "no session ctx"
}

# --- Read Inputs ---

read-plan: |md
  **Read Test Plan**

  - TestPlan.md frontmatter
  - endpoints (Sec 4)
  - strategy, priorities (Sec 2)
  - naming convention (Sec 5.2)
  - scope boundaries (Sec 1.2)
| {
  shape: rectangle
  style.fill: "#f5f5f5"
  style.stroke: "#333333"
  style.stroke-width: 2
}

read-gaps: |md
  **Read Gaps**

  - TestPlanGaps.md (if exists)
  - skip pending/missing areas
| {
  shape: rectangle
  style.fill: "#f5f5f5"
  style.stroke: "#333333"
  style.stroke-width: 2
}

read-template: |md
  **Read Template**

  - test-case-template.md
  - omit empty optional sections
  - placeholders for automation
| {
  shape: rectangle
  style.fill: "#f5f5f5"
  style.stroke: "#333333"
  style.stroke-width: 2
}

# --- Regeneration Detection ---

regen-check: |md
  **Detect Regen Mode**

  - tc_regeneration.py check
  - count existing TC files
  - confirm overwrite (AskUser)
| {
  shape: rectangle
  style.fill: "#f5f5f5"
  style.stroke: "#333333"
  style.stroke-width: 2
}

# --- Generate (container) ---

generate: Design & Generate TCs {
  style.fill: "#ececec"
  style.stroke: "#333333"
  style.stroke-width: 2

  design: |md
    **Design Category TCs**
    LLM

    - one category at a time
    - cover endpoints (Sec 4)
    - positive, negative, boundary
    - assign P0/P1/P2 priorities
    - cross-category dedup
  | {
    shape: rectangle
    style.fill: "#e8e8e8"
    style.stroke: "#333333"
    style.stroke-width: 2
    style.double-border: true
  }

  write-tc: |md
    **Write TC Files**

    - TC-CAT-NUM.md + frontmatter
    - evaluate upgrade_phase
    - Edit (regen) or Write (create)
  | {
    shape: rectangle
    style.fill: "#f5f5f5"
    style.stroke: "#333333"
    style.stroke-width: 2
  }

  e2e: |md
    **E2E Test Cases**
    LLM

    - every P0 endpoint covered
    - complete user journeys
    - TC-E2E-NUM naming
  | {
    shape: rectangle
    style.fill: "#e8e8e8"
    style.stroke: "#333333"
    style.stroke-width: 2
    style.double-border: true
  }

  upgrade: |md
    **Upgrade Test Cases**
    LLM

    - conditional on Sec 7.2
    - assign pre/post/both phase
    - feature-intro vs bug-found
  | {
    shape: rectangle
    style.fill: "#e8e8e8"
    style.stroke: "#333333"
    style.stroke-width: 2
    style.double-border: true
  }

  design -> write-tc
  write-tc -> design: "next category" {
    style.stroke-dash: 3
  }
  write-tc -> e2e: "all categories done"
  e2e -> upgrade: "Sec 7.2\nnon-trivial"
}

# --- Index ---

gen-index: |md
  **Generate INDEX.md**

  - stats: total, P0/P1/P2
  - tables by category
  - links to TestPlan.md
| {
  shape: rectangle
  style.fill: "#f5f5f5"
  style.stroke: "#333333"
  style.stroke-width: 2
}

# --- Update ---

update-plan: |md
  **Update TestPlan.md**

  - Sec 5: TC organization
  - Sec 6: E2E summary + matrix
  - Sec 10: coverage tables
| {
  shape: rectangle
  style.fill: "#f5f5f5"
  style.stroke: "#333333"
  style.stroke-width: 2
}

update-readme: |md
  **Update README**

  - add Test Cases section
  - link to INDEX.md
  - count + priority breakdown
| {
  shape: rectangle
  style.fill: "#f5f5f5"
  style.stroke: "#333333"
  style.stroke-width: 2
}

# --- Validation ---

coverage-val: |md
  **Coverage Validation**

  - endpoint coverage check
  - E2E covers all P0 endpoints
  - test objective coverage
  - priority distribution
  - gap cross-reference
  - append to TestPlanGaps.md
| {
  shape: rectangle
  style.fill: "#f5f5f5"
  style.stroke: "#333333"
  style.stroke-width: 2
}

validate-fm: |md
  **Validate Frontmatter**

  - frontmatter.py validate
  - fix and re-validate
| {
  shape: rectangle
  style.fill: "#f5f5f5"
  style.stroke: "#333333"
  style.stroke-width: 2
}

# --- External: upstream skill ---

test-plan-create: |md
  **/test-plan.create**
| {
  shape: rectangle
  style.fill: "#f5f5f5"
  style.stroke: "#333333"
  style.stroke-width: 2
  style.stroke-dash: 3
}

# --- Callout: TC file structure ---

tc-structure: |md
  test_cases/
    TC-API-001.md
    TC-API-002.md
    TC-UI-001.md
    TC-E2E-001.md
    TC-UPGRADE-001.md
    INDEX.md
| {
  shape: rectangle
  style.fill: "#f5f5f5"
  style.stroke: "#bbbbbb"
  style.stroke-width: 1
  style.font: mono
  style.font-size: 10
}

# --- Flow ---

test-plan-create -> entry: "TestPlan.md" {
  style.stroke-dash: 3
}

entry -> preflight.deps

preflight.resolve -> read-plan: "session ctx"
preflight.locate -> read-plan

read-plan -> read-gaps
read-gaps -> read-template
read-template -> regen-check

regen-check -> generate.design: "create"
regen-check -> generate.design: "regenerate\n(confirm)" {
  style.stroke-dash: 3
}

generate.upgrade -> gen-index
generate.e2e -> gen-index: "no upgrade" {
  style.stroke-dash: 3
}

gen-index -> update-plan
update-plan -> update-readme
update-readme -> coverage-val

coverage-val -> generate.design: "missing E2E" {
  style.stroke-dash: 3
}
coverage-val -> validate-fm

validate-fm -> validate-fm: "errors" {
  style.stroke-dash: 3
}

# --- Callout connection ---

gen-index -> tc-structure: {
  style.stroke: "#bbbbbb"
  style.stroke-dash: 4
  style.stroke-width: 1
}
