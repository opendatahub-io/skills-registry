direction: right

*.style.border-radius: 8
*.style.font-size: 13
*.style.fill: "#f5f5f5"
*.style.stroke: "#333333"

# --- Entry ---

entry: |md
  **test-plan.analyze.risks**
  forked sub-agent

  - strategy files
  - ADR files (optional)
  - additional docs
| {
  shape: rectangle
  style.fill: "#f5f5f5"
  style.stroke: "#333333"
  style.stroke-width: 2
}

# --- Strategy ---

strategy: |md
  **Extract Test Strategy**
  LLM analysis

  - test levels (API, UI,
    perf, security)
  - test types (positive,
    negative, boundary)
  - priority definitions
    (P0/P1/P2 per feature)
| {
  shape: rectangle
  style.fill: "#e8e8e8"
  style.stroke: "#333333"
  style.stroke-width: 2
  style.double-border: true
}

# --- NFR ---

nfr: |md
  **Assess NFRs**
  LLM analysis

  - disconnected/air-gapped
  - upgrade/migration
  - performance/scalability
  - RBAC/authorization
  - N/A with justification
| {
  shape: rectangle
  style.fill: "#e8e8e8"
  style.stroke: "#333333"
  style.stroke-width: 2
  style.double-border: true
}

# --- Risks ---

risks: |md
  **Identify Risks**
  LLM analysis

  - dependencies, external svcs
  - data migration, compat
  - impact + probability
  - concrete mitigations
| {
  shape: rectangle
  style.fill: "#e8e8e8"
  style.stroke: "#333333"
  style.stroke-width: 2
  style.double-border: true
}

# --- Output ---

output: |md
  **Structured Output**

  - Test Strategy (Sec 2)
  - NFRs (Sec 7)
  - Risk table (Sec 8)
  - Gaps list
| {
  shape: rectangle
  style.fill: "#f5f5f5"
  style.stroke: "#333333"
  style.stroke-width: 2
}

# --- Edges ---

entry -> strategy
strategy -> nfr
nfr -> risks
risks -> output
