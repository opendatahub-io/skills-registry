direction: right

*.style.border-radius: 8
*.style.font-size: 13
*.style.fill: "#f5f5f5"
*.style.stroke: "#333333"

# ── Entry ──
entry: |md
  **/test-plan.create**

  - `JIRA_KEY [ADR_FILE_PATH]`
  - Auto-detect from session
  - Interactive fallback
| {
  shape: rectangle
  style.fill: "#dbeafe"
  style.stroke: "#2563eb"
  style.stroke-width: 2
}

# ── Preflight ──
preflight: |md
  **Preflight Checks**

  - Python deps (`frontmatter.py`)
  - MCP availability check
  - Resolve output directory
  - Validate not in skill repo
  - Save preference prompt
| {
  shape: rectangle
  style.fill: "#f5f5f5"
  style.stroke: "#333333"
  style.stroke-width: 2
}

# ── Gather ──
gather: |md
  **Gather Information**

  - Fetch strategy via MCP
  - Extract Jira components
  - Read ADR file (optional)
| {
  shape: rectangle
  style.fill: "#f5f5f5"
  style.stroke: "#333333"
  style.stroke-width: 2
}

# ── External: Jira MCP ──
jira: |md
  **Jira MCP**
| {
  shape: rectangle
  style.fill: "#fff7ed"
  style.stroke: "#c2410c"
  style.stroke-width: 2
  style.stroke-dash: 5
}

# ── Parallel Sub-Agents ──
analyze: **Step 2: Parallel Analysis** {
  style.fill: "#f0fdf4"
  style.stroke: "#16a34a"
  style.stroke-width: 1
  style.stroke-dash: 3
  style.border-radius: 12
  style.font-size: 12

  endpoints: |md
    **analyze.endpoints**
    forked agent

    - Feature scope (in/out)
    - Test objectives
    - API endpoints & priority
    - Sections 1 + 4
  | {
    shape: rectangle
    style.fill: "#e8e8e8"
    style.stroke: "#333333"
    style.stroke-width: 2
    style.double-border: true
  }

  risks: |md
    **analyze.risks**
    forked agent

    - Test levels & types
    - Priority definitions
    - NFR assessments
    - Sections 2, 7 + 8
  | {
    shape: rectangle
    style.fill: "#e8e8e8"
    style.stroke: "#333333"
    style.stroke-width: 2
    style.double-border: true
  }

  infra: |md
    **analyze.infra**
    forked agent

    - Cluster config
    - Test data & users
    - Tooling requirements
    - Sections 3 + 9
  | {
    shape: rectangle
    style.fill: "#e8e8e8"
    style.stroke: "#333333"
    style.stroke-width: 2
    style.double-border: true
  }
}

# ── Generate ──
generate: |md
  **Generate Files**

  - Fill test plan template
  - Write `TestPlan.md`
  - Set frontmatter (script)
  - Write `README.md`
| {
  shape: rectangle
  style.fill: "#f5f5f5"
  style.stroke: "#333333"
  style.stroke-width: 2
}

# ── Gaps ──
gaps: |md
  **Collect Gaps**

  - Extract sub-agent gaps
  - Write `TestPlanGaps.md`
  - Set gaps frontmatter
| {
  shape: rectangle
  style.fill: "#f5f5f5"
  style.stroke: "#333333"
  style.stroke-width: 2
}

# ── Decision ──
decision: |md
  **User Decision**

  1. Provide more docs
  2. Proceed to review
  3. Proceed + create cases
| {
  shape: diamond
  style.fill: "#fef9c3"
  style.stroke: "#a16207"
  style.stroke-width: 2
  style.font-size: 11
}

# ── Review ──
review: |md
  **Review & Score**
  LLM (test-plan.review)

  - 5-criteria rubric (10pt)
  - Auto-revision (max 2x)
  - Write `TestPlanReview.md`
| {
  shape: rectangle
  style.fill: "#e8e8e8"
  style.stroke: "#333333"
  style.stroke-width: 2
  style.double-border: true
}

# ── Auto-fix ──
autofix: |md
  **Auto-Fix**

  - Consistency fixes
  - Feature-specific priorities
  - Never invent for TBDs
| {
  shape: rectangle
  style.fill: "#f5f5f5"
  style.stroke: "#333333"
  style.stroke-width: 2
}

# ── Output ──
output: |md
  **Output**

  - `TestPlan.md`
  - `TestPlanReview.md`
  - `TestPlanGaps.md`
  - `README.md`
| {
  shape: rectangle
  style.fill: "#ecfdf5"
  style.stroke: "#059669"
  style.stroke-width: 2
}

# ── Optional chaining ──
create-cases: |md
  **/test-plan.create-cases**
  (optional chaining)
| {
  shape: rectangle
  style.fill: "#f5f5f5"
  style.stroke: "#999999"
  style.stroke-width: 1
  style.stroke-dash: 5
}

# ── Main flow edges ──
entry -> preflight
preflight -> gather
gather -> jira: "fetch strategy" {style.stroke-dash: 5}
gather -> analyze.endpoints: "parallel" {style.stroke-dash: 5; style.font-style: italic}
gather -> analyze.risks: "parallel" {style.stroke-dash: 5; style.font-style: italic}
gather -> analyze.infra: "parallel" {style.stroke-dash: 5; style.font-style: italic}
analyze.endpoints -> generate: "findings"
analyze.risks -> generate: "findings"
analyze.infra -> generate: "findings"
generate -> gaps
gaps -> decision: "gaps found?"

# ── Decision edges ──
decision -> gather: "1: provide docs" {
  style.stroke: "#a16207"
  style.stroke-dash: 5
  style.font-style: italic
}
decision -> review: "2: proceed" {
  style.stroke: "#16a34a"
}
decision -> review: "3: proceed + cases" {
  style.stroke: "#2563eb"
  style.stroke-dash: 3
}

# ── Review flow ──
review -> autofix: "verdict"
autofix -> output

# ── Optional chaining ──
output -> create-cases: "option 3" {
  style.stroke: "#999999"
  style.stroke-dash: 5
  style.font-style: italic
}
