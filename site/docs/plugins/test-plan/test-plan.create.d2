direction: right

*.style.border-radius: 8
*.style.font-size: 13
*.style.fill: "#f5f5f5"
*.style.stroke: "#333333"

# --- Entry ---

entry: |md
  **/test-plan.create**

  - JIRA_KEY (required)
  - ADR_FILE_PATH (optional)
  - auto-detect from session
| {
  shape: rectangle
  style.fill: "#f5f5f5"
  style.stroke: "#333333"
  style.stroke-width: 2
}

# --- Pre-flight ---

preflight: |md
  **Pre-flight Checks**

  - verify Python deps (uv)
  - check Jira MCP available
  - determine output directory
  - validate not in skill repo
  - save preference prompt
| {
  shape: rectangle
  style.fill: "#f5f5f5"
  style.stroke: "#333333"
  style.stroke-width: 2
}

# --- Gather ---

gather: |md
  **Gather Information**

  - fetch strategy via Jira MCP
  - extract components list
  - read ADR file (if provided)
| {
  shape: rectangle
  style.fill: "#f5f5f5"
  style.stroke: "#333333"
  style.stroke-width: 2
}

# --- External: Jira MCP ---

jira: |md
  **Jira MCP**
| {
  shape: rectangle
  style.fill: "#f5f5f5"
  style.stroke: "#333333"
  style.stroke-width: 2
  style.stroke-dash: 3
}

# --- Parallel Analysis (container) ---

analyze: Parallel Analysis {
  style.fill: "#ececec"
  style.stroke: "#333333"
  style.stroke-width: 2

  endpoints: |md
    **analyze.endpoints**
    forked agent

    - feature scope (in/out)
    - test objectives
    - API endpoints and methods
    - Sections 1 + 4
  | {
    shape: rectangle
    style.fill: "#e8e8e8"
    style.stroke: "#333333"
    style.stroke-width: 2
    style.double-border: true
  }

  risks: |md
    **analyze.risks**
    forked agent

    - test levels and types
    - priority definitions
    - risks with mitigations
    - NFR assessments
    - Sections 2, 7 + 8
  | {
    shape: rectangle
    style.fill: "#e8e8e8"
    style.stroke: "#333333"
    style.stroke-width: 2
    style.double-border: true
  }

  infra: |md
    **analyze.infra**
    forked agent

    - test environment config
    - test data and users
    - tooling requirements
    - Sections 3 + 9
  | {
    shape: rectangle
    style.fill: "#e8e8e8"
    style.stroke: "#333333"
    style.stroke-width: 2
    style.double-border: true
  }
}

# --- Generate ---

generate: |md
  **Generate Files**

  - fill test plan template
  - TestPlan.md (10 sections)
  - set frontmatter via script
  - README.md with links
| {
  shape: rectangle
  style.fill: "#f5f5f5"
  style.stroke: "#333333"
  style.stroke-width: 2
}

# --- Gaps ---

gaps: |md
  **Collect Gaps**

  - merge sub-agent gaps
  - write TestPlanGaps.md
  - set gaps frontmatter
  - present action menu
| {
  shape: rectangle
  style.fill: "#f5f5f5"
  style.stroke: "#333333"
  style.stroke-width: 2
}

# --- Review (external skill) ---

review: |md
  **test-plan.review**

  - 5-criteria rubric (10pt)
  - auto-revision (max 2x)
  - TestPlanReview.md
| {
  shape: rectangle
  style.fill: "#e8e8e8"
  style.stroke: "#333333"
  style.stroke-width: 2
  style.stroke-dash: 3
  style.double-border: true
}

# --- Auto-fix + Summary ---

finalize: |md
  **Finalize**

  - apply auto-fixes (Edit)
  - present score and verdict
  - show remaining gaps
| {
  shape: rectangle
  style.fill: "#f5f5f5"
  style.stroke: "#333333"
  style.stroke-width: 2
}

# --- Output ---

output: |md
  **Output**

  - TestPlan.md
  - TestPlanReview.md
  - TestPlanGaps.md
  - README.md
| {
  shape: rectangle
  style.fill: "#f5f5f5"
  style.stroke: "#333333"
  style.stroke-width: 2
}

# --- Optional downstream ---

create-cases: |md
  **/test-plan.create-cases**
| {
  shape: rectangle
  style.fill: "#f5f5f5"
  style.stroke: "#333333"
  style.stroke-width: 2
  style.stroke-dash: 3
}

# --- Output callout ---

output-tree: |md
  {feature_name}/
    TestPlan.md        <- 10 sections
    TestPlanGaps.md    <- gap tracker
    TestPlanReview.md  <- scores
    README.md          <- links
    test_cases/        <- placeholder
| {
  shape: rectangle
  style.fill: "#f5f5f5"
  style.stroke: "#bbbbbb"
  style.stroke-width: 1
  style.font: mono
  style.font-size: 10
}

# --- Main flow ---

entry -> preflight
preflight -> gather

gather -> jira: "RHAISTRAT / RHOAIENG" {
  style.stroke-dash: 3
}

gather -> analyze.endpoints: "strategy + ADR"
gather -> analyze.risks: "strategy + ADR"
gather -> analyze.infra: "strategy + ADR"

analyze.endpoints -> generate: "scope, endpoints"
analyze.risks -> generate: "levels, risks, NFRs"
analyze.infra -> generate: "env, data, tooling"

generate -> gaps: "TestPlan.md"

# --- Gap resolution loop ---

gaps -> analyze.endpoints: "provide docs" {
  style.stroke-dash: 3
}
gaps -> analyze.risks: "provide docs" {
  style.stroke-dash: 3
}
gaps -> analyze.infra: "provide docs" {
  style.stroke-dash: 3
}

# --- Proceed to review ---

gaps -> review: "proceed"

review -> finalize: "TestPlanReview.md"

finalize -> output

# --- Optional chaining ---

output -> create-cases: "option 3" {
  style.stroke-dash: 3
}

# --- Callout connection ---

output -> output-tree: {
  style.stroke: "#bbbbbb"
  style.stroke-dash: 4
  style.stroke-width: 1
}
