direction: right

*.style.border-radius: 8
*.style.font-size: 13
*.style.fill: "#f5f5f5"
*.style.stroke: "#333333"

# --- External ---

orchestrator: |md
  **test-plan-update**
  (orchestrator)
| {
  shape: rectangle
  style.fill: "#f5f5f5"
  style.stroke: "#333333"
  style.stroke-width: 2
  style.stroke-dash: 3
}

# --- Entry ---

entry: |md
  **resolve-gaps**
  LLM sub-agent (Sonnet)

  - old gaps (TestPlanGaps.md)
  - new analyzer findings
  - new document list
| {
  shape: rectangle
  style.fill: "#e8e8e8"
  style.stroke: "#333333"
  style.stroke-width: 2
  style.double-border: true
}

# --- Parse ---

parse-gaps: |md
  **Parse Old Gaps**

  - scope & endpoints gaps
  - test strategy & risks gaps
  - environment & infra gaps
  - identify resolution criteria
| {
  shape: rectangle
  style.fill: "#f5f5f5"
  style.stroke: "#333333"
  style.stroke-width: 2
}

# --- Matching ---

semantic-match: |md
  **Semantic Gap Matching**
  LLM analysis

  - cross-ref gaps vs new findings
  - intelligent matching (not keyword)
  - handle partial resolution
  - conservative: uncertain = open
| {
  shape: rectangle
  style.fill: "#e8e8e8"
  style.stroke: "#333333"
  style.stroke-width: 2
  style.double-border: true
}

# --- New Gaps ---

new-gaps: |md
  **Identify New Gaps**
  LLM analysis

  - APIs without impl details
  - risks without mitigations
  - deps without version specs
| {
  shape: rectangle
  style.fill: "#e8e8e8"
  style.stroke: "#333333"
  style.stroke-width: 2
  style.double-border: true
}

# --- Output ---

output: |md
  **Structured Output**

  - resolved gaps (with source)
  - unresolved gaps
  - new gaps identified
  - gap count statistics
| {
  shape: rectangle
  style.fill: "#f5f5f5"
  style.stroke: "#333333"
  style.stroke-width: 2
}

# --- Flow ---

orchestrator -> entry: "inline content"
entry -> parse-gaps
parse-gaps -> semantic-match: "categorized gaps"
semantic-match -> new-gaps
new-gaps -> output
