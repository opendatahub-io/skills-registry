<mxGraphModel adaptiveColors="auto">
  <root>
    <mxCell id="0"/>
    <mxCell id="1" parent="0"/>
    <mxCell id="quality-repo-analysis" value="&lt;b&gt;/quality-repo-analysis&lt;/b&gt;&lt;br&gt;&lt;br&gt;Analyzes CI/CD, test coverage,&lt;br&gt;code quality, security, images&lt;br&gt;Scores each dimension 0-10&lt;br&gt;Compares against gold standards&lt;br&gt;Generates HTML + markdown report" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e8e8e8;strokeColor=#333333;strokeWidth=2;arcSize=10;verticalAlign=top;spacingTop=5;fontSize=11;fontFamily=Inter,Helvetica,Arial,sans-serif;" vertex="1" parent="1">
      <mxGeometry x="30" y="40" width="210" height="130" as="geometry"/>
    </mxCell>
    <mxCell id="historical-bug-coverage" value="&lt;b&gt;/historical-bug-coverage&lt;/b&gt;&lt;br&gt;&lt;br&gt;Queries Jira for blocker/critical bugs&lt;br&gt;Deep test analysis with assertions&lt;br&gt;Confidence scoring (0-100%)&lt;br&gt;Generates interactive HTML report" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e8e8e8;strokeColor=#333333;strokeWidth=2;arcSize=10;verticalAlign=top;spacingTop=5;fontSize=11;fontFamily=Inter,Helvetica,Arial,sans-serif;" vertex="1" parent="1">
      <mxGeometry x="300" y="40" width="210" height="130" as="geometry"/>
    </mxCell>
    <mxCell id="test-rules-generator" value="&lt;b&gt;/test-rules-generator&lt;/b&gt;&lt;br&gt;&lt;br&gt;Extracts test patterns from repo&lt;br&gt;Detects unit, mock, E2E, contract&lt;br&gt;Generates .claude/rules/ files&lt;br&gt;Framework-aware (Jest, Cypress, Go)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e8e8e8;strokeColor=#333333;strokeWidth=2;arcSize=10;verticalAlign=top;spacingTop=5;fontSize=11;fontFamily=Inter,Helvetica,Arial,sans-serif;" vertex="1" parent="1">
      <mxGeometry x="570" y="40" width="210" height="130" as="geometry"/>
    </mxCell>
    <mxCell id="konflux-build-simulator" value="&lt;b&gt;/konflux-build-simulator&lt;/b&gt;&lt;br&gt;&lt;br&gt;Simulates Konflux build on PRs&lt;br&gt;Phases: static, Docker, runtime,&lt;br&gt;module-fed, operator, manifest&lt;br&gt;Generates GH Actions workflows&lt;br&gt;Catches build failures pre-merge" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e8e8e8;strokeColor=#333333;strokeWidth=2;arcSize=10;verticalAlign=top;spacingTop=5;fontSize=11;fontFamily=Inter,Helvetica,Arial,sans-serif;" vertex="1" parent="1">
      <mxGeometry x="30" y="220" width="210" height="130" as="geometry"/>
    </mxCell>
    <mxCell id="risk-assessment" value="&lt;b&gt;/risk-assessment&lt;/b&gt;&lt;br&gt;&lt;br&gt;Extracts PR metadata via gh CLI&lt;br&gt;4 parallel agents: risk, test,&lt;br&gt;impact, cross-repo&lt;br&gt;Aggregates scores and decides&lt;br&gt;Advisory only, never blocks PRs" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e8e8e8;strokeColor=#333333;strokeWidth=2;arcSize=10;verticalAlign=top;spacingTop=5;fontSize=11;fontFamily=Inter,Helvetica,Arial,sans-serif;" vertex="1" parent="1">
      <mxGeometry x="30" y="400" width="210" height="130" as="geometry"/>
