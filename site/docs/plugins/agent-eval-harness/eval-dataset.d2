direction: right

*.style.border-radius: 8
*.style.font-size: 13
*.style.fill: "#f5f5f5"
*.style.stroke: "#333333"

# --- Entry ---

args: |md
  **/eval-dataset**

  - --config \<path\>
  - --count \<N\> (default 5)
  - --strategy \<type\>
| {
  shape: rectangle
  style.fill: "#f5f5f5"
  style.stroke: "#333333"
  style.stroke-width: 2
}

# --- Missing Config Decision ---

missing-config: |md
  **eval.yaml
  exists?**
| {
  shape: diamond
  style.fill: "#f5f5f5"
  style.stroke: "#333333"
  style.stroke-width: 2
  style.font-size: 12
}

# --- Invoke eval-analyze ---

invoke-analyze: |md
  **/eval-analyze**
  External skill

  - ask user which skill
  - Skill tool invocation
  - wait for completion
  - re-read eval.yaml
| {
  shape: rectangle
  style.fill: "#f5f5f5"
  style.stroke: "#333333"
  style.stroke-width: 2
  style.stroke-dash: 3
}

# --- Read Context ---

read-context: |md
  **Read Context**

  - eval.yaml config
  - eval.md analysis
  - dataset.schema + execution.mode
  - parse judges for criteria
  - build judge-driven reqs
| {
  shape: rectangle
  style.fill: "#f5f5f5"
  style.stroke: "#333333"
  style.stroke-width: 2
}

# --- Parse Schema ---

parse-schema: |md
  **Parse Schema**

  - required files per case
  - required + optional fields
  - field semantics
  - argument {field} placeholders
  - external-state [EXTERNAL]
| {
  shape: rectangle
  style.fill: "#f5f5f5"
  style.stroke: "#333333"
  style.stroke-width: 2
}

# --- Assess State ---

assess-state: |md
  **Assess Current State**

  - ls dataset_path
  - count existing cases
  - read sample case structure
  - identify coverage gaps
| {
  shape: rectangle
  style.fill: "#f5f5f5"
  style.stroke: "#333333"
  style.stroke-width: 2
}

# --- Strategy Decision ---

strategy: |md
  **Choose
  Strategy**
| {
  shape: diamond
  style.fill: "#f5f5f5"
  style.stroke: "#333333"
  style.stroke-width: 2
  style.font-size: 12
}

# --- Bootstrap ---

bootstrap: |md
  **Bootstrap**
  LLM generation

  - 1 simple case
  - 1 complex case
  - 1 edge case
  - remaining map to judges
| {
  shape: rectangle
  style.fill: "#e8e8e8"
  style.stroke: "#333333"
  style.stroke-width: 2
  style.double-border: true
}

# --- Expand ---

expand: |md
  **Expand**
  LLM generation

  - read all existing cases
  - compare vs judge criteria
  - identify untested scenarios
  - generate gap-filling cases
| {
  shape: rectangle
  style.fill: "#e8e8e8"
  style.stroke: "#333333"
  style.stroke-width: 2
  style.double-border: true
}

# --- From Traces ---

from-traces: |md
  **From Traces**

  - from_traces.py extraction
  - extract real prod inputs
  - structure into case dirs
| {
  shape: rectangle
  style.fill: "#f5f5f5"
  style.stroke: "#333333"
  style.stroke-width: 2
}

# --- MLflow Server ---

mlflow: |md
  **MLflow Server**
| {
  shape: rectangle
  style.fill: "#f5f5f5"
  style.stroke: "#333333"
  style.stroke-width: 2
  style.stroke-dash: 3
}

# --- Generate Cases ---

generate: |md
  **Generate Cases**
  LLM generation

  - create case-NNN-slug/ dirs
  - write required files + fields
  - vary optional fields
  - realistic domain content
  - TODO_ for external-state
  - answers.yaml (interactive)
  - annotations.yaml (judges)
  - companion files
| {
  shape: rectangle
  style.fill: "#e8e8e8"
  style.stroke: "#333333"
  style.stroke-width: 2
  style.double-border: true
}

# --- Validate ---

validate: |md
  **Validate**

  - read back generated case
  - check vs dataset.schema
  - verify {field} placeholders
  - verify companion files
  - check for empty/placeholder
| {
  shape: rectangle
  style.fill: "#f5f5f5"
  style.stroke: "#333333"
  style.stroke-width: 2
}

# --- Report ---

report: |md
  **Report**

  - N cases generated
  - strategy used
  - coverage summary
  - TODO_ placeholders listed
| {
  shape: rectangle
  style.fill: "#f5f5f5"
  style.stroke: "#333333"
  style.stroke-width: 2
}

# --- Downstream Skills ---

eval-run: |md
  **/eval-run**
| {
  shape: rectangle
  style.fill: "#f5f5f5"
  style.stroke: "#333333"
  style.stroke-width: 2
  style.stroke-dash: 3
}

eval-dataset-expand: |md
  **/eval-dataset --expand**
| {
  shape: rectangle
  style.fill: "#f5f5f5"
  style.stroke: "#333333"
  style.stroke-width: 2
  style.stroke-dash: 3
}

# --- Callout: Case Structure ---

case-structure: |md
  case-001-simple-basic/
  ├── input.yaml
  │   ├── required fields
  │   └── {field} placeholders
  ├── reference.md (optional)
  ├── answers.yaml (interactive)
  ├── annotations.yaml (judges)
  └── companion files
| {
  shape: rectangle
  style.fill: "#f5f5f5"
  style.stroke: "#bbbbbb"
  style.stroke-width: 1
  style.font: mono
  style.font-size: 10
}

# --- Flow ---

args -> missing-config

missing-config -> read-context: "yes"
missing-config -> invoke-analyze: "no"

invoke-analyze -> read-context: "eval.yaml"

read-context -> parse-schema: "eval.yaml +\neval.md"
parse-schema -> assess-state: "generation\ntemplate"
assess-state -> strategy

strategy -> bootstrap: "bootstrap\n(default / < 5 cases)"
strategy -> expand: "expand\n(cases exist)"
strategy -> from-traces: "from-traces"

mlflow -> from-traces: "prod traces" {
  style.stroke-dash: 3
}

from-traces -> expand: "no traces\nfound" {
  style.stroke-dash: 3
}

bootstrap -> generate
expand -> generate
from-traces -> generate

generate -> validate
validate -> report

validate -> generate: "schema\nmismatch" {
  style.stroke-dash: 3
}

# --- Downstream ---

report -> eval-run: "next step" {
  style.stroke-dash: 3
}

report -> eval-dataset-expand: "add more\ncases later" {
  style.stroke-dash: 3
}

# --- Callout connection ---

generate -> case-structure {
  style.stroke: "#bbbbbb"
  style.stroke-dash: 4
  style.stroke-width: 1
}
