direction: right

*.style.border-radius: 8
*.style.font-size: 13
*.style.fill: "#f5f5f5"
*.style.stroke: "#333333"

# --- Entry ---

args: |md
  **/eval-dataset**

  - --config <path>
  - --count N (5)
  - --strategy
  - --run-id <id>
| {
  shape: rectangle
  style.fill: "#f5f5f5"
  style.stroke: "#333333"
  style.stroke-width: 2
}

# --- Config discovery ---

discover: |md
  **Discover Config**

  - --config → use directly
  - else discover.py
  - 1 found → select
  - many → ask user
  - none → /eval-analyze
| {
  shape: rectangle
  style.fill: "#f5f5f5"
  style.stroke: "#333333"
  style.stroke-width: 2
  style.stroke-dash: 3
}

# --- Read context ---

read-context: |md
  **Read Context**
  _eval.yaml + eval.md_

  - skill, execution mode
  - dataset.schema + path
  - output schemas
  - extract judges →
    judge-driven reqs
| {
  shape: rectangle
  style.fill: "#f5f5f5"
  style.stroke: "#333333"
  style.stroke-width: 2
}

# --- Parse schema ---

parse-schema: |md
  **Parse Schema**
  _generation template_

  - required files + fields
  - optional fields (vary)
  - field semantics
  - {field} arg placeholders
  - [EXTERNAL] → TODO_
| {
  shape: rectangle
  style.fill: "#f5f5f5"
  style.stroke: "#333333"
  style.stroke-width: 2
}

# --- Assess state ---

assess: |md
  **Assess State**

  - ls dataset_path
  - count existing cases
  - read one sample
  - note coverage gaps
  - check --count vs paths
| {
  shape: rectangle
  style.fill: "#f5f5f5"
  style.stroke: "#333333"
  style.stroke-width: 2
}

# --- Strategy decision ---

strategy: |md
  **Choose Strategy**
| {
  shape: diamond
  style.fill: "#f5f5f5"
  style.stroke: "#333333"
  style.stroke-width: 2
}

# --- Strategy branches (fan-out) ---

bootstrap: |md
  **bootstrap**
  (default, from zero)

  - 1 simple case
  - 1 complex case
  - 1 edge case
  - rest → judge reqs
| {
  shape: rectangle
  style.fill: "#f5f5f5"
  style.stroke: "#333333"
  style.stroke-width: 2
}

expand: |md
  **expand**
  (thin coverage)

  - read existing cases
  - find gaps vs judges
  - continue numbering
| {
  shape: rectangle
  style.fill: "#f5f5f5"
  style.stroke: "#333333"
  style.stroke-width: 2
}

from-traces: |md
  **from-traces**
  (production usage)

  - from_traces.py
  - extract real inputs
  - exit 2 → fall back
    to expand
| {
  shape: rectangle
  style.fill: "#f5f5f5"
  style.stroke: "#333333"
  style.stroke-width: 2
  style.stroke-dash: 3
}

# --- Generate (LLM) ---

generate: |md
  **Generate Cases**
  _LLM synthesis_

  - case-NNN-slug/ dirs
  - input.yaml (all fields)
  - answers.yaml (guidance)
  - annotations.yaml
  - companion files
  - realistic content
| {
  shape: rectangle
  style.fill: "#e8e8e8"
  style.stroke: "#333333"
  style.stroke-width: 2
  style.double-border: true
}

# --- Validate ---

validate-cases: |md
  **Validate**

  - read case back vs schema
  - count files per case
  - {field} placeholders set
  - companion files present
  - both judge if-branches
| {
  shape: rectangle
  style.fill: "#f5f5f5"
  style.stroke: "#333333"
  style.stroke-width: 2
}

# --- Report ---

report: |md
  **Report**

  - N cases at <path>
  - strategy + coverage
  - TODO_ placeholders
  - next: /eval-run
| {
  shape: rectangle
  style.fill: "#f5f5f5"
  style.stroke: "#333333"
  style.stroke-width: 2
}

# --- Callout: case dir structure ---

case-tree: |md
  dataset.path/
    case-001-simple/
      input.yaml
      answers.yaml
      annotations.yaml
      reference.md
    case-002-complex/
      ...
| {
  shape: rectangle
  style.fill: "#f5f5f5"
  style.stroke: "#bbbbbb"
  style.stroke-width: 1
  style.font: mono
  style.font-size: 10
}

# --- Flow ---

args -> discover
discover -> read-context
read-context -> parse-schema
parse-schema -> assess
assess -> strategy

strategy -> bootstrap: "from zero"
strategy -> expand: "cases exist"
strategy -> from-traces: "--strategy\nfrom-traces"

bootstrap -> generate
expand -> generate
from-traces -> generate

generate -> validate-cases
validate-cases -> generate: "schema errors" {
  style.stroke-dash: 3
}
validate-cases -> report

generate -> case-tree: {
  style.stroke: "#bbbbbb"
  style.stroke-dash: 4
  style.stroke-width: 1
}
