direction: right

*.style.border-radius: 8
*.style.font-size: 13
*.style.fill: "#f5f5f5"
*.style.stroke: "#333333"

# --- Entry ---

args: |md
  **/eval-optimize**

  - --config
  - --model
  - --max-iterations N
  - --run-id
  - --target-judge
| {
  shape: rectangle
  style.fill: "#f5f5f5"
  style.stroke: "#333333"
  style.stroke-width: 2
}

# --- Step 0 ---

init: |md
  **Parse Arguments**

  - mkdir tmp/
  - state.py init
  - optimize-config.yaml
| {
  shape: rectangle
  style.fill: "#f5f5f5"
  style.stroke: "#333333"
  style.stroke-width: 2
}

# --- Step 1: Initial Run ---

initial-run: |md
  **Initial Eval Run**

  - invoke /eval-run iter-0
  - or reuse existing run
  - read summary.yaml
| {
  shape: rectangle
  style.fill: "#f5f5f5"
  style.stroke: "#333333"
  style.stroke-width: 2
}

# --- Step 2: Identify Failures ---

identify: |md
  **Identify Failures**

  - which judges failed + cases
  - rationale per failure
  - systematic vs case-specific
  - read review.yaml feedback
  - judge_type: builtin / check
    / llm / code
| {
  shape: rectangle
  style.fill: "#f5f5f5"
  style.stroke: "#333333"
  style.stroke-width: 2
}

# --- Step 3: Analyze Root Causes (LLM agents) ---

analyze: |md
  **Analyze Root Causes**
  LLM agent (Explore)

  - read skill SKILL.md
  - trace transcripts per
    failing case
  - compare actual vs expected
    output
  - form grounded hypotheses
| {
  shape: rectangle
  style.fill: "#e8e8e8"
  style.stroke: "#333333"
  style.stroke-width: 2
  style.double-border: true
}

# --- Step 4: Edit Skill ---

edit: |md
  **Edit the Skill**

  - surgical SKILL.md edits
  - grounded in judge evidence
  - explain why, avoid overfit
  - show edit before applying
| {
  shape: rectangle
  style.fill: "#f5f5f5"
  style.stroke: "#333333"
  style.stroke-width: 2
}

# --- Step 5: Re-Run and Verify ---

verify: |md
  **Re-Run & Verify**

  - invoke /eval-run iter-N
  - --cases (targeted) then full
  - --baseline iter-(N-1)
  - check fixed / regressions
    / score delta
| {
  shape: rectangle
  style.fill: "#f5f5f5"
  style.stroke: "#333333"
  style.stroke-width: 2
}

# --- Step 6: Handle Regressions ---

regressions: |md
  **Handle Regressions**

  - assess severity
  - minor: keep, net positive
  - major: revert, try reframe
  - stuck: report to user
| {
  shape: rectangle
  style.fill: "#f5f5f5"
  style.stroke: "#333333"
  style.stroke-width: 2
}

# --- Step 7: Report ---

report: |md
  **Iterate or Report**

  - all pass: success summary
  - max iters: what's left
  - final summary.yaml scores
| {
  shape: rectangle
  style.fill: "#f5f5f5"
  style.stroke: "#333333"
  style.stroke-width: 2
}

# --- External skills ---

eval-run: |md
  **/eval-run**

  - executes skill on cases
  - runs judges
  - writes summary.yaml
| {
  shape: rectangle
  style.fill: "#f5f5f5"
  style.stroke: "#333333"
  style.stroke-width: 2
  style.stroke-dash: 3
}

downstream: Next Steps {
  style.fill: "#ececec"
  style.stroke: "#333333"
  style.stroke-width: 2
  style.stroke-dash: 3

  mlflow: |md
    **/eval-mlflow**
    log optimization run
  | {
    shape: rectangle
    style.fill: "#f5f5f5"
    style.stroke: "#333333"
    style.stroke-width: 2
    style.stroke-dash: 3
  }
  review: |md
    **/eval-review**
    human assessment
  | {
    shape: rectangle
    style.fill: "#f5f5f5"
    style.stroke: "#333333"
    style.stroke-width: 2
    style.stroke-dash: 3
  }
  dataset: |md
    **/eval-dataset**
    expand coverage
  | {
    shape: rectangle
    style.fill: "#f5f5f5"
    style.stroke: "#333333"
    style.stroke-width: 2
    style.stroke-dash: 3
  }
}

# --- Callout: summary.yaml ---

summary-shape: |md
  summary.yaml
  judges:
    - name
      passed: bool
      score
      rationale
      judge_type
  human_review:
    - case_id
      comment
| {
  shape: rectangle
  style.fill: "#f5f5f5"
  style.stroke: "#bbbbbb"
  style.stroke-width: 1
  style.font: mono
  style.font-size: 10
}

# --- Flow ---

args -> init
init -> initial-run
initial-run -> eval-run: "invoke iter-0" {
  style.stroke-dash: 3
}
initial-run -> identify: "summary.yaml"
identify -> analyze: "failure map"
analyze -> edit: "hypotheses"
edit -> verify: "edited SKILL.md"
verify -> eval-run: "invoke iter-N" {
  style.stroke-dash: 3
}
verify -> regressions: "summary.yaml"

# decision out of regressions
regressions -> report: "all pass\nor max iters"
regressions -> identify: "iterate\n(failures remain)" {
  style.stroke-dash: 3
}
regressions -> edit: "major\nrevert + retry" {
  style.stroke-dash: 3
}

# downstream suggestions
report -> downstream.mlflow: optional {
  style.stroke-dash: 3
}
report -> downstream.review: "remaining\nfailures" {
  style.stroke-dash: 3
}
report -> downstream.dataset: "missing\ncoverage" {
  style.stroke-dash: 3
}

# callout
identify -> summary-shape: {
  style.stroke: "#bbbbbb"
  style.stroke-dash: 4
  style.stroke-width: 1
}
