direction: right

*.style.border-radius: 8
*.style.font-size: 13
*.style.fill: "#f5f5f5"
*.style.stroke: "#333333"

# --- Entry ---

args: |md
  **/eval-mlflow**

  - --action <action>
    (sync-dataset | log-results |
    push-feedback | pull-feedback | all)
  - --config <path> (auto-discover)
  - --run-id <id> (log / push / pull)
| {
  shape: rectangle
  style.fill: "#f5f5f5"
  style.stroke: "#333333"
  style.stroke-width: 2
}

# --- Step 0-2: load config + verify ---

config: |md
  **Load Config**

  - discover.py eval configs
  - 1 auto, many ask user
  - read mlflow.experiment
  - dataset.path + schema, judges
| {
  shape: rectangle
  style.fill: "#f5f5f5"
  style.stroke: "#333333"
  style.stroke-width: 2
}

verify: |md
  **Verify MLflow**

  - ensure_server() reachable?
  - URI: eval.yaml > env > :5000
  - remote set: proceed anyway
  - else suggest /eval-setup
| {
  shape: rectangle
  style.fill: "#f5f5f5"
  style.stroke: "#333333"
  style.stroke-width: 2
}

# --- Dispatch on --action ---

dispatch: |md
  **Action?**
| {
  shape: diamond
  style.fill: "#f5f5f5"
  style.stroke: "#333333"
  style.stroke-width: 2
}

# --- Operations (one per --action) ---

sync: |md
  **Sync Dataset**
  two-phase (LLM + script)

  - read dataset.schema + sample
  - interpret -> schema_mapping.json
  - sync_dataset.py validates + preview
  - push records to MLflow dataset
| {
  shape: rectangle
  style.fill: "#e8e8e8"
  style.stroke: "#333333"
  style.stroke-width: 3
  style.double-border: true
}

log: |md
  **Log Results**
  log_results.py --run-id

  - params: skill, runner, model
  - metrics: per-judge mean/pass_rate,
    duration, cost, tokens
  - artifacts: summary.yaml + table
  - one trace per case / run
| {
  shape: rectangle
  style.fill: "#f5f5f5"
  style.stroke: "#333333"
  style.stroke-width: 2
}

pushfb: |md
  **Push Feedback**
  attach_feedback.py --source all

  - judge: source_type=CODE
    ({case}/{judge}) from summary.yaml
  - human: source_type=HUMAN
    ({case}/human_review) from review.yaml
  - no traces? report 0, succeed
| {
  shape: rectangle
  style.fill: "#f5f5f5"
  style.stroke: "#333333"
  style.stroke-width: 2
}

pullfb: |md
  **Pull Feedback**
  attach_feedback.py --action pull

  - read UI annotations on traces
  - write review.yaml mlflow_feedback
  - separate from local human review
  - consumed by /eval-optimize
| {
  shape: rectangle
  style.fill: "#f5f5f5"
  style.stroke: "#333333"
  style.stroke-width: 2
}

# --- External service ---

mlflow: |md
  **MLflow Server**
  external service

  - dataset registry
  - runs: params, metrics, artifacts
  - traces + feedback
  - annotation UI ($MLFLOW_TRACKING_URI)
| {
  shape: rectangle
  style.fill: "#e8e8e8"
  style.stroke: "#333333"
  style.stroke-width: 2
  style.stroke-dash: 3
}

# --- Output ---

report: |md
  **Report & Next Steps**

  - synced N cases / logged run
  - pushed N / pulled N feedback
  - MLflow UI tracking URI
  - next: /eval-review, /eval-optimize
| {
  shape: rectangle
  style.fill: "#f5f5f5"
  style.stroke: "#333333"
  style.stroke-width: 2
}

# --- Callouts ---

mapping-tree: |md
  tmp/schema_mapping.json
  {
    "inputs": {
      "prompt":
        "input.yaml:prompt"
    },
    "expectations": {
      "ref":
        "reference.md:__file__"
    }
  }
| {
  shape: rectangle
  style.fill: "#f5f5f5"
  style.stroke: "#bbbbbb"
  style.stroke-width: 1
  style.font: mono
  style.font-size: 10
}

review-tree: |md
  review.yaml
    human_review:
      case-001: {...}
    mlflow_feedback:
      case-001:
        source: HUMAN
        value: ...
| {
  shape: rectangle
  style.fill: "#f5f5f5"
  style.stroke: "#bbbbbb"
  style.stroke-width: 1
  style.font: mono
  style.font-size: 10
}

# --- Flow ---

args -> config
config -> verify
verify -> dispatch

# --- Dispatch fan-out (one branch per --action) ---

dispatch -> sync: "sync-dataset / all"
dispatch -> log: "log-results / all"
dispatch -> pushfb: "push-feedback / all"
dispatch -> pullfb: "pull-feedback"

# --- Operations push to MLflow ---

sync -> mlflow: "push cases" {
  style.stroke-dash: 3
}
log -> mlflow: "push run" {
  style.stroke-dash: 3
}
pushfb -> mlflow: "push feedback" {
  style.stroke-dash: 3
}

# --- Pull annotations back from MLflow UI ---

mlflow -> pullfb: "pull annotations" {
  style.stroke-dash: 3
}

# --- Converge to report ---

sync -> report
log -> report
pushfb -> report
pullfb -> report

# --- Callout connections ---

sync -> mapping-tree: {
  style.stroke: "#bbbbbb"
  style.stroke-dash: 4
  style.stroke-width: 1
}
pullfb -> review-tree: {
  style.stroke: "#bbbbbb"
  style.stroke-dash: 4
  style.stroke-width: 1
}
