direction: right

*.style.border-radius: 8
*.style.font-size: 13
*.style.fill: "#f5f5f5"
*.style.stroke: "#333333"

# --- Entry ---

entry: |md
  **/eval-mlflow**

  - --action (sync-dataset,
    log-results, push-feedback,
    pull-feedback, all)
  - --config eval.yaml
  - --run-id (for log/push/pull)
| {
  shape: rectangle
  style.fill: "#f5f5f5"
  style.stroke: "#333333"
  style.stroke-width: 2
}

# --- Verify MLflow ---

verify: |md
  **Verify MLflow**

  - ensure_server() check
  - resolve tracking URI
    (eval.yaml → env → default)
  - suggest /eval-setup if down
| {
  shape: rectangle
  style.fill: "#f5f5f5"
  style.stroke: "#333333"
  style.stroke-width: 2
}

# --- Read Config ---

read-config: |md
  **Read Config**

  - mlflow.experiment name
  - dataset.path + schema
  - judges (for context)
| {
  shape: rectangle
  style.fill: "#f5f5f5"
  style.stroke: "#333333"
  style.stroke-width: 2
}

# --- Sync Dataset Container ---

sync: {
  label: "Sync Dataset"
  style.fill: "#ececec"
  style.stroke: "#333333"
  style.stroke-width: 2

  read-schema: |md
    **Read Schema**

    - read dataset.schema
    - browse case directory
    - sample file structure
  | {
    shape: rectangle
    style.fill: "#f5f5f5"
    style.stroke: "#333333"
    style.stroke-width: 2
  }

  build-mapping: |md
    **Build Mapping**
    LLM interpretation

    - inputs vs expectations
    - file:field_path pairs
    - __file__ for whole files
    - write schema_mapping.json
  | {
    shape: rectangle
    style.fill: "#e8e8e8"
    style.stroke: "#333333"
    style.stroke-width: 2
    style.double-border: true
  }

  run-sync: |md
    **Run Sync**

    - sync_dataset.py
    - validate mapping preview
    - sync records to MLflow
    - deduplicates on merge
  | {
    shape: rectangle
    style.fill: "#f5f5f5"
    style.stroke: "#333333"
    style.stroke-width: 2
  }

  read-schema -> build-mapping
  build-mapping -> run-sync: "schema_mapping.json"

  run-sync -> build-mapping: "preview wrong" {
    style.stroke-dash: 3
  }
}

# --- Log Results ---

log-results: |md
  **Log Results**

  - log_results.py
  - params: skill, model, runner
  - metrics: judge scores,
    cost, tokens, duration
  - artifacts: summary.yaml
  - table: per-case results
  - traces from stdout.log
  - tags: regressions, judges
| {
  shape: rectangle
  style.fill: "#f5f5f5"
  style.stroke: "#333333"
  style.stroke-width: 2
}

# --- Push Feedback ---

push-feedback: |md
  **Push Feedback**

  - attach_feedback.py
  - find execution traces
  - judge → CODE feedback
  - human → HUMAN feedback
  - skips if no traces exist
| {
  shape: rectangle
  style.fill: "#f5f5f5"
  style.stroke: "#333333"
  style.stroke-width: 2
}

# --- Pull Feedback ---

pull-feedback: |md
  **Pull Feedback**

  - attach_feedback.py --pull
  - MLflow UI annotations
  - save to review.yaml
    (mlflow_feedback section)
| {
  shape: rectangle
  style.fill: "#f5f5f5"
  style.stroke: "#333333"
  style.stroke-width: 2
}

# --- Report ---

report: |md
  **Report**

  - N cases synced
  - run logged to experiment
  - N feedback entries pushed
  - N annotations pulled
  - MLflow UI link
| {
  shape: rectangle
  style.fill: "#f5f5f5"
  style.stroke: "#333333"
  style.stroke-width: 2
}

# --- External: MLflow Server ---

mlflow-server: |md
  **MLflow Server**

  - experiment tracking
  - dataset registry
  - trace storage
  - feedback/assessments
| {
  shape: rectangle
  style.fill: "#f5f5f5"
  style.stroke: "#333333"
  style.stroke-width: 2
  style.stroke-dash: 3
}

# --- External: /eval-setup ---

eval-setup: |md
  **/eval-setup**
| {
  shape: rectangle
  style.fill: "#f5f5f5"
  style.stroke: "#333333"
  style.stroke-width: 2
  style.stroke-dash: 3
}

# --- Downstream: /eval-review ---

eval-review: |md
  **/eval-review**
| {
  shape: rectangle
  style.fill: "#f5f5f5"
  style.stroke: "#333333"
  style.stroke-width: 2
  style.stroke-dash: 3
}

# --- Downstream: /eval-optimize ---

eval-optimize: |md
  **/eval-optimize**
| {
  shape: rectangle
  style.fill: "#f5f5f5"
  style.stroke: "#333333"
  style.stroke-width: 2
  style.stroke-dash: 3
}

# --- Callout: schema_mapping.json ---

mapping-callout: |md
  ```
  schema_mapping.json
  {
    "inputs": {
      "prompt": "input.yaml:prompt",
      "context": "input.yaml:context"
    },
    "expectations": {
      "ref": "reference.md:__file__"
    }
  }
  ```
| {
  shape: rectangle
  style.fill: "#f5f5f5"
  style.stroke: "#bbbbbb"
  style.stroke-width: 1
  style.font: mono
  style.font-size: 10
}

# --- Flow ---

entry -> verify
verify -> read-config

verify -> eval-setup: "not reachable" {
  style.stroke-dash: 3
}

read-config -> sync: "sync-dataset\nor all"
read-config -> log-results: "log-results\nor all"
read-config -> push-feedback: "push-feedback\nor all"
read-config -> pull-feedback: "pull-feedback"

# Sequential flow when action=all
sync -> log-results: "all" {
  style.stroke-dash: 3
}
log-results -> push-feedback: "all" {
  style.stroke-dash: 3
}

# MLflow Server connections
verify -> mlflow-server
sync.run-sync -> mlflow-server: "dataset registry"
log-results -> mlflow-server: "experiment run"
push-feedback -> mlflow-server: "trace feedback"
pull-feedback -> mlflow-server: "annotations"

# Callout connection
sync.build-mapping -> mapping-callout: {
  style.stroke: "#bbbbbb"
  style.stroke-dash: 4
  style.stroke-width: 1
}

# Converge to report
sync -> report
log-results -> report
push-feedback -> report
pull-feedback -> report: "review.yaml"

# Downstream suggestions
report -> eval-review: "next step" {
  style.stroke-dash: 3
}
report -> eval-optimize: "next step" {
  style.stroke-dash: 3
}

# Pull feedback feeds optimize
pull-feedback -> eval-optimize: "review.yaml" {
  style.stroke-dash: 3
}
