direction: right

*.style.border-radius: 8
*.style.font-size: 13
*.style.fill: "#f5f5f5"
*.style.stroke: "#333333"

# --- Entry ---

args: |md
  **/eval-analyze**

  - --skill <name>
  - --config <path>
  - --update
| {
  shape: rectangle
  style.fill: "#f5f5f5"
  style.stroke: "#333333"
  style.stroke-width: 2
}

# --- Setup / discovery ---

discover: |md
  **Discover Layout**

  - state.py init tmp/
  - discover.py for configs
  - root vs eval/ layout
  - resolve config path
  - set eval.md path
| {
  shape: rectangle
  style.fill: "#f5f5f5"
  style.stroke: "#333333"
  style.stroke-width: 2
}

find-skill: |md
  **Find Target Skill**

  - find_skills.py
  - reads plugin.json paths
  - falls back .claude/skills/
  - auto-detect if single
| {
  shape: rectangle
  style.fill: "#f5f5f5"
  style.stroke: "#333333"
  style.stroke-width: 2
}

# --- Freshness decision ---

freshness: |md
  **Freshness Check**

  - config exists?
  - validate_eval.py config
  - validate_eval.py memory
  - SKILL.md hash unchanged?
| {
  shape: diamond
  style.fill: "#f5f5f5"
  style.stroke: "#333333"
  style.stroke-width: 2
}

# --- Deep analysis (LLM) ---

deep-read: |md
  **Deep-Read Skill**
  LLM agent (Explore)

  - read analyze-skill.md
  - read SKILL.md fully
  - follow sub-skill chains
    (recursive, max 5 levels)
  - read scripts/, prompts/
  - return purpose, I/O,
    pipeline, judges
| {
  shape: rectangle
  style.fill: "#e8e8e8"
  style.stroke: "#333333"
  style.stroke-width: 2
  style.double-border: true
}

explore-dataset: |md
  **Explore Dataset**

  - Glob cases/, fixtures/,
    eval/, tests/data/
  - read one full sample case
  - note field names, formats
  - input vs reference files
| {
  shape: rectangle
  style.fill: "#f5f5f5"
  style.stroke: "#333333"
  style.stroke-width: 2
}

# --- Generation (LLM) ---

gen-yaml: |md
  **Generate eval.yaml**
  LLM synthesis

  - execution mode + args
  - dataset.schema (observed)
  - output schemas
  - 1-2 builtin judges
  - 2-3 inline checks
  - 1-2 LLM judges
  - models, thresholds
| {
  shape: rectangle
  style.fill: "#e8e8e8"
  style.stroke: "#333333"
  style.stroke-width: 2
  style.double-border: true
}

builtins: |md
  **Builtin Judges**

  - list_builtins.py
  - reusable check + LLM
| {
  shape: rectangle
  style.fill: "#e8e8e8"
  style.stroke: "#333333"
  style.stroke-width: 2
  style.stroke-dash: 3
}

validate: |md
  **Validate Config**

  - validate_eval.py config
  - dataset path exists
  - paths relative
  - judge refs resolve
| {
  shape: rectangle
  style.fill: "#f5f5f5"
  style.stroke: "#333333"
  style.stroke-width: 2
}

gen-md: |md
  **Generate eval.md**

  - generate-eval-md.md
  - SKILL.md hash (SHA256)
  - cache skill analysis
  - YAML frontmatter
| {
  shape: rectangle
  style.fill: "#f5f5f5"
  style.stroke: "#333333"
  style.stroke-width: 2
}

# --- Output ---

report-out: |md
  **Report (Outputs)**

  - eval.yaml created
  - eval.md cached
  - N judges, M cases
  - next: /eval-dataset
    or /eval-run
| {
  shape: rectangle
  style.fill: "#f5f5f5"
  style.stroke: "#333333"
  style.stroke-width: 2
}

# --- Callouts ---

layout-tree: |md
  project/
  eval.yaml          # root layout
  eval/
    <skill-a>/
      eval.yaml
      eval.md
      cases/
        case-001/
          input.yaml
          reference.md
          annotations.yaml
| {
  shape: rectangle
  style.fill: "#f5f5f5"
  style.stroke: "#bbbbbb"
  style.stroke-width: 1
  style.font: mono
  style.font-size: 10
}

eval-yaml-schema: |md
  eval.yaml
    skill: <name>
    execution:
      mode: case|batch
      arguments: "{field}"
    runner: {type: claude-code}
    models: {skill, judge, hook}
    dataset: {path, schema}
    inputs: {tools: [match,prompt]}
    outputs: [{path, schema}]
    judges:
      builtin: cost_budget
      check: <python>
      prompt: <LLM rubric>
    thresholds:
      {judge: {min_pass_rate}}
| {
  shape: rectangle
  style.fill: "#f5f5f5"
  style.stroke: "#bbbbbb"
  style.stroke-width: 1
  style.font: mono
  style.font-size: 10
}

# --- Flow ---

args -> discover
discover -> find-skill
find-skill -> freshness

freshness -> report-out: "FRESH + COMPLETE" {
  style.stroke-dash: 3
}
freshness -> deep-read: "STALE / NO_CONFIG / --update"

deep-read -> explore-dataset
explore-dataset -> gen-yaml
builtins -> gen-yaml: "builtin: refs" {
  style.stroke-dash: 3
}

gen-yaml -> validate
validate -> gen-yaml: errors {
  style.stroke-dash: 3
}
validate -> gen-md: ok
gen-md -> report-out

# --- Callout connectors ---

discover -> layout-tree: {
  style.stroke: "#bbbbbb"
  style.stroke-dash: 4
  style.stroke-width: 1
}
gen-yaml -> eval-yaml-schema: {
  style.stroke: "#bbbbbb"
  style.stroke-dash: 4
  style.stroke-width: 1
}
