direction: right

*.style.border-radius: 8
*.style.font-size: 13
*.style.fill: "#f5f5f5"
*.style.stroke: "#333333"

# --- Entry ---

entry: |md
  **/eval-run**

  - --config <path>
  - --model / --subagent-model
  - --skill <name>
  - --run-id <id>
  - --cases <id ...>
  - --baseline <run-id>
  - --no-llm-judges / --gold
  - --effort <level>
| {
  shape: rectangle
  style.fill: "#f5f5f5"
  style.stroke: "#333333"
  style.stroke-width: 2
}

# --- Step 0: Config discovery ---

discover: |md
  **Step 0: Discover Config**

  - run discover.py
  - 1 found: auto-select
  - many: ask user
  - read skill, runner, dataset,
    judges, models
  - state.py init flags
| {
  shape: rectangle
  style.fill: "#f5f5f5"
  style.stroke: "#333333"
  style.stroke-width: 2
}

bootstrap: |md
  **/eval-analyze**

  - invoked if no config
  - generates eval.yaml
| {
  shape: rectangle
  style.fill: "#e8e8e8"
  style.stroke: "#333333"
  style.stroke-width: 2
  style.stroke-dash: 3
}

# --- Step 1: Find dataset ---

find-dataset: |md
  **Step 1: Find Dataset**

  - read dataset.path
  - verify case subdirs
  - apply --cases filter
  - empty: suggest /eval-dataset
| {
  shape: rectangle
  style.fill: "#f5f5f5"
  style.stroke: "#333333"
  style.stroke-width: 2
}

# --- Step 2: Preflight ---

preflight: |md
  **Step 2: Preflight**

  - preflight.py --config
  - scan tmp/ state files
  - check run-id / baseline
  - detect stale artifacts
| {
  shape: rectangle
  style.fill: "#f5f5f5"
  style.stroke: "#333333"
  style.stroke-width: 2
}

clean-gate: |md
  **CLEAN / DIRTY /
  MISSING_BASELINE?**
| {
  shape: diamond
  style.fill: "#f5f5f5"
  style.stroke: "#333333"
  style.stroke-width: 2
}

# --- Step 3: Workspace ---

workspace: |md
  **Step 3: Prepare Workspace**

  - workspace.py --run-id
  - case or batch mode
  - copy inputs, symlinks
  - create output dirs
  - .claude/settings.json
  - emit WORKSPACE / CASES
| {
  shape: rectangle
  style.fill: "#f5f5f5"
  style.stroke: "#333333"
  style.stroke-width: 2
}

resolve-tools: |md
  **Step 3b: Resolve Tools**

  - if inputs.tools set
  - read tool_handlers.yaml
  - add input_filters,
    env_checks, overrides
  - verify Bash filters
| {
  shape: rectangle
  style.fill: "#f5f5f5"
  style.stroke: "#333333"
  style.stroke-width: 2
}

# --- Step 4: Execute (LLM runner) ---

execute: |md
  **Step 4: Execute Skill**
  LLM runner (headless)

  - execute.py --workspace
  - claude --print per case
  - parallelism thread pool
  - stream-json capture
  - run_in_background, tail
| {
  shape: rectangle
  style.fill: "#e8e8e8"
  style.stroke: "#333333"
  style.stroke-width: 2
  style.double-border: true
}

exit-gate: |md
  **exit_code == 0?**
| {
  shape: diamond
  style.fill: "#f5f5f5"
  style.stroke: "#333333"
  style.stroke-width: 2
}

# --- Step 5: Collect ---

collect: |md
  **Step 5: Collect Artifacts**

  - collect.py --workspace
  - map files to cases
  - git diff -> _modified/
  - read collection.json
  - warn on 0 artifacts
| {
  shape: rectangle
  style.fill: "#f5f5f5"
  style.stroke: "#333333"
  style.stroke-width: 2
}

# --- Step 6: Score (container) ---

scoring: "Step 6: Score" {
  style.fill: "#ececec"
  style.stroke: "#333333"
  style.stroke-width: 2

  judge-builtin: |md
    **builtin + check**

    - harness library
    - inline Python snippets
    - deterministic
  | {
    shape: rectangle
    style.fill: "#f5f5f5"
    style.stroke: "#333333"
    style.stroke-width: 2
  }
  judge-llm: |md
    **LLM prompt / prompt_file**
    LLM judge

    - Jinja2 rendered
    - skip if --no-llm-judges
  | {
    shape: rectangle
    style.fill: "#e8e8e8"
    style.stroke: "#333333"
    style.stroke-width: 2
    style.double-border: true
  }
  judge-external: |md
    **external module / function**

    - dotted import path
    - arguments: params
  | {
    shape: rectangle
    style.fill: "#e8e8e8"
    style.stroke: "#333333"
    style.stroke-width: 2
    style.stroke-dash: 3
  }
  pairwise: |md
    **pairwise (--baseline)**
    LLM judge

    - score.py pairwise
    - regression detect
  | {
    shape: rectangle
    style.fill: "#e8e8e8"
    style.stroke: "#333333"
    style.stroke-width: 2
    style.double-border: true
  }
}

# --- Step 7: Interpret (LLM) ---

interpret: |md
  **Step 7: Interpret**
  LLM analysis

  - read summary.yaml
  - analyze-results.md
  - failure patterns,
    root causes, cost
  - write analysis.md
| {
  shape: rectangle
  style.fill: "#e8e8e8"
  style.stroke: "#333333"
  style.stroke-width: 2
  style.double-border: true
}

report-out: |md
  **Report + Next Steps**

  - report.py --open
  - report.html
  - --gold: save refs
  - suggest /eval-review,
    /eval-optimize
| {
  shape: rectangle
  style.fill: "#f5f5f5"
  style.stroke: "#333333"
  style.stroke-width: 2
}

# --- Step 8: MLflow (optional external skill) ---

mlflow: |md
  **/eval-mlflow**

  - if mlflow.experiment
  - log-results --run-id
| {
  shape: rectangle
  style.fill: "#e8e8e8"
  style.stroke: "#333333"
  style.stroke-width: 2
  style.stroke-dash: 3
}

# --- Callouts ---

workspace-tree: |md
  /tmp/agent-eval/{id}/
  case_order.yaml
  cases/
    case-001-name/
      input.yaml
      answers.yaml
      {output_dirs}/
      .claude/settings.json
      subagents/
  batch.yaml  (batch mode)
| {
  shape: rectangle
  style.fill: "#f5f5f5"
  style.stroke: "#bbbbbb"
  style.stroke-width: 1
  style.font: mono
  style.font-size: 10
}

handlers-snippet: |md
  handlers:
  - patterns: [AskUserQuestion]
    case_overrides: {...}
  - patterns: [Bash, mcp__*]
    input_filters: [jira]
    env_checks:
      JIRA_SERVER:
        must_contain: [test]
  hook_model: claude-haiku
| {
  shape: rectangle
  style.fill: "#f5f5f5"
  style.stroke: "#bbbbbb"
  style.stroke-width: 1
  style.font: mono
  style.font-size: 10
}

summary-snippet: |md
  summary.yaml:
    judges:
      <j>: {mean, pass_rate}
    per_case:
      <case>: {value, rationale}
    pairwise:
      wins_a, wins_b, ties
| {
  shape: rectangle
  style.fill: "#f5f5f5"
  style.stroke: "#bbbbbb"
  style.stroke-width: 1
  style.font: mono
  style.font-size: 10
}

# --- Flow ---

entry -> discover
discover -> find-dataset: "config found"
discover -> bootstrap: "no config"
bootstrap -> find-dataset: "eval.yaml"

find-dataset -> preflight
preflight -> clean-gate
clean-gate -> preflight: "DIRTY: --clean --force" {
  style.stroke-dash: 3
}
clean-gate -> preflight: "MISSING_BASELINE" {
  style.stroke-dash: 3
}
clean-gate -> workspace: "CLEAN"

workspace -> resolve-tools: "inputs.tools"
resolve-tools -> execute
workspace -> execute: "no tools" {
  style.stroke-dash: 3
}

execute -> exit-gate
exit-gate -> collect: "0 (ok)"
exit-gate -> report-out: "non-zero: abort" {
  style.stroke-dash: 3
}

collect -> scoring: "collection.json"
scoring -> interpret: "summary.yaml"
interpret -> report-out
report-out -> mlflow: "optional" {
  style.stroke-dash: 3
}

# --- Callout connectors ---

workspace -> workspace-tree: {
  style.stroke: "#bbbbbb"
  style.stroke-dash: 4
  style.stroke-width: 1
}
resolve-tools -> handlers-snippet: {
  style.stroke: "#bbbbbb"
  style.stroke-dash: 4
  style.stroke-width: 1
}
interpret -> summary-snippet: {
  style.stroke: "#bbbbbb"
  style.stroke-dash: 4
  style.stroke-width: 1
}
