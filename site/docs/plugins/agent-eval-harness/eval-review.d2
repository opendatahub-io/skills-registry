direction: right

*.style.border-radius: 8
*.style.font-size: 13
*.style.fill: "#f5f5f5"
*.style.stroke: "#333333"

# --- Entry ---

entry: |md
  **/eval-review**

  - --run-id \<id\> (required)
  - --config \<path\>
  - --cases \<name ...\>
| {
  shape: rectangle
  style.fill: "#f5f5f5"
  style.stroke: "#333333"
  style.stroke-width: 2
}

# --- Load Results ---

load-results: |md
  **Load Results**

  - state.py read summary.yaml
  - read eval.yaml config
  - note skill, dataset, judges
  - deterministic vs LLM judges
| {
  shape: rectangle
  style.fill: "#f5f5f5"
  style.stroke: "#333333"
  style.stroke-width: 2
}

# --- Present Overview ---

overview: |md
  **Present Overview**

  - read analysis.md if present
  - link to report.html
  - pass rates per judge
  - pairwise win/loss/tie
| {
  shape: rectangle
  style.fill: "#f5f5f5"
  style.stroke: "#333333"
  style.stroke-width: 2
}

# --- Walk Through Cases ---

walk-cases: |md
  **Walk Through Cases**
  human-in-the-loop

  - judge scores + rationale
  - pairwise results
  - summarize output files
  - ask feedback per case
| {
  shape: rectangle
  style.fill: "#e8e8e8"
  style.stroke: "#333333"
  style.stroke-width: 2
  style.double-border: true
}

# --- Check Transcripts ---

check-transcripts: |md
  **Check Transcripts**
  Agent delegation

  - check execution_mode
    (case vs batch)
  - spawn Agent on stdout.log
  - multi-approach? wasted turns?
  - error recovery patterns
| {
  shape: rectangle
  style.fill: "#e8e8e8"
  style.stroke: "#333333"
  style.stroke-width: 2
  style.double-border: true
}

# --- Save Feedback ---

save-feedback: |md
  **Save Feedback**

  - Write review.yaml (NOT state.py)
  - reviewer: "human"
  - keys = case dir names
  - empty = acceptable
| {
  shape: rectangle
  style.fill: "#f5f5f5"
  style.stroke: "#333333"
  style.stroke-width: 2
}

# --- review.yaml callout ---

review-yaml: |md
  review.yaml
  run_id: "\<id\>"
  reviewed_cases: N
  feedback_cases: M
  reviewer: "human"
  feedback:
    case-001: "comment"
    case-002: ""
| {
  shape: rectangle
  style.fill: "#f5f5f5"
  style.stroke: "#bbbbbb"
  style.stroke-width: 1
  style.font: mono
  style.font-size: 10
}

# --- Analyze Patterns ---

analyze: |md
  **Analyze Patterns**
  LLM (review-results.md)

  - judge-human alignment
  - systematic vs edge cases
  - new judge candidates
| {
  shape: rectangle
  style.fill: "#e8e8e8"
  style.stroke: "#333333"
  style.stroke-width: 2
  style.double-border: true
}

# --- Propose Changes ---

propose: |md
  **Propose Changes**
  LLM, requires approval

  - find SKILL.md via find_skills.py
  - show before/after diffs
  - grounded in feedback
  - propose new eval.yaml judges
| {
  shape: rectangle
  style.fill: "#e8e8e8"
  style.stroke: "#333333"
  style.stroke-width: 2
  style.double-border: true
}

# --- Next Steps ---

next-steps: |md
  **Next Steps**

  - /eval-run --baseline \<id\>
  - /eval-optimize
  - /eval-dataset --expand
  - /eval-mlflow push-feedback
| {
  shape: rectangle
  style.fill: "#f5f5f5"
  style.stroke: "#333333"
  style.stroke-width: 2
}

# --- Downstream Skills (external) ---

eval-run: |md
  **/eval-run**
| {
  shape: rectangle
  style.fill: "#f5f5f5"
  style.stroke: "#333333"
  style.stroke-width: 2
  style.stroke-dash: 3
}

eval-optimize: |md
  **/eval-optimize**
  reads review.yaml
| {
  shape: rectangle
  style.fill: "#f5f5f5"
  style.stroke: "#333333"
  style.stroke-width: 2
  style.stroke-dash: 3
}

eval-dataset: |md
  **/eval-dataset**
| {
  shape: rectangle
  style.fill: "#f5f5f5"
  style.stroke: "#333333"
  style.stroke-width: 2
  style.stroke-dash: 3
}

eval-mlflow: |md
  **/eval-mlflow**
  push feedback to traces
| {
  shape: rectangle
  style.fill: "#f5f5f5"
  style.stroke: "#333333"
  style.stroke-width: 2
  style.stroke-dash: 3
}

# --- Edges ---

# Main flow
entry -> load-results
load-results -> overview: "summary.yaml"
overview -> walk-cases: "all / failures / filter"

# Transcript check (optional)
walk-cases -> check-transcripts: "if transcripts exist" {
  style.stroke-dash: 3
}
check-transcripts -> save-feedback: "transcript findings"

# Main continuation
walk-cases -> save-feedback: "no transcripts"

# Save feedback with callout
save-feedback -> review-yaml: {
  style.stroke: "#bbbbbb"
  style.stroke-dash: 4
  style.stroke-width: 1
}

# Analysis and proposal
save-feedback -> analyze: "review.yaml"
analyze -> propose: "pattern analysis"

# Approval gate
propose -> next-steps: "approved edits applied"

# Downstream skill fan-out
next-steps -> eval-run: "re-run + compare" {
  style.stroke-dash: 3
}
next-steps -> eval-optimize: "auto-iterate" {
  style.stroke-dash: 3
}
next-steps -> eval-dataset: "expand coverage" {
  style.stroke-dash: 3
}
next-steps -> eval-mlflow: "push feedback" {
  style.stroke-dash: 3
}

# review.yaml consumed directly downstream
save-feedback -> eval-optimize: "review.yaml" {
  style.stroke-dash: 3
}
save-feedback -> eval-mlflow: "review.yaml" {
  style.stroke-dash: 3
}
