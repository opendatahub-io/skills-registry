direction: right

*.style.border-radius: 8
*.style.font-size: 13
*.style.fill: "#f5f5f5"
*.style.stroke: "#333333"

# --- Entry ---

entry: |md
  **/eval-review**

  - --run-id \<id\> (required)
  - --config \<path\>
  - --case \<filter\>
| {
  shape: rectangle
  style.fill: "#f5f5f5"
  style.stroke: "#333333"
  style.stroke-width: 2
}

# --- Load Results ---

load-results: |md
  **Load Results**

  - state.py read summary.yaml
  - read eval.yaml config
  - note skill, dataset, judges
  - inline checks vs LLM judges
| {
  shape: rectangle
  style.fill: "#f5f5f5"
  style.stroke: "#333333"
  style.stroke-width: 2
}

# --- Present Overview ---

overview: |md
  **Present Overview**

  - link to report.html
  - pass rates per judge
  - cases all-pass vs failures
  - pairwise win/loss/tie
| {
  shape: rectangle
  style.fill: "#f5f5f5"
  style.stroke: "#333333"
  style.stroke-width: 2
}

# --- Walk Through Cases ---

walk-cases: |md
  **Walk Through Cases**
  interactive review

  - present judge scores + rationale
  - summarize output files
  - ask feedback per case
  - empty feedback = acceptable
| {
  shape: rectangle
  style.fill: "#e8e8e8"
  style.stroke: "#333333"
  style.stroke-width: 2
  style.double-border: true
}

# --- Check Transcripts ---

check-transcripts: |md
  **Check Transcripts**
  Agent (sub-agent)

  - read stdout.log per case
  - multi-approach attempts?
  - unnecessary tool usage?
  - error recovery patterns
  - wasted turns count
| {
  shape: rectangle
  style.fill: "#e8e8e8"
  style.stroke: "#333333"
  style.stroke-width: 2
  style.double-border: true
}

# --- Save Feedback ---

save-feedback: |md
  **Save Feedback**

  - write review.yaml
  - run_id, reviewer: "human"
  - per-case feedback text
  - empty = acceptable
| {
  shape: rectangle
  style.fill: "#f5f5f5"
  style.stroke: "#333333"
  style.stroke-width: 2
}

# --- review.yaml callout ---

review-yaml: |md
  review.yaml
  run_id: "\<id\>"
  reviewed_cases: N
  feedback_cases: M
  reviewer: "human"
  feedback:
    case-001: "comment"
    case-002: ""
| {
  shape: rectangle
  style.fill: "#f5f5f5"
  style.stroke: "#bbbbbb"
  style.stroke-width: 1
  style.font: mono
  style.font-size: 10
}

# --- Analyze Patterns ---

analyze: |md
  **Analyze Patterns**
  LLM analysis

  - read review-results.md
  - judge-human alignment
  - systematic vs edge cases
  - new judge candidates
| {
  shape: rectangle
  style.fill: "#e8e8e8"
  style.stroke: "#333333"
  style.stroke-width: 2
  style.double-border: true
}

# --- Propose Changes ---

propose: |md
  **Propose Changes**
  LLM analysis

  - find skill's SKILL.md
  - before/after diffs
  - grounded in feedback
  - propose eval.yaml judges
| {
  shape: rectangle
  style.fill: "#e8e8e8"
  style.stroke: "#333333"
  style.stroke-width: 2
  style.double-border: true
}

# --- Apply Changes ---

apply: |md
  **Apply Changes**

  - edit SKILL.md (approved)
  - add judges to eval.yaml
| {
  shape: rectangle
  style.fill: "#f5f5f5"
  style.stroke: "#333333"
  style.stroke-width: 2
}

# --- Next Steps ---

next-steps: |md
  **Next Steps**

  - /eval-run --baseline \<id\>
  - /eval-optimize
  - /eval-dataset --expand
  - /eval-mlflow push-feedback
| {
  shape: rectangle
  style.fill: "#f5f5f5"
  style.stroke: "#333333"
  style.stroke-width: 2
}

# --- Downstream Skills (external) ---

eval-run: |md
  **/eval-run**
| {
  shape: rectangle
  style.fill: "#f5f5f5"
  style.stroke: "#333333"
  style.stroke-width: 2
  style.stroke-dash: 3
}

eval-optimize: |md
  **/eval-optimize**
| {
  shape: rectangle
  style.fill: "#f5f5f5"
  style.stroke: "#333333"
  style.stroke-width: 2
  style.stroke-dash: 3
}

eval-dataset: |md
  **/eval-dataset**
| {
  shape: rectangle
  style.fill: "#f5f5f5"
  style.stroke: "#333333"
  style.stroke-width: 2
  style.stroke-dash: 3
}

eval-mlflow: |md
  **/eval-mlflow**
| {
  shape: rectangle
  style.fill: "#f5f5f5"
  style.stroke: "#333333"
  style.stroke-width: 2
  style.stroke-dash: 3
}

# --- Edges ---

# Main flow
entry -> load-results
load-results -> overview: "summary.yaml"
overview -> walk-cases: "all / failures / filter"

# Walk cases with conditional transcript check
walk-cases -> check-transcripts: "transcripts exist"
walk-cases -> save-feedback: "no transcripts" {
  style.stroke-dash: 3
}
check-transcripts -> save-feedback

# Save feedback with callout
save-feedback -> review-yaml: {
  style.stroke: "#bbbbbb"
  style.stroke-dash: 4
  style.stroke-width: 1
}

# Analysis and proposal
save-feedback -> analyze: "review.yaml"
analyze -> propose

# Approval gate
propose -> apply: "approved"
propose -> next-steps: "declined" {
  style.stroke-dash: 3
}
apply -> next-steps

# Downstream skill fan-out
next-steps -> eval-run: "re-run + compare" {
  style.stroke-dash: 3
}
next-steps -> eval-optimize: "auto-iterate" {
  style.stroke-dash: 3
}
next-steps -> eval-dataset: "expand coverage" {
  style.stroke-dash: 3
}
next-steps -> eval-mlflow: "push feedback" {
  style.stroke-dash: 3
}
