direction: right

*.style.border-radius: 8
*.style.font-size: 13
*.style.fill: "#f5f5f5"
*.style.stroke: "#333333"

# --- Entry (Step 0) ---

entry: |md
  **/eval-review**

  - --run-id <id>
  - --config <path>
  - --cases <name> ...
| {
  shape: rectangle
  style.fill: "#f5f5f5"
  style.stroke: "#333333"
  style.stroke-width: 2
}

# --- Step 0: config discovery (decision) ---

discover: |md
  **Discover Config**

  - --config? use it
  - else discover.py
  - read skill field
  - set <eval-name>
| {
  shape: diamond
  style.fill: "#f5f5f5"
  style.stroke: "#333333"
  style.stroke-width: 2
}

# --- Step 1: load results ---

load-results: |md
  **Load Results**

  - state.py read summary.yaml
  - read eval.yaml (skill,
    schema, judges)
  - note judge_type per case
| {
  shape: rectangle
  style.fill: "#f5f5f5"
  style.stroke: "#333333"
  style.stroke-width: 2
}

# --- Step 2: present overview (decision: which cases) ---

overview: |md
  **Present Overview**

  - read analysis.md if present
  - mention report.html
  - pass rates per judge
  - pairwise win/loss/tie
  - which cases to review?
| {
  shape: diamond
  style.fill: "#f5f5f5"
  style.stroke: "#333333"
  style.stroke-width: 2
}

# --- Step 3: walk cases ---

walk-cases: |md
  **Walk Through Cases**

  - judge scores + rationale
  - pairwise per-case result
  - summarize output files
  - ask: judges miss anything?
  - collect feedback notes
| {
  shape: rectangle
  style.fill: "#f5f5f5"
  style.stroke: "#333333"
  style.stroke-width: 2
}

# --- Step 4: check transcripts (LLM agent) ---

transcripts: |md
  **Check Transcripts**
  delegate to Agent

  - case vs batch stdout.log
  - multiple approaches?
  - wasted tools / turns?
  - error recovery, sub-skills
| {
  shape: rectangle
  style.fill: "#e8e8e8"
  style.stroke: "#333333"
  style.stroke-width: 2
  style.double-border: true
}

# --- Step 5: save feedback ---

save-feedback: |md
  **Save Feedback**

  - Write review.yaml
  - keys = case dir names
  - empty = acceptable
  - NOT state.py format
| {
  shape: rectangle
  style.fill: "#f5f5f5"
  style.stroke: "#333333"
  style.stroke-width: 2
}

# --- Step 6: analyze patterns (LLM) ---

analyze-patterns: |md
  **Analyze Patterns**
  review-results.md framework

  - judge-human alignment
  - systematic vs edge cases
  - new judge candidates
| {
  shape: rectangle
  style.fill: "#e8e8e8"
  style.stroke: "#333333"
  style.stroke-width: 2
  style.double-border: true
}

# --- Step 7: propose changes (decision: approval) ---

propose: |md
  **Propose Changes**

  - locate SKILL.md (find_skills)
  - before/after diffs
  - propose new judges (builtins)
  - user approves?
| {
  shape: diamond
  style.fill: "#f5f5f5"
  style.stroke: "#333333"
  style.stroke-width: 2
}

apply-edits: |md
  **Apply Edits**

  - edit SKILL.md
  - add judges to eval.yaml
  - grounded in feedback
| {
  shape: rectangle
  style.fill: "#f5f5f5"
  style.stroke: "#333333"
  style.stroke-width: 2
}

# --- Step 8: next steps (output) ---

next-steps: |md
  **Suggest Next Steps**

  - /eval-run --baseline
  - /eval-optimize
  - /eval-dataset --expand
  - /eval-mlflow push-feedback
| {
  shape: rectangle
  style.fill: "#f5f5f5"
  style.stroke: "#333333"
  style.stroke-width: 2
}

# --- External skills / services ---

eval-optimize: |md
  **/eval-optimize**
  automated loop

  - reads review.yaml
| {
  shape: rectangle
  style.fill: "#e8e8e8"
  style.stroke: "#333333"
  style.stroke-width: 2
  style.stroke-dash: 3
}

eval-mlflow-skill: |md
  **/eval-mlflow**
  push-feedback

  - feedback -> traces
| {
  shape: rectangle
  style.fill: "#e8e8e8"
  style.stroke: "#333333"
  style.stroke-width: 2
  style.stroke-dash: 3
}

# --- Callouts ---

review-yaml: |md
  run_id: "<id>"
  reviewed_cases: <count>
  feedback_cases: <count>
  reviewer: "human"
  feedback:
    case-001-...: "comment"
    case-002-...: "comment"
    case-003-...: ""  # empty = ok
| {
  shape: rectangle
  style.fill: "#f5f5f5"
  style.stroke: "#bbbbbb"
  style.stroke-width: 1
  style.font: mono
  style.font-size: 10
}

runs-tree: |md
  $AGENT_EVAL_RUNS_DIR/<eval-name>/<id>/
    summary.yaml
    analysis.md
    report.html
    run_result.json
    review.yaml
    cases/<case>/
      stdout.log
| {
  shape: rectangle
  style.fill: "#f5f5f5"
  style.stroke: "#bbbbbb"
  style.stroke-width: 1
  style.font: mono
  style.font-size: 10
}

# --- Flow ---

entry -> discover
discover -> load-results: "config\nselected"
load-results -> overview

overview -> walk-cases: "all / failures\n/ specific"
walk-cases -> transcripts: "if logs exist"
transcripts -> save-feedback
walk-cases -> save-feedback: "no logs"

save-feedback -> analyze-patterns
analyze-patterns -> propose

propose -> apply-edits: "approved"
propose -> next-steps: "declined"
apply-edits -> next-steps

# --- Back-edge (review more cases) ---

save-feedback -> overview: more cases {
  style.stroke-dash: 3
}

# --- External connections ---

next-steps -> eval-optimize: optional {
  style.stroke-dash: 3
}
next-steps -> eval-mlflow-skill: optional {
  style.stroke-dash: 3
}

# --- Callout connections ---

save-feedback -> review-yaml: {
  style.stroke: "#bbbbbb"
  style.stroke-dash: 4
  style.stroke-width: 1
}
load-results -> runs-tree: {
  style.stroke: "#bbbbbb"
  style.stroke-dash: 4
  style.stroke-width: 1
}
