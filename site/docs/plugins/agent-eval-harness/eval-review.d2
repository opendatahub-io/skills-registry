direction: right

*.style.border-radius: 8
*.style.font-size: 13
*.style.fill: "#f5f5f5"
*.style.stroke: "#333333"

# --- Entry ---

args: |md
  **/eval-review**

  - --run-id \<id\> (required)
  - --config eval.yaml
  - --case \<filter\>
| {
  shape: rectangle
  style.fill: "#f5f5f5"
  style.stroke: "#333333"
  style.stroke-width: 2
}

# --- Load Results ---

load-results: |md
  **Load Results**

  - state.py read summary.yaml
  - read eval.yaml config
  - note skill, dataset, judges
  - inline checks vs LLM judges
| {
  shape: rectangle
  style.fill: "#f5f5f5"
  style.stroke: "#333333"
  style.stroke-width: 2
}

# --- Present Overview ---

overview: |md
  **Present Overview**

  - link to report.html (if exists)
  - pass rates per judge
  - cases all-pass vs failures
  - pairwise win/loss/tie counts
| {
  shape: rectangle
  style.fill: "#f5f5f5"
  style.stroke: "#333333"
  style.stroke-width: 2
}

# --- User Choice ---

user-choice: |md
  **User Choice**

  "Review all, only
  failures, or specific?"
| {
  shape: diamond
  style.fill: "#fff3e0"
  style.stroke: "#e65100"
  style.stroke-width: 2
}

# --- Walk Through Cases ---

walk-cases: |md
  **Walk Through Cases**
  Interactive loop

  - show judge scores + rationale
  - summarize output files
  - ask for feedback per case
  - "looks fine" → move on
| {
  shape: rectangle
  style.fill: "#e8e8e8"
  style.stroke: "#333333"
  style.stroke-width: 2
  style.double-border: true
}

# --- Check Transcripts ---

check-transcripts: |md
  **Check Transcripts**
  Agent (sub-agent)

  - read stdout.log per case
  - detect multi-approach tries
  - flag roundabout tool usage
  - error recovery patterns
  - wasted turns count
| {
  shape: rectangle
  style.fill: "#e8e8e8"
  style.stroke: "#333333"
  style.stroke-width: 2
  style.double-border: true
}

# --- Save Feedback ---

save-feedback: |md
  **Save Feedback**

  - write review.yaml
  - run_id, reviewer: human
  - per-case feedback text
  - empty = acceptable
| {
  shape: rectangle
  style.fill: "#f5f5f5"
  style.stroke: "#333333"
  style.stroke-width: 2
}

# --- Analyze Patterns ---

analyze: |md
  **Analyze Patterns**
  LLM synthesis

  - review-results.md prompt
  - judge-human alignment
  - systematic vs edge cases
  - new judge candidates
| {
  shape: rectangle
  style.fill: "#e8e8e8"
  style.stroke: "#333333"
  style.stroke-width: 2
  style.double-border: true
}

# --- Propose Changes ---

propose: |md
  **Propose Changes**

  - read skill's SKILL.md
  - before/after diffs
  - grounded in feedback
  - ask user approval
| {
  shape: rectangle
  style.fill: "#f5f5f5"
  style.stroke: "#333333"
  style.stroke-width: 2
}

# --- Apply ---

apply: |md
  **Apply Changes**

  - edit SKILL.md (approved)
  - add judges to eval.yaml
| {
  shape: rectangle
  style.fill: "#f5f5f5"
  style.stroke: "#333333"
  style.stroke-width: 2
}

# --- Next Steps ---

next-steps: |md
  **Next Steps**

  - /eval-run --baseline \<id\>
  - /eval-optimize
  - /eval-dataset --expand
  - /eval-mlflow push-feedback
| {
  shape: rectangle
  style.fill: "#f5f5f5"
  style.stroke: "#333333"
  style.stroke-width: 2
}

# --- Callout: review.yaml structure ---

review-yaml: |md
  review.yaml
  ├── run_id: "<id>"
  ├── reviewed_cases: N
  ├── feedback_cases: M
  ├── reviewer: "human"
  └── feedback:
      ├── case-001: "comment"
      ├── case-002: "comment"
      └── case-003: ""
| {
  shape: rectangle
  style.fill: "#f5f5f5"
  style.stroke: "#bbbbbb"
  style.stroke-width: 1
  style.font: mono
  style.font-size: 10
}

# --- Flow ---

args -> load-results
load-results -> overview
overview -> user-choice

user-choice -> walk-cases: "all / failures / filter"

walk-cases -> check-transcripts: "transcripts exist"
walk-cases -> save-feedback: "no transcripts" {
  style.stroke-dash: 3
}

check-transcripts -> save-feedback
save-feedback -> analyze
analyze -> propose

propose -> apply: "approved"
propose -> next-steps: "declined" {
  style.stroke-dash: 3
}

apply -> next-steps

# Callout connection
save-feedback -> review-yaml {
  style.stroke: "#bbbbbb"
  style.stroke-dash: 4
  style.stroke-width: 1
}
