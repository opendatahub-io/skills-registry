direction: right

*.style.border-radius: 8
*.style.font-size: 13
*.style.fill: "#f5f5f5"
*.style.stroke: "#333333"

# --- Entry ---

setup: |md
  **/eval-setup**

  - Install deps into isolated venv
  - Configure MLflow tracking URI
  - Verify API keys (Anthropic/Vertex)
  - Preflight environment checks
| {
  shape: rectangle
  style.fill: "#f5f5f5"
  style.stroke: "#333333"
  style.stroke-width: 2
  style.stroke-dash: 3
}

# --- Analysis ---

analyze: |md
  **/eval-analyze**

  - Deep-read skill + sub-skills (LLM agent)
  - Explore dataset schema and test cases
  - Generate eval.yaml (judges, models, thresholds)
  - Cache analysis in eval.md
| {
  shape: rectangle
  style.fill: "#e8e8e8"
  style.stroke: "#333333"
  style.stroke-width: 2
  style.double-border: true
}

# --- Dataset ---

dataset: |md
  **/eval-dataset**

  - Bootstrap, expand, or extract from traces
  - Generate realistic test cases matching schema
  - Cover simple, complex, and edge scenarios
  - Validate cases against eval.yaml schema
| {
  shape: rectangle
  style.fill: "#e8e8e8"
  style.stroke: "#333333"
  style.stroke-width: 2
  style.double-border: true
}

# --- Execution ---

run: |md
  **/eval-run**

  - Prepare isolated workspace per case
  - Execute skill headlessly (case or batch)
  - Collect artifacts and score with judges
  - Generate HTML report with analysis
| {
  shape: rectangle
  style.fill: "#f5f5f5"
  style.stroke: "#333333"
  style.stroke-width: 2
}

# --- Fan-out targets ---

review: |md
  **/eval-review**

  - Present judge scores per case
  - Collect human qualitative feedback
  - Analyze transcript execution paths
  - Propose targeted SKILL.md edits
| {
  shape: rectangle
  style.fill: "#e8e8e8"
  style.stroke: "#333333"
  style.stroke-width: 2
  style.double-border: true
}

optimize: |md
  **/eval-optimize**

  - Identify failures from judge rationale
  - Analyze root causes via transcripts (LLM)
  - Edit SKILL.md with surgical fixes
  - Re-run and check for regressions
| {
  shape: rectangle
  style.fill: "#e8e8e8"
  style.stroke: "#333333"
  style.stroke-width: 2
  style.double-border: true
}

mlflow-skill: |md
  **/eval-mlflow**

  - Sync dataset to MLflow registry
  - Log params, metrics, and artifacts
  - Push judge + human feedback to traces
  - Pull MLflow UI annotations back
| {
  shape: rectangle
  style.fill: "#f5f5f5"
  style.stroke: "#333333"
  style.stroke-width: 2
}

# --- External Service ---

mlflow-server: |md
  **MLflow Server**
| {
  shape: rectangle
  style.fill: "#f5f5f5"
  style.stroke: "#333333"
  style.stroke-width: 2
  style.stroke-dash: 3
}

# --- Main pipeline flow ---

setup -> analyze: "environment ready"
analyze -> dataset: "eval.yaml + eval.md"
dataset -> run: "test cases"

# --- Fan-out from eval-run ---

run -> review: "summary.yaml"
run -> optimize: "summary.yaml"
run -> mlflow-skill: "summary.yaml"

# --- eval-optimize invokes eval-run (feedback loop) ---

optimize -> run: "re-run with\n--baseline" {
  style.stroke-dash: 3
}

# --- eval-review feeds into optimize ---

review -> optimize: "review.yaml"

# --- MLflow connections ---

mlflow-skill -> mlflow-server
setup -> mlflow-server: "configure\ntracking URI" {
  style.stroke-dash: 3
}

# --- Fallback: eval-dataset invokes eval-analyze if missing ---

dataset -> analyze: "missing\neval.yaml" {
  style.stroke-dash: 3
}

# --- Fallback: eval-run invokes eval-analyze if missing ---

run -> analyze: "missing\nconfig" {
  style.stroke-dash: 3
}
