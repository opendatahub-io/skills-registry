    <mxCell id="analyze" value="&lt;b&gt;Analyze Root Causes&lt;/b&gt;&lt;br&gt;&lt;i&gt;LLM agents (Explore)&lt;/i&gt;&lt;br&gt;&lt;br&gt;read skill's SKILL.md&lt;br&gt;read failing transcripts&lt;br&gt;examine failing outputs&lt;br&gt;form hypotheses&lt;br&gt;connect to SKILL.md sections" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e8e8e8;strokeColor=#333333;strokeWidth=2;arcSize=10;verticalAlign=top;spacingTop=5;fontSize=11;fontFamily=Inter,Helvetica,Arial,sans-serif;" vertex="1" parent="1">
      <mxGeometry x="695" y="175" width="185" height="155" as="geometry"/>
    </mxCell>
    <mxCell id="edit-skill" value="&lt;b&gt;Edit SKILL.md&lt;/b&gt;&lt;br&gt;&lt;br&gt;surgical, targeted fixes&lt;br&gt;ground in judge evidence&lt;br&gt;explain why, not just rules&lt;br&gt;avoid overfitting to one case&lt;br&gt;respect execution mode" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#333333;strokeWidth=2;arcSize=10;verticalAlign=top;spacingTop=5;fontSize=11;fontFamily=Inter,Helvetica,Arial,sans-serif;" vertex="1" parent="1">
      <mxGeometry x="930" y="175" width="185" height="155" as="geometry"/>
    </mxCell>
    <mxCell id="rerun" value="&lt;b&gt;Re-Run &amp; Verify&lt;/b&gt;&lt;br&gt;&lt;i&gt;invokes /eval-run&lt;/i&gt;&lt;br&gt;&lt;br&gt;--baseline previous iter&lt;br&gt;check targeted fixes passed&lt;br&gt;detect regressions&lt;br&gt;compare aggregate scores" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e8e8e8;strokeColor=#333333;strokeWidth=2;arcSize=10;verticalAlign=top;spacingTop=5;fontSize=11;fontFamily=Inter,Helvetica,Arial,sans-serif;" vertex="1" parent="1">
