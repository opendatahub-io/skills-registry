<mxGraphModel adaptiveColors="auto">
  <root>
    <mxCell id="0"/>
    <mxCell id="1" parent="0"/>
    <mxCell id="args" value="&lt;b&gt;/eval-optimize&lt;/b&gt;&lt;br&gt;&lt;br&gt;--config eval.yaml&lt;br&gt;--model &lt;model&gt;&lt;br&gt;--max-iterations 3&lt;br&gt;--run-id &lt;id&gt;&lt;br&gt;--target-judge &lt;name&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#333333;strokeWidth=2;arcSize=10;verticalAlign=top;spacingTop=5;fontSize=11;fontFamily=Inter,Helvetica,Arial,sans-serif;" vertex="1" parent="1">
      <mxGeometry x="30" y="200" width="140" height="155" as="geometry"/>
    </mxCell>
    <mxCell id="initial-run" value="&lt;b&gt;Initial Eval Run&lt;/b&gt;&lt;br&gt;&lt;i&gt;invokes /eval-run&lt;/i&gt;&lt;br&gt;&lt;br&gt;skip if recent results&lt;br&gt;--run-id &lt;id&gt;-iter-0&lt;br&gt;read summary.yaml&lt;br&gt;all pass → exit early" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e8e8e8;strokeColor=#333333;strokeWidth=2;arcSize=10;verticalAlign=top;spacingTop=5;fontSize=11;fontFamily=Inter,Helvetica,Arial,sans-serif;" vertex="1" parent="1">
      <mxGeometry x="220" y="205" width="170" height="140" as="geometry"/>
    </mxCell>
    <mxCell id="eval-run" value="&lt;b&gt;/eval-run&lt;/b&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#333333;strokeWidth=2;arcSize=10;dashed=1;dashPattern=8 4;verticalAlign=middle;fontSize=11;fontFamily=Inter,Helvetica,Arial,sans-serif;" vertex="1" parent="1">
      <mxGeometry x="700" y="100" width="120" height="45" as="geometry"/>
    </mxCell>
    <mxCell id="identify" value="&lt;b&gt;Identify Failures&lt;/b&gt;&lt;br&gt;&lt;br&gt;which judges failed&lt;br&gt;failure rationale per case&lt;br&gt;systematic vs input-dep&lt;br&gt;check review.yaml&lt;br&gt;(human feedback priority)&lt;br&gt;build failure map" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#333333;strokeWidth=2;arcSize=10;verticalAlign=top;spacingTop=5;fontSize=11;fontFamily=Inter,Helvetica,Arial,sans-serif;" vertex="1" parent="1">
      <mxGeometry x="440" y="200" width="175" height="155" as="geometry"/>
    </mxCell>
    <mxCell id="analyze" value="&lt;b&gt;Analyze Root Causes&lt;/b&gt;&lt;br&gt;&lt;i&gt;LLM agents (Explore)&lt;/i&gt;&lt;br&gt;&lt;br&gt;read skill's SKILL.md&lt;br&gt;read failing transcripts&lt;br&gt;examine failing outputs&lt;br&gt;form hypotheses&lt;br&gt;connect to SKILL.md sections" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e8e8e8;strokeColor=#333333;strokeWidth=2;arcSize=10;verticalAlign=top;spacingTop=5;fontSize=11;fontFamily=Inter,Helvetica,Arial,sans-serif;" vertex="1" parent="1">
      <mxGeometry x="665" y="200" width="175" height="155" as="geometry"/>
    </mxCell>
    <mxCell id="edit-skill" value="&lt;b&gt;Edit SKILL.md&lt;/b&gt;&lt;br&gt;&lt;br&gt;surgical, targeted fixes&lt;br&gt;ground in judge evidence&lt;br&gt;explain why, not just rules&lt;br&gt;avoid overfitting to one case&lt;br&gt;respect execution mode" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#333333;strokeWidth=2;arcSize=10;verticalAlign=top;spacingTop=5;fontSize=11;fontFamily=Inter,Helvetica,Arial,sans-serif;" vertex="1" parent="1">
      <mxGeometry x="890" y="200" width="170" height="155" as="geometry"/>
    </mxCell>
    <mxCell id="rerun" value="&lt;b&gt;Re-Run &amp; Verify&lt;/b&gt;&lt;br&gt;&lt;i&gt;invokes /eval-run&lt;/i&gt;&lt;br&gt;&lt;br&gt;--baseline previous iter&lt;br&gt;check targeted fixes passed&lt;br&gt;detect regressions&lt;br&gt;compare aggregate scores" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e8e8e8;strokeColor=#333333;strokeWidth=2;arcSize=10;verticalAlign=top;spacingTop=5;fontSize=11;fontFamily=Inter,Helvetica,Arial,sans-serif;" vertex="1" parent="1">
      <mxGeometry x="1110" y="205" width="170" height="140" as="geometry"/>
    </mxCell>
    <mxCell id="regressions" value="&lt;b&gt;Handle Regressions&lt;/b&gt;&lt;br&gt;&lt;br&gt;assess severity&lt;br&gt;minor → net positive, continue&lt;br&gt;major → revert edit, retry&lt;br&gt;stuck → report to user" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#333333;strokeWidth=2;arcSize=10;verticalAlign=top;spacingTop=5;fontSize=11;fontFamily=Inter,Helvetica,Arial,sans-serif;" vertex="1" parent="1">
      <mxGeometry x="1330" y="205" width="165" height="140" as="geometry"/>
    </mxCell>
    <mxCell id="iterate" value="&lt;b&gt;Iterate?&lt;/b&gt;&lt;br&gt;&lt;br&gt;failures remain?&lt;br&gt;iterations &lt; max?" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#333333;strokeWidth=2;arcSize=40;verticalAlign=top;spacingTop=5;fontSize=11;fontFamily=Inter,Helvetica,Arial,sans-serif;" vertex="1" parent="1">
      <mxGeometry x="1545" y="230" width="130" height="90" as="geometry"/>
    </mxCell>
    <mxCell id="report" value="&lt;b&gt;Report&lt;/b&gt;&lt;br&gt;&lt;br&gt;edits applied + fixes summary&lt;br&gt;iteration count&lt;br&gt;final summary.yaml scores&lt;br&gt;persistent failures explained&lt;br&gt;&lt;br&gt;&lt;i&gt;suggest /eval-review&lt;/i&gt;&lt;br&gt;&lt;i&gt;suggest /eval-mlflow&lt;/i&gt;&lt;br&gt;&lt;i&gt;suggest /eval-dataset&lt;/i&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#333333;strokeWidth=2;arcSize=10;verticalAlign=top;spacingTop=5;fontSize=11;fontFamily=Inter,Helvetica,Arial,sans-serif;" vertex="1" parent="1">
      <mxGeometry x="1350" y="460" width="175" height="165" as="geometry"/>
    </mxCell>
    <mxCell id="rules" value="&lt;b&gt;Rules&lt;/b&gt;&lt;br&gt;─────────────────────&lt;br&gt;• never broad generic changes&lt;br&gt;• check regressions after every edit&lt;br&gt;• stop after max iterations&lt;br&gt;• don't modify test cases or judges&lt;br&gt;• don't modify eval.yaml&lt;br&gt;• try different approaches" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#bbbbbb;strokeWidth=1;arcSize=6;verticalAlign=top;spacingTop=5;align=left;spacingLeft=8;fontSize=10;fontFamily=JetBrains Mono,Courier New,monospace;" vertex="1" parent="1">
