    <mxCell id="initial-run" value="&lt;b&gt;Initial Eval Run&lt;/b&gt;&lt;br&gt;&lt;i&gt;invokes /eval-run&lt;/i&gt;&lt;br&gt;&lt;br&gt;skip if recent results exist&lt;br&gt;--run-id &lt;id&gt;-iter-0&lt;br&gt;read summary.yaml&lt;br&gt;all pass → exit early" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e8e8e8;strokeColor=#333333;strokeWidth=2;arcSize=10;verticalAlign=top;spacingTop=5;fontSize=11;fontFamily=Inter,Helvetica,Arial,sans-serif;" vertex="1" parent="1">
