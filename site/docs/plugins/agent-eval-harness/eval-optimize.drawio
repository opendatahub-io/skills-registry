<mxGraphModel adaptiveColors="auto">
  <root>
    <mxCell id="0"/>
    <mxCell id="1" parent="0"/>
    <mxCell id="args" value="&lt;b&gt;/eval-optimize&lt;/b&gt;&lt;br&gt;&lt;br&gt;--config eval.yaml&lt;br&gt;--model &amp;lt;model&amp;gt;&lt;br&gt;--max-iterations 3&lt;br&gt;--run-id &amp;lt;id&amp;gt;&lt;br&gt;--target-judge &amp;lt;name&amp;gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#333333;strokeWidth=2;arcSize=10;verticalAlign=top;spacingTop=5;fontSize=11;" vertex="1" parent="1">
      <mxGeometry x="80" y="55" width="150" height="170" as="geometry"/>
    </mxCell>
    <mxCell id="initial-run" value="&lt;b&gt;Initial Eval Run&lt;/b&gt;&lt;br&gt;&lt;i&gt;invokes /eval-run&lt;/i&gt;&lt;br&gt;&lt;br&gt;skip if recent results&lt;br&gt;read summary.yaml&lt;br&gt;all pass → exit early" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e8e8e8;strokeColor=#333333;strokeWidth=2;arcSize=10;verticalAlign=top;spacingTop=5;fontSize=11;" vertex="1" parent="1">
      <mxGeometry x="280" y="60" width="170" height="150" as="geometry"/>
    </mxCell>
    <mxCell id="identify" value="&lt;b&gt;Identify Failures&lt;/b&gt;&lt;br&gt;&lt;br&gt;which judges failed&lt;br&gt;failure rationale&lt;br&gt;systematic vs input-dep&lt;br&gt;check review.yaml&lt;br&gt;build failure map" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#333333;strokeWidth=2;arcSize=10;verticalAlign=top;spacingTop=5;fontSize=11;" vertex="1" parent="1">
      <mxGeometry x="500" y="50" width="170" height="170" as="geometry"/>
    </mxCell>
    <mxCell id="analyze" value="&lt;b&gt;Analyze Root Causes&lt;/b&gt;&lt;br&gt;&lt;i&gt;LLM agents (Explore)&lt;/i&gt;&lt;br&gt;&lt;br&gt;read SKILL.md&lt;br&gt;read failing transcripts&lt;br&gt;read failing outputs&lt;br&gt;form hypotheses&lt;br&gt;connect to SKILL.md" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e8e8e8;strokeColor=#333333;strokeWidth=2;arcSize=10;verticalAlign=top;spacingTop=5;fontSize=11;" vertex="1" parent="1">
      <mxGeometry x="720" y="50" width="180" height="170" as="geometry"/>
    </mxCell>
    <mxCell id="edit" value="&lt;b&gt;Edit SKILL.md&lt;/b&gt;&lt;br&gt;&lt;br&gt;surgical, targeted fixes&lt;br&gt;ground in evidence&lt;br&gt;explain why, not just what&lt;br&gt;avoid overfitting&lt;br&gt;respect execution mode" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#333333;strokeWidth=2;arcSize=10;verticalAlign=top;spacingTop=5;fontSize=11;" vertex="1" parent="1">
      <mxGeometry x="950" y="50" width="170" height="170" as="geometry"/>
    </mxCell>
    <mxCell id="rules" value="&lt;b&gt;Rules&lt;/b&gt;&lt;br&gt;─────────────────────&lt;br&gt;• never broad generic changes&lt;br&gt;• check regressions after edit&lt;br&gt;• stop after max iterations&lt;br&gt;• don&#x27;t modify test cases&lt;br&gt;• don&#x27;t modify eval.yaml&lt;br&gt;• try different approaches" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#bbbbbb;strokeWidth=1;arcSize=6;verticalAlign=top;spacingTop=5;align=left;spacingLeft=8;fontSize=10;fontFamily=Courier New;" vertex="1" parent="1">
      <mxGeometry x="1190" y="60" width="200" height="160" as="geometry"/>
    </mxCell>
    <mxCell id="rerun" value="&lt;b&gt;Re-Run &amp;amp; Verify&lt;/b&gt;&lt;br&gt;&lt;i&gt;invokes /eval-run&lt;/i&gt;&lt;br&gt;&lt;br&gt;--baseline previous iter&lt;br&gt;check fixed failures&lt;br&gt;check regressions&lt;br&gt;score improvement" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e8e8e8;strokeColor=#333333;strokeWidth=2;arcSize=10;verticalAlign=top;spacingTop=5;fontSize=11;" vertex="1" parent="1">
      <mxGeometry x="950" y="490" width="170" height="150" as="geometry"/>
    </mxCell>
    <mxCell id="regressions" value="&lt;b&gt;Handle Regressions&lt;/b&gt;&lt;br&gt;&lt;br&gt;assess severity&lt;br&gt;minor → continue&lt;br&gt;major → revert, retry&lt;br&gt;stuck → report to user" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#333333;strokeWidth=2;arcSize=10;verticalAlign=top;spacingTop=5;fontSize=11;" vertex="1" parent="1">
      <mxGeometry x="720" y="500" width="170" height="140" as="geometry"/>
    </mxCell>
    <mxCell id="decision" value="&lt;b&gt;Iterate?&lt;/b&gt;&lt;br&gt;&lt;br&gt;failures remain?&lt;br&gt;iterations &amp;lt; max?" style="rhombus;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#333333;strokeWidth=2;verticalAlign=middle;fontSize=11;" vertex="1" parent="1">
      <mxGeometry x="510" y="510" width="140" height="110" as="geometry"/>
    </mxCell>
    <mxCell id="report" value="&lt;b&gt;Report&lt;/b&gt;&lt;br&gt;&lt;br&gt;edits + fixes summary&lt;br&gt;iteration count&lt;br&gt;final scores&lt;br&gt;suggest /eval-review&lt;br&gt;suggest /eval-mlflow" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#999999;strokeWidth=1;arcSize=10;verticalAlign=top;spacingTop=5;fontSize=11;" vertex="1" parent="1">
