    <mxCell id="config-state" value="&lt;b&gt;Discover Config + Init State&lt;/b&gt;&lt;br&gt;&lt;br&gt;discover.py finds eval.yaml&lt;br&gt;1 &amp;rarr; auto; many &amp;rarr; ask user&lt;br&gt;read skill field &amp;rarr; eval-name&lt;br&gt;state.py init optimize-config&lt;br&gt;model, max_iterations, run_id" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#333333;strokeWidth=2;verticalAlign=top;spacingTop=5;fontSize=11;fontFamily=Inter,Helvetica,Arial,sans-serif;arcSize=16;absoluteArcSize=1;" vertex="1" parent="1">
