    <mxCell id="identify" value="&lt;b&gt;Identify Failures&lt;/b&gt;&lt;br&gt;&lt;br&gt;which judges failed&lt;br&gt;failure rationale per case&lt;br&gt;systematic vs input-dependent&lt;br&gt;check review.yaml&lt;br&gt;build failure map" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#333333;strokeWidth=2;arcSize=10;verticalAlign=top;spacingTop=5;fontSize=11;fontFamily=Inter,Helvetica,Arial,sans-serif;" vertex="1" parent="1">
