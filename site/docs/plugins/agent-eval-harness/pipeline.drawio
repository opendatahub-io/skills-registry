    </mxCell>
    <mxCell id="run" value="&lt;b&gt;/eval-run&lt;/b&gt;&lt;br&gt;&lt;br&gt;Prepare isolated workspace per case&lt;br&gt;Execute skill headlessly (case/batch)&lt;br&gt;Collect artifacts and score w/ judges&lt;br&gt;Generate HTML report with analysis" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#333333;strokeWidth=2;arcSize=10;verticalAlign=top;spacingTop=5;fontSize=11;fontFamily=Inter,Helvetica,Arial,sans-serif;" vertex="1" parent="1">
