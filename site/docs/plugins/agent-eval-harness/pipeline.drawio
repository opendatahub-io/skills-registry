    <mxCell id="setup" value="&lt;b&gt;/eval-setup&lt;/b&gt;&lt;br&gt;&lt;br&gt;Install deps into isolated venv&lt;br&gt;Configure MLflow tracking URI&lt;br&gt;Verify API keys (Anthropic/Vertex)&lt;br&gt;Preflight environment checks" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#333333;strokeWidth=2;arcSize=10;dashed=1;dashPattern=8 4;verticalAlign=top;spacingTop=5;fontSize=11;fontFamily=Inter,Helvetica,Arial,sans-serif;" vertex="1" parent="1">
