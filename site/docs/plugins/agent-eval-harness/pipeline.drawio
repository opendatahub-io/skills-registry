      <mxGeometry x="1300" y="90" width="250" height="150" as="geometry"/>
    </mxCell>
    <mxCell id="optimize" value="&lt;b&gt;/eval-optimize&lt;/b&gt;&lt;br&gt;&lt;br&gt;Identify failures from judge rationale&lt;br&gt;Analyze root causes via transcripts (LLM)&lt;br&gt;Edit SKILL.md with surgical fixes&lt;br&gt;Re-run and check for regressions" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e8e8e8;strokeColor=#333333;strokeWidth=2;arcSize=10;verticalAlign=top;spacingTop=5;fontSize=11;fontFamily=Inter,Helvetica,Arial,sans-serif;" vertex="1" parent="1">
