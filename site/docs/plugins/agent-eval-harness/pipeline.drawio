    </mxCell>
    <mxCell id="analyze" value="&lt;b&gt;/eval-analyze&lt;/b&gt;&lt;br&gt;&lt;br&gt;Deep-read skill + sub-skills (LLM agent)&lt;br&gt;Explore dataset schema and test cases&lt;br&gt;Generate eval.yaml (judges, models, thresholds)&lt;br&gt;Cache analysis in eval.md" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e8e8e8;strokeColor=#333333;strokeWidth=2;arcSize=10;verticalAlign=top;spacingTop=5;fontSize=11;fontFamily=Inter,Helvetica,Arial,sans-serif;" vertex="1" parent="1">
