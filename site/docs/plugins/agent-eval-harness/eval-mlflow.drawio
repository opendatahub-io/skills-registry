<mxGraphModel adaptiveColors="auto">
  <root>
    <mxCell id="0"/>
    <mxCell id="1" parent="0"/>
    <mxCell id="args" value="&lt;b&gt;/eval-mlflow&lt;/b&gt;&lt;br&gt;&lt;br&gt;--action &lt;action&gt;&lt;br&gt;(sync-dataset | log-results |&lt;br&gt;push-feedback | pull-feedback | all)&lt;br&gt;--config &lt;path&gt; (auto-discover)&lt;br&gt;--run-id &lt;id&gt; (log / push / pull)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#333333;strokeWidth=2;verticalAlign=top;spacingTop=5;fontSize=11;fontFamily=Inter,Helvetica,Arial,sans-serif;arcSize=16;absoluteArcSize=1;" vertex="1" parent="1">
      <mxGeometry x="40" y="320" width="240" height="160" as="geometry"/>
    </mxCell>
    <mxCell id="config" value="&lt;b&gt;Load Config&lt;/b&gt;&lt;br&gt;&lt;br&gt;discover.py eval configs&lt;br&gt;1 auto, many ask user&lt;br&gt;read mlflow.experiment&lt;br&gt;dataset.path + schema, judges" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#333333;strokeWidth=2;verticalAlign=top;spacingTop=5;fontSize=11;fontFamily=Inter,Helvetica,Arial,sans-serif;arcSize=16;absoluteArcSize=1;" vertex="1" parent="1">
