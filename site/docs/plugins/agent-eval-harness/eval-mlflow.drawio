    <mxCell id="mlflow" value="&lt;b&gt;MLflow Server&lt;/b&gt;&lt;br&gt;external service&lt;br&gt;&lt;br&gt;dataset registry&lt;br&gt;runs: params, metrics, artifacts&lt;br&gt;traces + feedback&lt;br&gt;annotation UI ($MLFLOW_TRACKING_URI)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e8e8e8;strokeColor=#333333;strokeWidth=2;dashed=1;dashPattern=8 4;verticalAlign=top;spacingTop=5;fontSize=11;fontFamily=Inter,Helvetica,Arial,sans-serif;arcSize=16;absoluteArcSize=1;" vertex="1" parent="1">
