      <mxGeometry x="830" y="345" width="130" height="110" as="geometry"/>
    </mxCell>
    <mxCell id="group-1" value="&lt;b&gt;Operations&lt;/b&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ececec;strokeColor=#333333;strokeWidth=2;container=1;collapsible=0;verticalAlign=top;spacingTop=5;fontSize=12;fontStyle=1;fontFamily=Inter,Helvetica,Arial,sans-serif;arcSize=16;absoluteArcSize=1;" vertex="1" parent="1">
      <mxGeometry x="1020" y="75" width="286" height="680" as="geometry"/>
    </mxCell>
    <mxCell id="sync" value="&lt;b&gt;Sync Dataset&lt;/b&gt;&lt;br&gt;two-phase (LLM + script)&lt;br&gt;&lt;br&gt;read dataset.schema + sample&lt;br&gt;interpret &amp;rarr; schema_mapping.json&lt;br&gt;sync_dataset.py validates + preview&lt;br&gt;push records to MLflow dataset" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e8e8e8;strokeColor=#333333;strokeWidth=3;verticalAlign=top;spacingTop=5;fontSize=11;fontFamily=Inter,Helvetica,Arial,sans-serif;double=1;arcSize=16;absoluteArcSize=1;" vertex="1" parent="group-1">
      <mxGeometry x="18" y="45" width="250" height="135" as="geometry"/>
    </mxCell>
    <mxCell id="log" value="&lt;b&gt;Log Results&lt;/b&gt;&lt;br&gt;log_results.py --run-id&lt;br&gt;&lt;br&gt;params: skill, runner, model&lt;br&gt;metrics: per-judge mean/pass_rate,&lt;br&gt;duration, cost, tokens&lt;br&gt;artifacts: summary.yaml + table&lt;br&gt;one trace per case / run" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#333333;strokeWidth=2;verticalAlign=top;spacingTop=5;fontSize=11;fontFamily=Inter,Helvetica,Arial,sans-serif;arcSize=16;absoluteArcSize=1;" vertex="1" parent="group-1">
      <mxGeometry x="18" y="195" width="250" height="145" as="geometry"/>
    </mxCell>
    <mxCell id="pushfb" value="&lt;b&gt;Push Feedback&lt;/b&gt;&lt;br&gt;attach_feedback.py --source all&lt;br&gt;&lt;br&gt;judge: source_type=CODE&lt;br&gt;({case}/{judge}) from summary.yaml&lt;br&gt;human: source_type=HUMAN&lt;br&gt;({case}/human_review) from review.yaml&lt;br&gt;no traces? report 0, succeed" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#333333;strokeWidth=2;verticalAlign=top;spacingTop=5;fontSize=11;fontFamily=Inter,Helvetica,Arial,sans-serif;arcSize=16;absoluteArcSize=1;" vertex="1" parent="group-1">
