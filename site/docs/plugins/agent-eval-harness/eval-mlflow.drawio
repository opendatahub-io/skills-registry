    </mxCell>
    <mxCell id="pullfb" value="&lt;b&gt;Pull Feedback&lt;/b&gt;&lt;br&gt;attach_feedback.py --action pull&lt;br&gt;&lt;br&gt;read UI annotations on traces&lt;br&gt;write review.yaml mlflow_feedback&lt;br&gt;separate from local human review&lt;br&gt;consumed by /eval-optimize" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#333333;strokeWidth=2;verticalAlign=top;spacingTop=5;fontSize=11;fontFamily=Inter,Helvetica,Arial,sans-serif;arcSize=16;absoluteArcSize=1;" vertex="1" parent="group-1">
