    <mxCell id="entry" value="&lt;b&gt;/eval-run&lt;/b&gt;&lt;br&gt;&lt;br&gt;--config &lt;path&gt;&lt;br&gt;--model / --subagent-model&lt;br&gt;--skill &lt;name&gt;&lt;br&gt;--run-id &lt;id&gt;&lt;br&gt;--cases &lt;id ...&gt;&lt;br&gt;--baseline &lt;run-id&gt;&lt;br&gt;--no-llm-judges / --gold&lt;br&gt;--effort &lt;level&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#333333;strokeWidth=2;verticalAlign=top;spacingTop=5;fontSize=11;fontFamily=Inter,Helvetica,Arial,sans-serif;arcSize=16;absoluteArcSize=1;" vertex="1" parent="1">
