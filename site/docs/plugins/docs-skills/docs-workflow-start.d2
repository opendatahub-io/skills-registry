direction: right

*.style.border-radius: 8
*.style.font-size: 13
*.style.fill: "#f5f5f5"
*.style.stroke: "#333333"

# --- Entry ---

entry: |md
  **/docs-workflow-start**

  - [<ticket>]
  - [--pr, --mkdocs, --draft]
  - [--source-code-repo ...]
  - [--docs-repo-path ...]
| {
  shape: rectangle
  style.fill: "#f5f5f5"
  style.stroke: "#333333"
  style.stroke-width: 2
}

# --- Mode decision ---

mode: |md
  **Determine mode**

  any `--` switches
  present?
| {
  shape: diamond
  style.fill: "#f5f5f5"
  style.stroke: "#333333"
  style.stroke-width: 2
}

# --- Pass-through ---

passthrough: |md
  **Pass-through**

  - no prompts
  - forward all original
    args unchanged
| {
  shape: rectangle
  style.fill: "#f5f5f5"
  style.stroke: "#333333"
  style.stroke-width: 2
}

# --- Interactive: get ticket ---

get-ticket: |md
  **Get ticket ID**

  - required for run
  - ask conversationally
    if missing (PROJ-123)
| {
  shape: rectangle
  style.fill: "#f5f5f5"
  style.stroke: "#333333"
  style.stroke-width: 2
}

# --- Action decision ---

action: |md
  **Action select**
  AskUserQuestion

  full / steps / resume?
| {
  shape: diamond
  style.fill: "#f5f5f5"
  style.stroke: "#333333"
  style.stroke-width: 2
}

# --- Full config ---

full-config: |md
  **Full config**
  AskUserQuestion (x4)

  - output format
  - source code
  - doc placement
  - create linked JIRA
| {
  shape: rectangle
  style.fill: "#f5f5f5"
  style.stroke: "#333333"
  style.stroke-width: 2
}

# --- Specific steps ---

specific-steps: |md
  **Specific step(s)**
  multiSelect + resolve

  - pick steps
  - resolve_steps.py
    prereq dependencies
  - relevant config Qs
| {
  shape: rectangle
  style.fill: "#f5f5f5"
  style.stroke: "#333333"
  style.stroke-width: 2
}

# --- Follow-ups ---

followups: |md
  **Free-text follow-ups**
  AskUserQuestion (textInput)

  - PR/MR URLs
  - repo URL or path
  - docs-repo path
  - JIRA project key
| {
  shape: rectangle
  style.fill: "#f5f5f5"
  style.stroke: "#333333"
  style.stroke-width: 2
}

# --- Build flags ---

build-flags: |md
  **Build CLI flags**

  - map answers to flags
  - --mkdocs, --draft,
    --pr, --create-jira
  - docs-repo-path wins
    over --draft
| {
  shape: rectangle
  style.fill: "#f5f5f5"
  style.stroke: "#333333"
  style.stroke-width: 2
}

# --- Execute ---

execute: |md
  **Execute**

  - run full workflow
    or step skills
  - ticket + built args
| {
  shape: rectangle
  style.fill: "#f5f5f5"
  style.stroke: "#333333"
  style.stroke-width: 2
}

# --- External orchestrator ---

orchestrator: |md
  **docs-orchestrator**

  - full pipeline run, or
  - direct step skills
    (deps resolved)
| {
  shape: rectangle
  style.fill: "#e8e8e8"
  style.stroke: "#333333"
  style.stroke-width: 2
  style.stroke-dash: 3
}

# --- Flow ---

entry -> mode

mode -> passthrough: "yes\n(switches present)"
passthrough -> orchestrator: "all original args"

mode -> get-ticket: "no\n(bare / ticket)"
get-ticket -> action

action -> full-config: "full workflow"
action -> specific-steps: "specific steps"
action -> execute: "resume"

full-config -> followups
specific-steps -> followups

followups -> build-flags
build-flags -> execute
execute -> orchestrator: "invoke"
