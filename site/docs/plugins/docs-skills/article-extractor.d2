direction: right

*.style.border-radius: 8
*.style.font-size: 13
*.style.fill: "#f5f5f5"
*.style.stroke: "#333333"

# --- Entry ---

entry: |md
  **article_extractor.py**

  - --url (required)
  - --format html/md/text
  - --selector CSS
  - --output FILE
  - --strip-links
| {
  shape: rectangle
  style.fill: "#f5f5f5"
  style.stroke: "#333333"
  style.stroke-width: 2
}

# --- Download ---

download: |md
  **Download HTML**

  - fetch page from URL
  - static HTML only
  - no auth support
| {
  shape: rectangle
  style.fill: "#f5f5f5"
  style.stroke: "#333333"
  style.stroke-width: 2
}

requests: |md
  **requests**
| {
  shape: rectangle
  style.fill: "#e8e8e8"
  style.stroke: "#333333"
  style.stroke-width: 2
  style.stroke-dash: 3
}

# --- Extract ---

extract: |md
  **Extract Article**

  - locate <article> by
    CSS selector
  - default aria-live
    ="polite"
  - strip nav / styling
    bloat
| {
  shape: rectangle
  style.fill: "#f5f5f5"
  style.stroke: "#333333"
  style.stroke-width: 2
}

soup: |md
  **BeautifulSoup**
| {
  shape: rectangle
  style.fill: "#e8e8e8"
  style.stroke: "#333333"
  style.stroke-width: 2
  style.stroke-dash: 3
}

# --- Convert ---

convert: |md
  **Convert Format**

  - html: tags preserved
  - markdown (html2text)
  - text: tags stripped
  - --strip-links option
| {
  shape: rectangle
  style.fill: "#f5f5f5"
  style.stroke: "#333333"
  style.stroke-width: 2
}

# --- Result ---

result: |md
  **Clean Content**

  - stdout (default)
  - --output file
| {
  shape: rectangle
  style.fill: "#f5f5f5"
  style.stroke: "#333333"
  style.stroke-width: 2
}

# --- Flow ---

entry -> download: "--url"
download -> requests: "GET"
requests -> extract: "raw HTML"
extract -> soup: "parse DOM"
soup -> convert: "<article> node"
convert -> result: "markdown /\nhtml / text"
