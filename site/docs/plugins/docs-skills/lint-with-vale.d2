direction: right

*.style.border-radius: 8
*.style.font-size: 13
*.style.fill: "#f5f5f5"
*.style.stroke: "#333333"

# --- Entry ---

entry: |md
  **lint-with-vale**

  - file | dir | glob
  - --minAlertLevel
  - .md .adoc .rst .html
| {
  shape: rectangle
  style.fill: "#f5f5f5"
  style.stroke: "#333333"
  style.stroke-width: 2
}

# --- Config decision ---

check-config: |md
  **.vale.ini present?**

  - ls .vale.ini vale.ini
| {
  shape: diamond
  style.fill: "#f5f5f5"
  style.stroke: "#333333"
  style.stroke-width: 2
}

# --- Sync ---

sync: |md
  **vale sync**

  - download style packages
  - update RedHat package
  - StylesPath refreshed
| {
  shape: rectangle
  style.fill: "#f5f5f5"
  style.stroke: "#333333"
  style.stroke-width: 2
}

# --- Lint ---

lint: |md
  **Run vale**

  - lint targets
  - Markdown, AsciiDoc, rST
  - HTML, code comments
| {
  shape: rectangle
  style.fill: "#f5f5f5"
  style.stroke: "#333333"
  style.stroke-width: 2
}

# --- External Vale CLI ---

vale: |md
  **Vale CLI**

  - style-guide engine
  - JSON / line output
| {
  shape: rectangle
  style.fill: "#e8e8e8"
  style.stroke: "#333333"
  style.stroke-width: 2
  style.stroke-dash: 3
}

# --- Present ---

present: |md
  **Present results**

  - errors first
  - group warn / suggest
  - per-file count table
  - flag false positives
  - no auto-fix
| {
  shape: rectangle
  style.fill: "#f5f5f5"
  style.stroke: "#333333"
  style.stroke-width: 2
}

# --- Flow ---

entry -> check-config
check-config -> sync: "found"
check-config -> sync: "none: temp\nRedHat config"
sync -> lint
lint -> vale: "invoke"
vale -> present: "alerts"
