direction: right

*.style.border-radius: 8
*.style.font-size: 13
*.style.fill: "#f5f5f5"
*.style.stroke: "#333333"

# --- Entry ---

entry: |md
  **/docs-review-style**

  - --local | --pr <url>
  - --post-comments
  - --fix
  - --threshold <0-100>
| {
  shape: rectangle
  style.fill: "#f5f5f5"
  style.stroke: "#333333"
  style.stroke-width: 2
}

# --- Mode decision ---

mode: |md
  **Select Mode**

  interactive
  AskUserQuestion
| {
  shape: diamond
  style.fill: "#f5f5f5"
  style.stroke: "#333333"
  style.stroke-width: 2
}

# --- Pre-flight ---

preflight: |md
  **Pre-flight Checks**

  - --pr: haiku agent
    (state, draft, files)
  - --local: base branch,
    feature-branch guard
| {
  shape: rectangle
  style.fill: "#f5f5f5"
  style.stroke: "#333333"
  style.stroke-width: 2
}

# --- Discover files ---

discover: |md
  **Discover Docs**

  - changed files vs base
    or PR diff
  - keep .adoc / .md
  - exit if none
| {
  shape: rectangle
  style.fill: "#f5f5f5"
  style.stroke: "#333333"
  style.stroke-width: 2
}

# --- Changed ranges ---

ranges: |md
  **Extract Ranges**

  - extract_changed_ranges.py
  - --context 3
  - changed-ranges.json
  - scope guard
| {
  shape: rectangle
  style.fill: "#f5f5f5"
  style.stroke: "#333333"
  style.stroke-width: 2
}

# --- Summarize (agent) ---

summarize: |md
  **Summarize Changes**
  sonnet agent

  - new vs modified
  - concept / procedure /
    reference / assembly
  - structural patterns
| {
  shape: rectangle
  style.fill: "#e8e8e8"
  style.stroke: "#333333"
  style.stroke-width: 3
  style.double-border: true
}

# --- Parallel review (agents) ---

review: |md
  **Parallel Review**
  3x docs-reviewer agents

  - A: IBM + RH batch
  - B: IBM/RH batch
  - modular-docs +
    content-quality (Vale)
| {
  shape: rectangle
  style.fill: "#e8e8e8"
  style.stroke: "#333333"
  style.stroke-width: 3
  style.double-border: true
}

# --- Validate (agents) ---

validate: |md
  **Validate Issues**
  per-issue subagents

  - confirm rule applies
  - verify text violates
  - sonnet for style
| {
  shape: rectangle
  style.fill: "#e8e8e8"
  style.stroke: "#333333"
  style.stroke-width: 3
  style.double-border: true
}

# --- Filter ---

filter-issues: |md
  **Filter Issues**

  - drop unvalidated
  - drop below threshold
    (default 80)
  - drop outside ranges
| {
  shape: rectangle
  style.fill: "#f5f5f5"
  style.stroke: "#333333"
  style.stroke-width: 2
}

# --- Report ---

report: |md
  **Report + Summary**

  - style-report.md
  - terminal summary
  - errors / warnings /
    suggestions
| {
  shape: rectangle
  style.fill: "#f5f5f5"
  style.stroke: "#333333"
  style.stroke-width: 2
}

# --- Post comments (external) ---

post-comments: |md
  **Post Inline Comments**
  git-pr-reader

  - extract line numbers
  - post per issue
  - one comment / issue
| {
  shape: rectangle
  style.fill: "#e8e8e8"
  style.stroke: "#333333"
  style.stroke-width: 2
  style.stroke-dash: 3
}

# --- Fix mode ---

fix-mode: |md
  **Fix Mode**

  - auto-fix >= 65%
  - interactive walkthrough
    (Apply / Modify / Skip)
| {
  shape: rectangle
  style.fill: "#f5f5f5"
  style.stroke: "#333333"
  style.stroke-width: 2
}

# --- Flow ---

entry -> mode

mode -> preflight: "--local"
mode -> preflight: "--pr <url>"

preflight -> discover
discover -> ranges: "docs found"
ranges -> summarize: "changed-ranges.json"
summarize -> review: "diff summary"
review -> validate: "candidate issues"
validate -> filter-issues
filter-issues -> report

report -> post-comments: "--pr\n--post-comments" {
  style.stroke-dash: 3
}
report -> fix-mode: "--fix" {
  style.stroke-dash: 3
}
