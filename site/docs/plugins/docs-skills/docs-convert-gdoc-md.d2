direction: right

*.style.border-radius: 8
*.style.font-size: 13
*.style.fill: "#f5f5f5"
*.style.stroke: "#333333"

# --- Entry ---

entry: |md
  **gdoc2md.py**

  - [--comments]
  - [--include-resolved]
  - <url> [output]
| {
  shape: rectangle
  style.fill: "#f5f5f5"
  style.stroke: "#333333"
  style.stroke-width: 2
}

# --- Auth ---

auth: |md
  **Authenticate**

  - gcloud CLI login
  - or Google ADC
  - GOOGLE_APPLICATION_
    CREDENTIALS
| {
  shape: rectangle
  style.fill: "#f5f5f5"
  style.stroke: "#333333"
  style.stroke-width: 2
}

google-api: |md
  **Google APIs**

  - Drive / Docs
  - Slides / Sheets
| {
  shape: rectangle
  style.fill: "#e8e8e8"
  style.stroke: "#333333"
  style.stroke-width: 2
  style.stroke-dash: 3
}

# --- Detect type ---

detect-type: |md
  **Detect URL type**
| {
  shape: diamond
  style.fill: "#f5f5f5"
  style.stroke: "#333333"
  style.stroke-width: 2
}

# --- Converters ---

docs-md: |md
  **Docs to Markdown**

  - export .md
  - --comments to
    footnotes
  - --include-resolved
| {
  shape: rectangle
  style.fill: "#f5f5f5"
  style.stroke: "#333333"
  style.stroke-width: 2
}

slides-md: |md
  **Slides to Markdown**

  - via PPTX export
  - titles, bullets
  - tables, notes
| {
  shape: rectangle
  style.fill: "#f5f5f5"
  style.stroke: "#333333"
  style.stroke-width: 2
}

sheets-csv: |md
  **Sheets to CSV**

  - export .csv
  - one file per sheet
| {
  shape: rectangle
  style.fill: "#f5f5f5"
  style.stroke: "#333333"
  style.stroke-width: 2
}

# --- Output ---

result: |md
  **Output file**

  - <id>.md or .csv
  - read + present
| {
  shape: rectangle
  style.fill: "#f5f5f5"
  style.stroke: "#333333"
  style.stroke-width: 2
}

# --- Flow ---

entry -> auth
auth -> google-api: "credentials"
auth -> detect-type

detect-type -> docs-md: "/document/"
detect-type -> slides-md: "/presentation/"
detect-type -> sheets-csv: "/spreadsheets/"

docs-md -> google-api: "fetch" {
  style.stroke-dash: 3
}
slides-md -> google-api: "fetch" {
  style.stroke-dash: 3
}
sheets-csv -> google-api: "fetch" {
  style.stroke-dash: 3
}

docs-md -> result
slides-md -> result
sheets-csv -> result
