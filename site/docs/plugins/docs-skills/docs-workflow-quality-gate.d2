direction: right

*.style.border-radius: 8
*.style.font-size: 13
*.style.fill: "#f5f5f5"
*.style.stroke: "#333333"

# --- Entry ---

entry: |md
  **/docs-workflow-quality-gate**

  - <ticket>
  - --base-path <path>
| {
  shape: rectangle
  style.fill: "#f5f5f5"
  style.stroke: "#333333"
  style.stroke-width: 2
}

# --- Prepare ---

prepare: |md
  **Prepare prompts**

  - quality_gate.py prepare
  - reads writing + ticket ctx
  - dq-prompt.md
  - ia-prompt.md
| {
  shape: rectangle
  style.fill: "#f5f5f5"
  style.stroke: "#333333"
  style.stroke-width: 2
}

# --- Per-AC coverage agents ---

coverage-verify: |md
  **Per-AC coverage agents**
  parallel (one per AC)

  - one subagent per AC item
  - covered: true / false
  - verbatim quote
| {
  shape: rectangle
  style.fill: "#e8e8e8"
  style.stroke: "#333333"
  style.stroke-width: 3
  style.double-border: true
}

# --- Classify coverage ---

classify-coverage: |md
  **Classify coverage**

  - verify --classify
  - quote substring match
  - join evidence-status
  - coverage-check.json
  - covered / real_defect /
    correctly_absent / unverified
| {
  shape: rectangle
  style.fill: "#f5f5f5"
  style.stroke: "#333333"
  style.stroke-width: 2
}

# --- Judge agents ---

judges: |md
  **Judge agents (Opus)**
  2 in parallel

  - doc_quality (score 1-5)
  - intent_alignment (1-5)
  - + missed_items[]
  - judge-results.json
| {
  shape: rectangle
  style.fill: "#e8e8e8"
  style.stroke: "#333333"
  style.stroke-width: 3
  style.double-border: true
}

# --- Classify gaps ---

classify-gaps: |md
  **Classify gaps**

  - quality_gate.py classify
  - x-ref scope-req-audit
    evidence
  - step-result.json
| {
  shape: rectangle
  style.fill: "#f5f5f5"
  style.stroke: "#333333"
  style.stroke-width: 2
}

# --- Decision ---

passed: |md
  **intent_alignment >= 4 ?**
| {
  shape: diamond
  style.fill: "#f5f5f5"
  style.stroke: "#333333"
  style.stroke-width: 2
}

# --- Feedback brief ---

feedback-brief: |md
  **Feedback brief**
  passed = false

  - feedback-brief-N.md
  - full judge rationales
  - classified gaps + actions
  - writer fix loop
| {
  shape: rectangle
  style.fill: "#f5f5f5"
  style.stroke: "#333333"
  style.stroke-width: 2
}

# --- Report ---

report: |md
  **Report**

  - scores dq / ia
  - pass / fail verdict
  - gaps list
| {
  shape: rectangle
  style.fill: "#f5f5f5"
  style.stroke: "#333333"
  style.stroke-width: 2
}

# --- Flow ---

entry -> prepare
prepare -> coverage-verify: "coverage prompts"
coverage-verify -> classify-coverage: "covered + quote"
classify-coverage -> judges: "coverage-check.json"
judges -> classify-gaps: "judge-results.json"
classify-gaps -> passed

passed -> report: "true"
passed -> feedback-brief: "false"
feedback-brief -> report
