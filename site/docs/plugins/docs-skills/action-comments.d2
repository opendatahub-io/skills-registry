direction: right

*.style.border-radius: 8
*.style.font-size: 13
*.style.fill: "#f5f5f5"
*.style.stroke: "#333333"

# --- Entry ---

entry: |md
  **/action-comments**

  - [url] [--ci]
  - [--include-resolved]
  - workflow: <ticket>
    --base-path
| {
  shape: rectangle
  style.fill: "#f5f5f5"
  style.stroke: "#333333"
  style.stroke-width: 2
}

# --- Resolve URL ---

resolve-url: |md
  **Resolve PR/MR URL**

  - use given url, or
    git_pr_reader detect
  - validate forge URL
    (pull/merge_requests)
| {
  shape: rectangle
  style.fill: "#f5f5f5"
  style.stroke: "#333333"
  style.stroke-width: 2
}

# --- Load workspace ---

load-workspace: |md
  **Load Workspace**

  - .agent_workspace/
  - code-analysis,
    requirements
  - tech-review, scope-audit
  - source.yaml (grounding)
| {
  shape: rectangle
  style.fill: "#f5f5f5"
  style.stroke: "#333333"
  style.stroke-width: 2
}

# --- Checkout ---

checkout: |md
  **Checkout Branch**

  - git_pr_reader info
    → head_ref, title
  - validate ref name
  - git fetch + checkout
| {
  shape: rectangle
  style.fill: "#f5f5f5"
  style.stroke: "#333333"
  style.stroke-width: 2
}

# --- Fetch comments ---

fetch-comments: |md
  **Fetch Comments**

  - git_pr_reader
    comments --json
  - filters bots + resolved
  - id, path, line, body
| {
  shape: rectangle
  style.fill: "#f5f5f5"
  style.stroke: "#333333"
  style.stroke-width: 2
}

# --- External CLI ---

git-pr-reader: |md
  **git_pr_reader.py**

  - unified GitHub /
    GitLab interface
  - detect / info /
    comments / reply
| {
  shape: rectangle
  style.fill: "#e8e8e8"
  style.stroke: "#333333"
  style.stroke-width: 2
  style.stroke-dash: 3
}

# --- Categorize ---

categorize: |md
  **Categorize**

  - Required / Suggestion
  - Question
  - Outdated = quoted text
    no longer near line
| {
  shape: rectangle
  style.fill: "#f5f5f5"
  style.stroke: "#333333"
  style.stroke-width: 2
}

# --- Mode decision ---

mode: |md
  **--ci ?**
| {
  shape: diamond
  style.fill: "#f5f5f5"
  style.stroke: "#333333"
  style.stroke-width: 2
}

# --- Interactive ---

interactive: |md
  **Interactive**

  - per comment: Apply /
    Edit / Skip / View
  - AskUserQuestion
  - grounded in workspace
| {
  shape: rectangle
  style.fill: "#f5f5f5"
  style.stroke: "#333333"
  style.stroke-width: 2
}

# --- CI ---

ci: |md
  **CI (autonomous)**

  - auto-decide by category
  - apply edits
  - post reply comments
    explaining rationale
| {
  shape: rectangle
  style.fill: "#f5f5f5"
  style.stroke: "#333333"
  style.stroke-width: 2
}

# --- Summary ---

summary: |md
  **Summary**

  - metrics table
  - changes applied / skipped
  - step-result.json
    (workflow-step mode)
| {
  shape: rectangle
  style.fill: "#f5f5f5"
  style.stroke: "#333333"
  style.stroke-width: 2
}

# --- Flow ---

entry -> resolve-url
resolve-url -> load-workspace
load-workspace -> checkout
checkout -> fetch-comments
fetch-comments -> categorize
categorize -> mode

mode -> interactive: "no"
mode -> ci: "--ci"

interactive -> summary
ci -> summary

# --- External CLI usage (dashed) ---

resolve-url -> git-pr-reader: "detect" {
  style.stroke-dash: 3
}
checkout -> git-pr-reader: "info" {
  style.stroke-dash: 3
}
fetch-comments -> git-pr-reader: "comments" {
  style.stroke-dash: 3
}
ci -> git-pr-reader: "reply" {
  style.stroke-dash: 3
}
