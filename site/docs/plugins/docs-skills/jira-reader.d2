direction: right

*.style.border-radius: 8
*.style.font-size: 13
*.style.fill: "#f5f5f5"
*.style.stroke: "#333333"

# --- Entry ---

entry: |md
  **jira_reader.py**
  read-only JIRA access

  - --issue KEY
  - --jql "..."
  - --graph KEY
| {
  shape: rectangle
  style.fill: "#f5f5f5"
  style.stroke: "#333333"
  style.stroke-width: 2
}

# --- Mode decision ---

mode: |md
  **Query mode?**
| {
  shape: diamond
  style.fill: "#f5f5f5"
  style.stroke: "#333333"
  style.stroke-width: 2
}

# --- Modes (fan-out) ---

fetch-issue: |md
  **Fetch Issue**
  --issue (full detail)

  - description, status,
    priority, assignee
  - comments (anonymized)
  - custom fields, git links
| {
  shape: rectangle
  style.fill: "#f5f5f5"
  style.stroke: "#333333"
  style.stroke-width: 2
}

search-jql: |md
  **Search JQL**
  --jql

  - summary mode: 1 call
  - --fetch-details:
    N+1 calls, full fields
  - categorize issues
| {
  shape: rectangle
  style.fill: "#f5f5f5"
  style.stroke: "#333333"
  style.stroke-width: 2
}

graph: |md
  **Traverse Graph**
  --graph

  - ancestors, children
  - siblings, issue links
  - remote/web links
| {
  shape: rectangle
  style.fill: "#f5f5f5"
  style.stroke: "#333333"
  style.stroke-width: 2
}

# --- External service ---

jira-api: |md
  **Atlassian REST API v3**
  redhat.atlassian.net

  - ADF to plain text
  - rate-limited
    (2 calls / 5s)
| {
  shape: rectangle
  style.fill: "#e8e8e8"
  style.stroke: "#333333"
  style.stroke-width: 2
  style.stroke-dash: 3
}

# --- Output ---

results: |md
  **JSON Output**

  - summary / detailed
  - graph relationships
| {
  shape: rectangle
  style.fill: "#f5f5f5"
  style.stroke: "#333333"
  style.stroke-width: 2
}

# --- Flow ---

entry -> mode

mode -> fetch-issue: "--issue"
mode -> search-jql: "--jql"
mode -> graph: "--graph"

fetch-issue -> jira-api
search-jql -> jira-api
graph -> jira-api

jira-api -> results
