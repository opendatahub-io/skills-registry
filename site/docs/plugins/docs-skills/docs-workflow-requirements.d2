direction: right

*.style.border-radius: 8
*.style.font-size: 13
*.style.fill: "#f5f5f5"
*.style.stroke: "#333333"

# --- Entry ---

entry: |md
  **/docs-workflow-requirements**

  - <ticket>
  - --base-path
  - --pr <url> (repeatable)
  - --repo <path>
| {
  shape: rectangle
  style.fill: "#f5f5f5"
  style.stroke: "#333333"
  style.stroke-width: 2
}

# --- Pass 1: Discovery agent ---

discovery: |md
  **Discovery Pass**
  requirements-discoverer agent

  - fetch JIRA ticket
  - traverse ticket graph
  - list PRs + specs
  - enumerate requirements
| {
  shape: rectangle
  style.fill: "#e8e8e8"
  style.stroke: "#333333"
  style.stroke-width: 3
  style.double-border: true
}

# --- Extract repos ---

extract-repos: |md
  **Extract Repos**

  - extract_discovered_repos.py
  - read JIRA graph links
  - dedup repo / PR URLs
  - discovered_repos.json
| {
  shape: rectangle
  style.fill: "#f5f5f5"
  style.stroke: "#333333"
  style.stroke-width: 2
}

# --- Parse discovery summary ---

parse-discovery: |md
  **Parse Discovery**

  - compact JSON only
  - count + REQ ids + titles
  - no full read to context
  - count 0 -> minimal md
| {
  shape: rectangle
  style.fill: "#f5f5f5"
  style.stroke: "#333333"
  style.stroke-width: 2
}

# --- Pass 2: Fan-out deep analysis ---

fanout: |md
  **Deep Analysis Fan-Out**
  requirements-analyst agents

  - one agent per requirement
  - all launched in parallel
  - read skeleton from disk
  - write req-NNN.json
| {
  shape: rectangle
  style.fill: "#e8e8e8"
  style.stroke: "#333333"
  style.stroke-width: 3
  style.double-border: true
}

# --- Merge ---

merge: |md
  **Merge Assembly**
  merge agent

  - read per-req JSON files
  - fallback to skeleton
  - assemble by priority
  - write requirements.md
| {
  shape: rectangle
  style.fill: "#e8e8e8"
  style.stroke: "#333333"
  style.stroke-width: 3
  style.double-border: true
}

# --- Sidecar ---

sidecar: |md
  **Write Sidecar**

  - parse_title.py
  - extract first heading
  - requirement_count
  - step-result.json
| {
  shape: rectangle
  style.fill: "#f5f5f5"
  style.stroke: "#333333"
  style.stroke-width: 2
}

# --- Output ---

requirements: |md
  **requirements.md**

  - requirements by priority
  - documentation scope
  - breaking changes
  - sources consulted
| {
  shape: rectangle
  style.fill: "#f5f5f5"
  style.stroke: "#333333"
  style.stroke-width: 2
}

# --- Flow ---

entry -> discovery
discovery -> extract-repos: "discovery.json"
extract-repos -> parse-discovery: "discovered_repos.json"
parse-discovery -> fanout: "REQ ids"
fanout -> merge: "req-NNN.json"
merge -> sidecar: "requirements.md"
sidecar -> requirements: "step-result.json"
