direction: right

*.style.border-radius: 8
*.style.font-size: 13
*.style.fill: "#f5f5f5"
*.style.stroke: "#333333"

# --- Entry ---

entry: |md
  **/docs-workflow-create-merge-request**

  - <ticket>
  - --base-path
  - --draft (optional)
  - --repo-path (optional)
| {
  shape: rectangle
  style.fill: "#f5f5f5"
  style.stroke: "#333333"
  style.stroke-width: 2
}

# --- Draft decision ---

draft: |md
  **--draft ?**
| {
  shape: diamond
  style.fill: "#f5f5f5"
  style.stroke: "#333333"
  style.stroke-width: 2
}

# --- Git context ---

git-context: |md
  **Git Context**

  - resolve repo root
  - current branch, remote URL
  - detect platform
    (GitHub / GitLab)
| {
  shape: rectangle
  style.fill: "#f5f5f5"
  style.stroke: "#333333"
  style.stroke-width: 2
}

# --- Branch ---

branch: |md
  **Feature Branch**

  - on main/master ?
  - create <ticket> branch
  - or switch to existing
  - skip if --repo-path
| {
  shape: rectangle
  style.fill: "#f5f5f5"
  style.stroke: "#333333"
  style.stroke-width: 2
}

# --- Manifest ---

manifest: |md
  **Read Manifest**

  - writing/step-result.json
  - files[] to commit
  - filter to repo root
| {
  shape: rectangle
  style.fill: "#f5f5f5"
  style.stroke: "#333333"
  style.stroke-width: 2
}

# --- Commit ---

commit: |md
  **Stage & Commit**

  - git add manifest files
  - docs(<ticket>): add
    generated documentation
| {
  shape: rectangle
  style.fill: "#f5f5f5"
  style.stroke: "#333333"
  style.stroke-width: 2
}

# --- Push ---

push-branch: |md
  **Push**

  - git push
    --force-with-lease
  - to origin
| {
  shape: rectangle
  style.fill: "#f5f5f5"
  style.stroke: "#333333"
  style.stroke-width: 2
}

# --- Create MR/PR ---

create-mr: |md
  **Create MR / PR**

  - build title from
    requirements
  - check existing open MR/PR
  - create new if none
| {
  shape: rectangle
  style.fill: "#f5f5f5"
  style.stroke: "#333333"
  style.stroke-width: 2
}

# --- External CLI ---

gh-glab: |md
  **gh / glab CLI**

  - gh pr create (GitHub)
  - glab mr create (GitLab)
  - fork detection
| {
  shape: rectangle
  style.fill: "#e8e8e8"
  style.stroke: "#333333"
  style.stroke-width: 2
  style.stroke-dash: 3
}

# --- Sidecar ---

sidecar: |md
  **step-result.json**

  - commit_sha, branch
  - pushed, url
  - action, platform
  - skipped, skip_reason
| {
  shape: rectangle
  style.fill: "#f5f5f5"
  style.stroke: "#333333"
  style.stroke-width: 2
}

# --- Flow ---

entry -> draft

draft -> sidecar: "yes: skip\ngit ops" {
  style.stroke-dash: 3
}
draft -> git-context: "no"

git-context -> branch
branch -> manifest
manifest -> commit
commit -> push-branch
push-branch -> create-mr

create-mr -> gh-glab: "invoke" {
  style.stroke-dash: 3
}
gh-glab -> create-mr: "MR/PR url" {
  style.stroke-dash: 3
}

create-mr -> sidecar
