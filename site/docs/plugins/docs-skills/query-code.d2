direction: right

*.style.border-radius: 8
*.style.font-size: 13
*.style.fill: "#f5f5f5"
*.style.stroke: "#333333"

# --- Entry ---

entry: |md
  **/query-code**

  - <question>
  - --repo <path|url>
| {
  shape: rectangle
  style.fill: "#f5f5f5"
  style.stroke: "#333333"
  style.stroke-width: 2
}

# --- Resolve analysis ---

resolve: |md
  **Resolve Analysis**

  - --repo path or git URL
  - or scan .agent_workspace
  - single ONBOARDING.md
  - derive BASE_PATH
| {
  shape: rectangle
  style.fill: "#f5f5f5"
  style.stroke: "#333333"
  style.stroke-width: 2
}

# --- Decision ---

has-analysis: |md
  **Analysis exists?**
| {
  shape: diamond
  style.fill: "#f5f5f5"
  style.stroke: "#333333"
  style.stroke-width: 2
}

# --- External skill ---

learn-code: |md
  **learn-code**
  (other skill)

  - offer to run first
  - analyze the codebase
| {
  shape: rectangle
  style.fill: "#e8e8e8"
  style.stroke: "#333333"
  style.stroke-width: 2
  style.stroke-dash: 3
}

# --- Load context ---

load-context: |md
  **Load Context**

  - detection.json
  - registry.json
  - summary.json
  - relationships.json
  - ONBOARDING.md
| {
  shape: rectangle
  style.fill: "#f5f5f5"
  style.stroke: "#333333"
  style.stroke-width: 2
}

# --- Agent ---

code-questioner: |md
  **code-questioner**
  LLM agent

  - reasons over context
  - Read / Grep the source
  - gather file:line evidence
| {
  shape: rectangle
  style.fill: "#e8e8e8"
  style.stroke: "#333333"
  style.stroke-width: 2
  style.double-border: true
}

# --- Output ---

answer: |md
  **Answer**

  - timestamped .md
  - YAML frontmatter
  - to queries/
| {
  shape: rectangle
  style.fill: "#f5f5f5"
  style.stroke: "#333333"
  style.stroke-width: 2
}

# --- Flow ---

entry -> resolve
resolve -> has-analysis

has-analysis -> learn-code: "no"
has-analysis -> load-context: "yes"
learn-code -> load-context

load-context -> code-questioner: "context + ONBOARDING"
code-questioner -> answer: "file:line answer"
