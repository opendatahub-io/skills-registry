direction: right

*.style.border-radius: 8
*.style.font-size: 13
*.style.fill: "#f5f5f5"
*.style.stroke: "#333333"

# --- Entry ---

entry: |md
  **toc_extractor.py**

  - --url (required)
  - --format json | list
  - --output FILE
| {
  shape: rectangle
  style.fill: "#f5f5f5"
  style.stroke: "#333333"
  style.stroke-width: 2
}

# --- Download ---

download: |md
  **Download Page**

  - fetch Red Hat docs URL
  - requests.get(html)
  - stream HTML content
| {
  shape: rectangle
  style.fill: "#f5f5f5"
  style.stroke: "#333333"
  style.stroke-width: 2
}

# --- Locate TOC ---

locate-toc: |md
  **Locate TOC**

  - parse with BeautifulSoup
  - find nav#toc element
  - class table-of-contents
| {
  shape: rectangle
  style.fill: "#f5f5f5"
  style.stroke: "#333333"
  style.stroke-width: 2
}

# --- Extract links ---

extract-links: |md
  **Extract Links**

  - parse all <a> tags
  - drop #anchors + fragments
  - skip index pages
  - relative -> absolute
| {
  shape: rectangle
  style.fill: "#f5f5f5"
  style.stroke: "#333333"
  style.stroke-width: 2
}

# --- Dedup + sort ---

dedup-sort: |md
  **Dedup + Sort**

  - remove duplicate URLs
  - alphabetical sort
  - distinct article pages
| {
  shape: rectangle
  style.fill: "#f5f5f5"
  style.stroke: "#333333"
  style.stroke-width: 2
}

# --- Result ---

result: |md
  **Result**

  - JSON: count + articles
  - or plain URL list
  - stdout or --output file
| {
  shape: rectangle
  style.fill: "#f5f5f5"
  style.stroke: "#333333"
  style.stroke-width: 2
}

# --- Flow ---

entry -> download
download -> locate-toc: "HTML"
locate-toc -> extract-links: "nav#toc"
extract-links -> dedup-sort: "absolute URLs"
dedup-sort -> result
