direction: right

*.style.border-radius: 8
*.style.font-size: 13
*.style.fill: "#f5f5f5"
*.style.stroke: "#333333"

# --- Entry ---

entry: |md
  **/docs-review-technical**

  - --local | --pr <url>
  - --code <url>, --jira
  - --fix, --threshold
| {
  shape: rectangle
  style.fill: "#f5f5f5"
  style.stroke: "#333333"
  style.stroke-width: 2
}

# --- Discovery phase ---

preflight: |md
  **Pre-flight Checks**

  - PR closed/draft?
  - any .adoc/.md changed?
  - Claude already commented?
| {
  shape: rectangle
  style.fill: "#f5f5f5"
  style.stroke: "#333333"
  style.stroke-width: 2
}

discover: |md
  **Discover Doc Files**

  - git diff / PR files
  - filter .adoc + .md
  - exit if none
| {
  shape: rectangle
  style.fill: "#f5f5f5"
  style.stroke: "#333333"
  style.stroke-width: 2
}

ranges: |md
  **Extract Changed Ranges**

  - extract_changed_ranges.py
  - "new" or [start, end]
  - scopes all agents
| {
  shape: rectangle
  style.fill: "#f5f5f5"
  style.stroke: "#333333"
  style.stroke-width: 2
}

# --- Review agents (LLM) ---

summarize: |md
  **Summarize Changes**
  sonnet agent

  - new vs modified
  - concept/procedure/ref
  - structural patterns
| {
  shape: rectangle
  style.fill: "#e8e8e8"
  style.stroke: "#333333"
  style.stroke-width: 2
  style.double-border: true
}

agent-technical: |md
  **Agent 1 — Technical**
  technical-reviewer (opus)

  - doc-type detection
  - 6 review dimensions
  - accuracy & consistency
  - confidence scoring
| {
  shape: rectangle
  style.fill: "#e8e8e8"
  style.stroke: "#333333"
  style.stroke-width: 2
  style.double-border: true
}

agent-code-aware: |md
  **Agent 2 — Code-Aware**
  general-purpose (opus)

  - clone repos, extract_refs.py
  - validate claims vs source
  - verified/inaccurate/stale
| {
  shape: rectangle
  style.fill: "#e8e8e8"
  style.stroke: "#333333"
  style.stroke-width: 2
  style.double-border: true
}

# --- Externals ---

git-pr-reader: |md
  **git-pr-reader**

  - files / diff / clone
  - extract line numbers
| {
  shape: rectangle
  style.fill: "#e8e8e8"
  style.stroke: "#333333"
  style.stroke-width: 2
  style.stroke-dash: 3
}

jira-reader: |md
  **jira-reader**

  - fetch ticket
  - discover code repos
| {
  shape: rectangle
  style.fill: "#e8e8e8"
  style.stroke: "#333333"
  style.stroke-width: 2
  style.stroke-dash: 3
}

# --- Triage + validation ---

triage: |md
  **Structured Triage**

  - 5-pass classification
  - scope, claim, API surface
  - source verify, dedup
| {
  shape: rectangle
  style.fill: "#f5f5f5"
  style.stroke: "#333333"
  style.stroke-width: 2
}

validate: |md
  **Validate Issues**
  per-issue opus subagents

  - confirm each finding
  - wrong flag / stale API
  - broken example / config
| {
  shape: rectangle
  style.fill: "#e8e8e8"
  style.stroke: "#333333"
  style.stroke-width: 2
  style.double-border: true
}

filter-issues: |md
  **Filter Issues**

  - drop unvalidated
  - below threshold (80)
  - outside changed ranges
| {
  shape: rectangle
  style.fill: "#f5f5f5"
  style.stroke: "#333333"
  style.stroke-width: 2
}

blast-scan: |md
  **Anti-Pattern / Blast Scan**
  (when Agent 2 ran)

  - grep whole doc tree
  - repeated wrong flags
  - blast-radius per issue
| {
  shape: rectangle
  style.fill: "#f5f5f5"
  style.stroke: "#333333"
  style.stroke-width: 2
}

# --- Output ---

report: |md
  **Report & Present**

  - report.md + summary
  - file:line [confidence]
| {
  shape: rectangle
  style.fill: "#f5f5f5"
  style.stroke: "#333333"
  style.stroke-width: 2
}

post-comments: |md
  **Post Inline Comments**

  - --pr --post-comments
  - one comment per issue
| {
  shape: rectangle
  style.fill: "#e8e8e8"
  style.stroke: "#333333"
  style.stroke-width: 2
  style.stroke-dash: 3
}

fix-mode: |md
  **Fix Mode**
  (--fix)

  - auto-fix >= 65%
  - interactive walkthrough
| {
  shape: rectangle
  style.fill: "#f5f5f5"
  style.stroke: "#333333"
  style.stroke-width: 2
}

# --- Flow ---

entry -> preflight
preflight -> discover
discover -> ranges
ranges -> summarize

summarize -> agent-technical
agent-technical -> agent-code-aware: "when --code / --jira" {
  style.stroke-dash: 3
}

agent-technical -> triage
agent-code-aware -> triage

triage -> validate
validate -> filter-issues
filter-issues -> blast-scan: "when Agent 2 ran" {
  style.stroke-dash: 3
}
filter-issues -> report
blast-scan -> report

report -> post-comments: "--post-comments" {
  style.stroke-dash: 3
}
report -> fix-mode: "--fix" {
  style.stroke-dash: 3
}

# External service edges (dashed)
preflight -> git-pr-reader: {
  style.stroke-dash: 3
}
discover -> git-pr-reader: {
  style.stroke-dash: 3
}
agent-code-aware -> jira-reader: {
  style.stroke-dash: 3
}
post-comments -> git-pr-reader: {
  style.stroke-dash: 3
}
