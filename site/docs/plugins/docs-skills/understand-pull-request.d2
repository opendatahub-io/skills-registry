direction: right

*.style.border-radius: 8
*.style.font-size: 13
*.style.fill: "#f5f5f5"
*.style.stroke: "#333333"

# --- Entry ---

entry: |md
  **/understand-pull-request**

  - <pr-number-or-url>
  - --repo <path>
| {
  shape: rectangle
  style.fill: "#f5f5f5"
  style.stroke: "#333333"
  style.stroke-width: 2
}

# --- Pre-flight ---

preflight: |md
  **Pre-flight**

  - parse PR ref, resolve repo
  - detect platform (GitHub/GitLab)
  - validate auth token
  - resume checkpoint check
| {
  shape: rectangle
  style.fill: "#f5f5f5"
  style.stroke: "#333333"
  style.stroke-width: 2
}

# --- Step 1: PR Metadata ---

pr-metadata: |md
  **PR Metadata**

  - fetch metadata + diff.patch
  - metadata.json
  - step-result.json
| {
  shape: rectangle
  style.fill: "#f5f5f5"
  style.stroke: "#333333"
  style.stroke-width: 2
}

git-pr-reader: |md
  **git-pr-reader**
  (external skill)

  - git_pr_reader.py metadata
  - GitHub / GitLab API
| {
  shape: rectangle
  style.fill: "#e8e8e8"
  style.stroke: "#333333"
  style.stroke-width: 2
  style.stroke-dash: 3
}

# --- Step 2: Repo Context ---

repo-context: |md
  **Repo Context**

  - detect language + module map
  - reuse ONBOARDING.md, OR
  - dispatch pr-repo-summarizer
  - detection.json
| {
  shape: rectangle
  style.fill: "#f5f5f5"
  style.stroke: "#333333"
  style.stroke-width: 2
}

# --- Step 3: Change Analysis (LLM fan-out) ---

change-analysis: |md
  **Change Analysis**
  LLM fan-out (agents)

  - identify affected modules
  - pr-change-analyzer agents
  - batches of ≤10, parallel
  - change-summary.json
| {
  shape: rectangle
  style.fill: "#e8e8e8"
  style.stroke: "#333333"
  style.stroke-width: 2
  style.double-border: true
}

# --- Step 4: Synthesis (LLM agent) ---

synthesis: |md
  **Synthesis**
  LLM agent

  - build context.json
  - pr-synthesis-writer agent
  - PR-<N>-ANALYSIS.md
| {
  shape: rectangle
  style.fill: "#e8e8e8"
  style.stroke: "#333333"
  style.stroke-width: 2
  style.double-border: true
}

# --- Output ---

analysis-doc: |md
  **PR-ANALYSIS.md**

  - repo overview
  - per-module changes
  - risks + breaking changes
| {
  shape: rectangle
  style.fill: "#f5f5f5"
  style.stroke: "#333333"
  style.stroke-width: 2
}

# --- Flow ---

entry -> preflight
preflight -> pr-metadata

pr-metadata -> git-pr-reader: "fetch" {
  style.stroke-dash: 3
}
git-pr-reader -> pr-metadata: "metadata + diff" {
  style.stroke-dash: 3
}

pr-metadata -> repo-context: "metadata.json"
repo-context -> change-analysis: "detection.json"
change-analysis -> synthesis: "change-summary.json"
synthesis -> analysis-doc: "PR-<N>-ANALYSIS.md"
