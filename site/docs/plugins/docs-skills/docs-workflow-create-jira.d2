direction: right

*.style.border-radius: 8
*.style.font-size: 13
*.style.fill: "#f5f5f5"
*.style.stroke: "#333333"

# --- Entry ---

entry: |md
  **/docs-workflow-create-jira**

  - <ticket> (parent ID)
  - --base-path <path>
  - --project <PROJECT>
| {
  shape: rectangle
  style.fill: "#f5f5f5"
  style.stroke: "#333333"
  style.stroke-width: 2
}

# --- Script container ---

script: create-jira-ticket.sh {
  style.fill: "#ececec"
  style.stroke: "#333333"
  style.stroke-width: 2

  check-link: |md
    **Check Existing Link**

    - "Document" link on parent?
    - if present, exit early
  | {
    shape: rectangle
    style.fill: "#f5f5f5"
    style.stroke: "#333333"
    style.stroke-width: 2
  }

  visibility: |md
    **Probe Visibility**

    - unauthenticated probe
    - public vs private project
  | {
    shape: rectangle
    style.fill: "#f5f5f5"
    style.stroke: "#333333"
    style.stroke-width: 2
  }

  extract-desc: |md
    **Extract Description**

    - pull JTBD sections
      from plan.md
    - append dated footer
  | {
    shape: rectangle
    style.fill: "#f5f5f5"
    style.stroke: "#333333"
    style.stroke-width: 2
  }

  convert: |md
    **Convert Markup**

    - md2wiki.py
    - markdown -> JIRA
      wiki markup
  | {
    shape: rectangle
    style.fill: "#f5f5f5"
    style.stroke: "#333333"
    style.stroke-width: 2
  }

  create: |md
    **Create Ticket**

    - POST JIRA REST API
    - "[ccs] Docs -" prefix
  | {
    shape: rectangle
    style.fill: "#f5f5f5"
    style.stroke: "#333333"
    style.stroke-width: 2
  }

  link-attach: |md
    **Link & Attach**

    - "Document" link to parent
    - attach plan (private only)
  | {
    shape: rectangle
    style.fill: "#f5f5f5"
    style.stroke: "#333333"
    style.stroke-width: 2
  }

  check-link -> visibility
  visibility -> extract-desc
  extract-desc -> convert
  convert -> create
  create -> link-attach
}

# --- External service ---

jira: |md
  **JIRA REST API**

  - redhat.atlassian.net
| {
  shape: rectangle
  style.fill: "#e8e8e8"
  style.stroke: "#333333"
  style.stroke-width: 2
  style.stroke-dash: 3
}

# --- Output sidecar ---

sidecar: |md
  **step-result.json**

  - jira_url, jira_key
  - action: created /
    found_existing / skipped
| {
  shape: rectangle
  style.fill: "#f5f5f5"
  style.stroke: "#333333"
  style.stroke-width: 2
}

# --- Flow ---

entry -> script.check-link: "plan.md"
script.create -> jira: "POST issue"
script.link-attach -> jira: "link + attach"
script.link-attach -> sidecar: "write result"
