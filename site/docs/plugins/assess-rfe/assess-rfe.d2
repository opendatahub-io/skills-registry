direction: right

*.style.border-radius: 8
*.style.font-size: 13
*.style.fill: "#f5f5f5"
*.style.stroke: "#333333"

# --- Entry ---

entry: |md
  **/assess-rfe**

  - Jira key, file, URL, text
  - or wildcard for bulk
| {
  shape: rectangle
  style.fill: "#f5f5f5"
  style.stroke: "#333333"
  style.stroke-width: 2
}

# --- Input Detection ---

detect: |md
  **Detect Input Type**

  - Jira key: `KEY-123`
  - file path or URL
  - raw text
  - wildcard: `PROJ-*`
| {
  shape: rectangle
  style.fill: "#f5f5f5"
  style.stroke: "#333333"
  style.stroke-width: 2
}

# --- Single Input Path ---

single: Single Input {
  style.fill: "#ececec"
  style.stroke: "#333333"
  style.stroke-width: 2

  fetch: Fetch Content {
    style.fill: "#e4e4e4"
    style.stroke: "#333333"
    style.stroke-width: 2

    mcp: |md
      **Jira MCP**

      - getJiraIssue
      - extract summary +
        description
    | {
      shape: rectangle
      style.fill: "#f5f5f5"
      style.stroke: "#333333"
      style.stroke-width: 2
      style.stroke-dash: 3
    }

    rest-api: |md
      **Jira REST API**
      fetch_single.py

      - REST API v3 fallback
      - ADF to markdown
      - writes .md directly
    | {
      shape: rectangle
      style.fill: "#f5f5f5"
      style.stroke: "#333333"
      style.stroke-width: 2
      style.stroke-dash: 3
    }

    read-file: |md
      **Read File / URL**

      - read file contents
      - or fetch URL content
    | {
      shape: rectangle
      style.fill: "#f5f5f5"
      style.stroke: "#333333"
      style.stroke-width: 2
    }
  }

  prep: |md
    **Prep Single**
    prep_single.py

    - clean stale .md / .result.md
    - ensure output dir exists
  | {
    shape: rectangle
    style.fill: "#f5f5f5"
    style.stroke: "#333333"
    style.stroke-width: 2
  }

  write-content: |md
    **Write Content**

    - /tmp/rfe-assess/single/{KEY}.md
    - `# KEY: Title` format
    - skip if REST API wrote it
  | {
    shape: rectangle
    style.fill: "#f5f5f5"
    style.stroke: "#333333"
    style.stroke-width: 2
  }

  score-single: |md
    **Score RFE**
    LLM agent (Opus)

    - read agent_prompt.md rubric
    - score against criteria
    - write {KEY}.result.md
  | {
    shape: rectangle
    style.fill: "#e8e8e8"
    style.stroke: "#333333"
    style.stroke-width: 2
    style.double-border: true
  }

  present-single: |md
    **Present Result**

    - read {KEY}.result.md
    - wrap with header
    - display to user
  | {
    shape: rectangle
    style.fill: "#f5f5f5"
    style.stroke: "#333333"
    style.stroke-width: 2
  }
}

# --- Bulk Path ---

bulk: Bulk Assessment {
  style.fill: "#ececec"
  style.stroke: "#333333"
  style.stroke-width: 2

  preflight: |md
    **Preflight**
    preflight.py

    - check JIRA_SERVER,
      JIRA_USER, JIRA_TOKEN
    - detect incomplete runs
    - report cache state
  | {
    shape: rectangle
    style.fill: "#f5f5f5"
    style.stroke: "#333333"
    style.stroke-width: 2
  }

  dump: |md
    **Fetch All Issues**
    dump_jira.py

    - REST API v3 bulk fetch
    - ADF to markdown
    - one .md per issue
  | {
    shape: rectangle
    style.fill: "#f5f5f5"
    style.stroke: "#333333"
    style.stroke-width: 2
  }

  setup: |md
    **Setup Run**
    setup_run.py

    - timestamped run dir
    - resume detection
    - queue.txt with pending keys
    - current symlink
  | {
    shape: rectangle
    style.fill: "#f5f5f5"
    style.stroke: "#333333"
    style.stroke-width: 2
  }

  pipeline: Agent Pipeline {
    style.fill: "#e0e0e0"
    style.stroke: "#333333"
    style.stroke-width: 2

    next-batch: |md
      **Pop Batch**
      next_batch.py

      - pop up to 30 keys
      - from queue.txt
      - track remaining
    | {
      shape: rectangle
      style.fill: "#f5f5f5"
      style.stroke: "#333333"
      style.stroke-width: 2
    }

    spawn: |md
      **Spawn Scorers**
      30 concurrent agents (Opus)

      - one agent per key
      - read agent_prompt.md
      - score + write .result.md
    | {
      shape: rectangle
      style.fill: "#e8e8e8"
      style.stroke: "#333333"
      style.stroke-width: 2
      style.double-border: true
    }

    poll: |md
      **Poll Progress**
      check_progress.py

      - poll every 30s
      - completed vs total
      - 5-min timeout check
    | {
      shape: rectangle
      style.fill: "#f5f5f5"
      style.stroke: "#333333"
      style.stroke-width: 2
    }
  }

  parse-results: |md
    **Parse Results**
    parse_results.py

    - extract scores from
      .result.md files
    - generate scores.csv
    - marks run complete
  | {
    shape: rectangle
    style.fill: "#f5f5f5"
    style.stroke: "#333333"
    style.stroke-width: 2
  }

  summarize: |md
    **Summarize**
    summarize_run.py

    - pass/fail counts
    - score distribution
    - criteria averages
    - what-if analysis
    - near-miss failures
  | {
    shape: rectangle
    style.fill: "#f5f5f5"
    style.stroke: "#333333"
    style.stroke-width: 2
  }
}

# --- External ---

jira-server: |md
  **Jira Server**

  - redhat.atlassian.net
  - REST API v3
| {
  shape: rectangle
  style.fill: "#f5f5f5"
  style.stroke: "#333333"
  style.stroke-width: 2
  style.stroke-dash: 3
}

# --- Callout: Directory Structure ---

dir-tree: |md
  assessments/PROJ/
    20260322-143000/
      RHAIRFE-42.result.md
      queue.txt
      scores.csv
    current -> 20260322-143000

  /tmp/rfe-assess/PROJ/
    RHAIRFE-42.md  (bulk cache)
  /tmp/rfe-assess/single/
    KEY.md  (single mode)
| {
  shape: rectangle
  style.fill: "#f5f5f5"
  style.stroke: "#bbbbbb"
  style.stroke-width: 1
  style.font: mono
  style.font-size: 10
}

# --- Callout: Agent Prompt ---

rubric-callout: |md
  agent_prompt.md
    scoring rubric
    calibration examples
    output format spec
    single source of truth
| {
  shape: rectangle
  style.fill: "#f5f5f5"
  style.stroke: "#bbbbbb"
  style.stroke-width: 1
  style.font: mono
  style.font-size: 10
}

# --- Flow: Main ---

entry -> detect

# --- Flow: Single ---

detect -> single.prep: "single input"
single.prep -> single.fetch

single.fetch.mcp -> single.write-content
single.fetch.rest-api -> single.write-content: "already written"
single.fetch.read-file -> single.write-content

single.write-content -> single.score-single: "{KEY}.md"
single.score-single -> single.present-single: "{KEY}.result.md"

# MCP fallback
single.fetch.mcp -> single.fetch.rest-api: "MCP fails" {
  style.stroke-dash: 3
}

# --- Flow: Bulk ---

detect -> bulk.preflight: "wildcard *"
bulk.preflight -> bulk.dump: "env OK"
bulk.preflight -> bulk.preflight: "env missing\nprompt user" {
  style.stroke-dash: 3
}
bulk.dump -> bulk.setup
bulk.setup -> bulk.pipeline.next-batch: "queue.txt"
bulk.pipeline.next-batch -> bulk.pipeline.spawn: "batch of keys"
bulk.pipeline.spawn -> bulk.pipeline.poll
bulk.pipeline.poll -> bulk.pipeline.next-batch: "batch done,\nqueue not empty" {
  style.stroke-dash: 3
}
bulk.pipeline.poll -> bulk.parse-results: "queue empty"
bulk.parse-results -> bulk.summarize: "scores.csv"

# --- External connections ---

single.fetch.mcp -> jira-server
single.fetch.rest-api -> jira-server
bulk.dump -> jira-server: "REST API"

# --- Callout connections ---

bulk.setup -> dir-tree: {
  style.stroke: "#bbbbbb"
  style.stroke-dash: 4
  style.stroke-width: 1
}

single.score-single -> rubric-callout: {
  style.stroke: "#bbbbbb"
  style.stroke-dash: 4
  style.stroke-width: 1
}

bulk.pipeline.spawn -> rubric-callout: {
  style.stroke: "#bbbbbb"
  style.stroke-dash: 4
  style.stroke-width: 1
}
