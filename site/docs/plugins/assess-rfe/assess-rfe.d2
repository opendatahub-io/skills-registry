direction: right

*.style.border-radius: 8
*.style.font-size: 13
*.style.fill: "#f5f5f5"
*.style.stroke: "#333333"

# --- Entry ---

entry: |md
  **/assess-rfe**

  - Jira key, file, URL,
    raw text, or wildcard
| {
  shape: rectangle
  style.fill: "#f5f5f5"
  style.stroke: "#333333"
  style.stroke-width: 2
}

# --- Input Detection ---

detect: |md
  **Detect Input Type**

  - Jira key → MCP or REST
  - File path → read file
  - URL → fetch content
  - Raw text → use directly
  - Wildcard → bulk mode
| {
  shape: rectangle
  style.fill: "#f5f5f5"
  style.stroke: "#333333"
  style.stroke-width: 2
}

# --- Single Mode ---

fetch-single: |md
  **Fetch & Prepare**

  - MCP getJiraIssue first
  - REST fallback (fetch_single.py)
  - prep_single.py cleanup
  - Write to /tmp/rfe-assess/single/
| {
  shape: rectangle
  style.fill: "#f5f5f5"
  style.stroke: "#333333"
  style.stroke-width: 2
}

# --- Bulk Mode ---

preflight: |md
  **Preflight Checks**

  - Verify JIRA_SERVER,
    JIRA_USER, JIRA_TOKEN
  - Check cache state
  - Resume incomplete runs
| {
  shape: rectangle
  style.fill: "#f5f5f5"
  style.stroke: "#333333"
  style.stroke-width: 2
}

dump-jira: |md
  **Dump Jira Project**

  - dump_jira.py
  - All issues → local cache
  - ADF → markdown conversion
| {
  shape: rectangle
  style.fill: "#f5f5f5"
  style.stroke: "#333333"
  style.stroke-width: 2
}

setup-run: |md
  **Setup Run**

  - setup_run.py
  - Timestamped run directory
  - Resume logic + pending list
| {
  shape: rectangle
  style.fill: "#f5f5f5"
  style.stroke: "#333333"
  style.stroke-width: 2
}

# --- Scoring ---

score: |md
  **Scorer Agents**
  LLM agents (Opus)

  - 30 concurrent max (bulk)
  - Rolling pipeline launch
  - agent_prompt.md rubric
  - Poll every 30s
| {
  shape: rectangle
  style.fill: "#e8e8e8"
  style.stroke: "#333333"
  style.stroke-width: 2
  style.double-border: true
}

# --- Output ---

results: |md
  **Results & Summary**

  - parse_results.py → scores.csv
  - summarize_run.py
  - Pass/fail rates, averages
  - What-if analysis, near-misses
| {
  shape: rectangle
  style.fill: "#f5f5f5"
  style.stroke: "#333333"
  style.stroke-width: 2
}

# --- External ---

jira: |md
  **Jira**
| {
  shape: rectangle
  style.fill: "#f5f5f5"
  style.stroke: "#333333"
  style.stroke-width: 2
  style.stroke-dash: 3
}

# --- Callout: Directory Structure ---

dir-tree: |md
  assessments/RHAIRFE/
    20260322-143000/
      RHAIRFE-42.result.md
      scores.csv
    current → 20260322-143000

  /tmp/rfe-assess/RHAIRFE/
    RHAIRFE-42.md
  /tmp/rfe-assess/single/
    RHAIRFE-1234.md
| {
  shape: rectangle
  style.fill: "#f5f5f5"
  style.stroke: "#bbbbbb"
  style.stroke-width: 1
  style.font: mono
  style.font-size: 10
}

# --- Flow ---

entry -> detect

detect -> fetch-single: "single"
detect -> preflight: "RHAIRFE-*"

fetch-single -> score: "{KEY}.md"

preflight -> dump-jira
dump-jira -> setup-run
setup-run -> score: "pending keys"

score -> results: "*.result.md"

# External
fetch-single -> jira: "MCP / REST" {
  style.stroke-dash: 3
}
dump-jira -> jira: "REST API" {
  style.stroke-dash: 3
}

# Callout
results -> dir-tree: {
  style.stroke: "#bbbbbb"
  style.stroke-dash: 4
  style.stroke-width: 1
}
