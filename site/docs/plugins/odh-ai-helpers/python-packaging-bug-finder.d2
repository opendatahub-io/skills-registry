direction: right

*.style.border-radius: 8
*.style.font-size: 13
*.style.fill: "#f5f5f5"
*.style.stroke: "#333333"

# --- Entry ---

entry: |md
  **/python-packaging-bug-finder**

  - package name
  - target version
| {
  shape: rectangle
  style.fill: "#f5f5f5"
  style.stroke: "#333333"
  style.stroke-width: 2
}

# --- External: source-finder skill ---

source-finder: |md
  **/python-packaging-source-finder**
| {
  shape: rectangle
  style.fill: "#f5f5f5"
  style.stroke: "#333333"
  style.stroke-width: 2
  style.stroke-dash: 3
}

# --- Find Repo ---

find-repo: |md
  **Find Repository**

  - invoke source-finder skill
  - receive repo URL + confidence
  - gate on confidence level
| {
  shape: rectangle
  style.fill: "#f5f5f5"
  style.stroke: "#333333"
  style.stroke-width: 2
}

# --- External: GitHub ---

github: |md
  **GitHub Issues**
| {
  shape: rectangle
  style.fill: "#f5f5f5"
  style.stroke: "#333333"
  style.stroke-width: 2
  style.stroke-dash: 3
}

# --- Search Issues ---

search-issues: |md
  **Search Issues**

  - WebFetch repo issues page
  - filter by packaging keywords
  - build, install, compiler,
    platform, dependency terms
  - prioritize open issues
| {
  shape: rectangle
  style.fill: "#f5f5f5"
  style.stroke: "#333333"
  style.stroke-width: 2
}

# --- Analyze Issues ---

analyze: |md
  **Analyze Each Issue**
  LLM analysis

  - fetch full issue + comments
  - extract problem description
  - identify affected versions
  - find fixes, PRs, workarounds
  - check resolution indicators
| {
  shape: rectangle
  style.fill: "#e8e8e8"
  style.stroke: "#333333"
  style.stroke-width: 2
  style.double-border: true
}

# --- Version Impact ---

version-impact: |md
  **Version Impact Assessment**
  LLM analysis

  - compare affected vs target version
  - classify: fixed & included,
    fixed but pending, workaround
    available, or unresolved
| {
  shape: rectangle
  style.fill: "#e8e8e8"
  style.stroke: "#333333"
  style.stroke-width: 2
  style.double-border: true
}

# --- Report ---

report: |md
  **Report**

  - issues found count
  - per-issue status & resolution
  - workarounds listed
  - recommendations
| {
  shape: rectangle
  style.fill: "#f5f5f5"
  style.stroke: "#333333"
  style.stroke-width: 2
}

# --- Error output ---

error-stop: |md
  **Error**

  - low confidence or
    no repo found
| {
  shape: rectangle
  style.fill: "#f5f5f5"
  style.stroke: "#333333"
  style.stroke-width: 2
}

# --- Flow ---

entry -> find-repo
find-repo -> source-finder: {
  style.stroke-dash: 3
}
find-repo -> search-issues: "high/medium\nconfidence"
find-repo -> error-stop: "low/none"

search-issues -> github: {
  style.stroke-dash: 3
}
search-issues -> analyze: "matching issues"

analyze -> github: "fetch details" {
  style.stroke-dash: 3
}
analyze -> version-impact: "per issue"

version-impact -> report
