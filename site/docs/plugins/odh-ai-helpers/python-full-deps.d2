direction: right

*.style.border-radius: 8
*.style.font-size: 13
*.style.fill: "#f5f5f5"
*.style.stroke: "#333333"

# --- Entry ---

entry: |md
  **/python-full-deps**

  - package name (required)
  - version (optional)
  - Python version (default: 3.12)
| {
  shape: rectangle
  style.fill: "#f5f5f5"
  style.stroke: "#333333"
  style.stroke-width: 2
}

# --- Processing ---

build-req: |md
  **Build Requirement**

  - Construct requirement string
  - package==version or bare name
| {
  shape: rectangle
  style.fill: "#f5f5f5"
  style.stroke: "#333333"
  style.stroke-width: 2
}

try-uv: |md
  **Try uv Resolver**

  - uv pip compile
  - --python-version flag
  - 150s timeout
| {
  shape: rectangle
  style.fill: "#f5f5f5"
  style.stroke: "#333333"
  style.stroke-width: 2
}

parse-uv: |md
  **Parse Compile Output**

  - requirements.txt format
  - PEP 503 normalization
| {
  shape: rectangle
  style.fill: "#f5f5f5"
  style.stroke: "#333333"
  style.stroke-width: 2
}

pip-fallback: |md
  **Pip Fallback**

  - Create temp venv
  - pip install --dry-run --report
  - 150s timeout
| {
  shape: rectangle
  style.fill: "#f5f5f5"
  style.stroke: "#333333"
  style.stroke-width: 2
}

parse-report: |md
  **Parse Pip Report**

  - JSON report file
  - Extract name + version
| {
  shape: rectangle
  style.fill: "#f5f5f5"
  style.stroke: "#333333"
  style.stroke-width: 2
}

# --- Output ---

sort-dedup: |md
  **Sort & Deduplicate**

  - Alphabetical sort
  - Unique entries
  - name==version per line
| {
  shape: rectangle
  style.fill: "#f5f5f5"
  style.stroke: "#333333"
  style.stroke-width: 2
}

report: |md
  **Report**

  - Sorted dependency tree
  - Total count + notable packages
  - Context for container/supply-chain
| {
  shape: rectangle
  style.fill: "#f5f5f5"
  style.stroke: "#333333"
  style.stroke-width: 2
}

# --- External ---

pypi: |md
  **PyPI**
| {
  shape: rectangle
  style.fill: "#f5f5f5"
  style.stroke: "#333333"
  style.stroke-width: 2
  style.stroke-dash: 3
}

# --- Flow ---

entry -> build-req
build-req -> try-uv

try-uv -> parse-uv: "uv found"
try-uv -> pip-fallback: "uv missing" {
  style.stroke-dash: 3
}

parse-uv -> sort-dedup
pip-fallback -> parse-report
parse-report -> sort-dedup

sort-dedup -> report

try-uv -> pypi: "network" {
  style.stroke-dash: 3
}
pip-fallback -> pypi: "network" {
  style.stroke-dash: 3
}
