{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Skills Registry",
  "description": "Schema for the opendatahub-io skills registry (registry.yaml)",
  "type": "object",
  "required": ["name", "owner", "plugins"],
  "additionalProperties": false,
  "properties": {
    "name": {
      "type": "string",
      "description": "Registry identifier"
    },
    "description": {
      "type": "string",
      "description": "Human-readable description of the registry"
    },
    "owner": {
      "type": "object",
      "required": ["name"],
      "properties": {
        "name": { "type": "string" },
        "email": { "type": "string", "format": "email" }
      },
      "additionalProperties": false
    },
    "categories": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "required": ["name", "description"],
        "properties": {
          "name": { "type": "string" },
          "description": { "type": "string" }
        },
        "additionalProperties": false
      }
    },
    "plugins": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/plugin"
      }
    }
  },
  "$defs": {
    "nonEmptyText": {
      "type": "string",
      "pattern": ".*\\S.*"
    },
    "repoRelativePath": {
      "type": "string",
      "maxLength": 512,
      "pattern": "^(?![A-Za-z]:)(?!/)(?!\\\\)(?!.*(?:^|/)\\.\\.(?:/|$))(?!.*\\\\).*\\S.*$"
    },
    "skillSourcePath": {
      "type": "string",
      "maxLength": 512,
      "pattern": "^(?![A-Za-z]:)(?!/)(?!\\\\)(?!.*(?:^|/)\\.\\.(?:/|$))(?!.*\\\\)(?:[^/]+/)*SKILL\\.md$"
    },
    "evaluationNonEmptyList": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "$ref": "#/$defs/nonEmptyText"
      }
    },
    "canonicalFunction": {
      "type": "string",
      "description": "Published job-to-be-done for the skill. Choose the user-visible function, not an implementation detail.",
      "enum": [
        "plan",
        "retrieve",
        "analyze",
        "review",
        "generate",
        "transform",
        "verify",
        "execute",
        "orchestrate"
      ]
    },
    "canonicalMetric": {
      "type": "string",
      "description": "Optimization target for the skill. Choose the smallest metric set that captures what must improve without changing the skill's purpose.",
      "enum": [
        "task_success",
        "tool_correctness",
        "argument_correctness",
        "evidence_completeness",
        "step_efficiency",
        "latency",
        "token_efficiency",
        "context_footprint",
        "output_quality"
      ]
    },
    "metricMeasure": {
      "type": "string",
      "description": "How this metric is currently measured. Contributor-facing contracts must declare the measure explicitly.",
      "enum": ["deterministic", "verifier_backed", "judge"]
    },
    "knowledgeInput": {
      "type": "object",
      "required": ["kind", "privacy"],
      "additionalProperties": false,
      "properties": {
        "kind": {
          "type": "string",
          "enum": [
            "repository_content",
            "task_input",
            "tool_output",
            "external_reference",
            "organization_memory"
          ]
        },
        "privacy": {
          "type": "string",
          "enum": ["public", "repository_internal", "organization_private", "task_private"]
        }
      }
    },
    "contractInvariants": {
      "type": "object",
      "required": ["must_preserve", "fixed_context"],
      "additionalProperties": false,
      "properties": {
        "must_preserve": { "$ref": "#/$defs/evaluationNonEmptyList" },
        "fixed_context": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "tools": { "$ref": "#/$defs/evaluationNonEmptyList" },
            "cli": { "$ref": "#/$defs/evaluationNonEmptyList" },
            "documents": { "$ref": "#/$defs/evaluationNonEmptyList" },
            "knowledge_inputs": {
              "type": "array",
              "minItems": 1,
              "items": { "$ref": "#/$defs/knowledgeInput" }
            }
          },
          "anyOf": [
            { "required": ["tools"] },
            { "required": ["cli"] },
            { "required": ["documents"] },
            { "required": ["knowledge_inputs"] }
          ]
        }
      }
    },
    "sourceAssertions": {
      "type": "object",
      "required": ["skill_path"],
      "additionalProperties": false,
      "properties": {
        "skill_path": { "$ref": "#/$defs/skillSourcePath" },
        "supporting_paths": {
          "type": "array",
          "uniqueItems": true,
          "items": { "$ref": "#/$defs/repoRelativePath" }
        }
      }
    },
    "contractMetricAssignment": {
      "type": "object",
      "required": ["id", "measure"],
      "additionalProperties": false,
      "properties": {
        "id": { "$ref": "#/$defs/canonicalMetric" },
        "measure": { "$ref": "#/$defs/metricMeasure" },
        "target_measure": { "$ref": "#/$defs/metricMeasure" },
        "verifier_ref": { "$ref": "#/$defs/nonEmptyText" },
        "rubric_ref": { "$ref": "#/$defs/nonEmptyText" },
        "calibration_ref": { "$ref": "#/$defs/nonEmptyText" },
        "trials": { "type": "integer", "minimum": 1 },
        "success_mode": {
          "type": "string",
          "enum": ["single_run", "pass_at_k", "pass_all_k"]
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "id": {
                "enum": ["latency", "token_efficiency", "context_footprint", "step_efficiency"]
              }
            },
            "required": ["id"]
          },
          "then": {
            "properties": {
              "measure": { "const": "deterministic" }
            }
          }
        },
        {
          "if": { "properties": { "id": { "const": "output_quality" } }, "required": ["id"] },
          "then": {
            "properties": {
              "measure": { "const": "judge" }
            }
          }
        },
        {
          "if": { "properties": { "measure": { "const": "judge" } }, "required": ["measure"] },
          "then": { "required": ["rubric_ref"] }
        },
        {
          "if": { "properties": { "measure": { "const": "verifier_backed" } }, "required": ["measure"] },
          "then": { "required": ["verifier_ref"] }
        },
        {
          "if": {
            "properties": { "success_mode": { "enum": ["pass_at_k", "pass_all_k"] } },
            "required": ["success_mode"]
          },
          "then": {
            "required": ["trials"],
            "properties": { "trials": { "type": "integer", "minimum": 2 } }
          }
        }
      ]
    },
    "contract": {
      "type": "object",
      "required": [
        "version",
        "functions",
        "metrics",
        "problem_statement",
        "success_conditions",
        "invariants",
        "source_assertions"
      ],
      "additionalProperties": false,
      "properties": {
        "version": { "type": "string", "enum": ["canonical-skill-v1"] },
        "functions": {
          "type": "array",
          "minItems": 1,
          "maxItems": 2,
          "uniqueItems": true,
          "items": { "$ref": "#/$defs/canonicalFunction" }
        },
        "metrics": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/contractMetricAssignment" }
        },
        "problem_statement": { "$ref": "#/$defs/nonEmptyText" },
        "success_conditions": { "$ref": "#/$defs/evaluationNonEmptyList" },
        "invariants": { "$ref": "#/$defs/contractInvariants" },
        "source_assertions": { "$ref": "#/$defs/sourceAssertions" }
      }
    },
    "contractSummary": {
      "type": "object",
      "required": ["focus_functions", "focus_metrics", "notes"],
      "additionalProperties": false,
      "properties": {
        "focus_functions": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": { "$ref": "#/$defs/canonicalFunction" }
        },
        "focus_metrics": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": { "$ref": "#/$defs/canonicalMetric" }
        },
        "notes": { "$ref": "#/$defs/nonEmptyText" }
      }
    },
    "plugin": {
      "type": "object",
      "required": ["name", "description", "version", "source"],
      "additionalProperties": false,
      "dependentRequired": {
        "skills_dir": ["strict"]
      },
      "properties": {
        "name": {
          "type": "string",
          "pattern": "^[a-z0-9][a-z0-9-]*$",
          "description": "Plugin identifier (lowercase, hyphens allowed)"
        },
        "description": {
          "type": "string",
          "description": "What this plugin does"
        },
        "version": {
          "type": "string",
          "pattern": "^\\d+\\.\\d+\\.\\d+(-[0-9A-Za-z.-]+)?(\\+[0-9A-Za-z.-]+)?$",
          "description": "Semantic version"
        },
        "category": {
          "type": "string",
          "description": "Category key from the categories map"
        },
        "scope": {
          "type": "string",
          "enum": ["generic", "sdlc", "team"],
          "default": "sdlc",
          "description": "Reusability scope. 'generic' works anywhere; 'sdlc' (default) is RHOAI/ODH-wide and reusable across teams; 'team' is hardcoded to a specific team's setup and not generally reusable. The catalog and site label generic and team plugins. Catalog-only metadata — not propagated to marketplace.json."
        },
        "tags": {
          "type": "array",
          "items": { "type": "string" }
        },
        "author": {
          "type": "object",
          "properties": {
            "name": { "type": "string" },
            "email": { "type": "string", "format": "email" }
          },
          "additionalProperties": false
        },
        "license": {
          "type": "string"
        },
        "source": {
          "$ref": "#/$defs/source"
        },
        "strict": {
          "type": "boolean",
          "default": true,
          "description": "If false, marketplace is the entire plugin definition. If true (default), plugin.json in the repo is authoritative and marketplace supplements it. Setting strict: false when the repo also has a plugin.json with components causes a conflict"
        },
        "skills_dir": {
          "type": "string",
          "description": "Path to skills directory in the repo. Only valid when strict: false (marketplace defines the plugin). When strict: true, Claude Code auto-discovers skills in default locations"
        },
        "homepage": {
          "type": "string",
          "format": "uri"
        },
        "repository": {
          "type": "string",
          "format": "uri"
        },
        "skills": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/skill"
          }
        },
        "agents": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/agent"
          }
        },
        "agents_dir": {
          "type": "string",
          "description": "Path to agents directory in the repo (used when strict: false)"
        },
        "harnesses": {
          "type": "object",
          "additionalProperties": {
            "type": "object",
            "additionalProperties": true
          }
        },
        "python": {
          "type": "object",
          "properties": {
            "package": { "type": "string" },
            "requires_python": { "type": "string" },
            "dependencies": {
              "type": "array",
              "items": { "type": "string" }
            }
          },
          "additionalProperties": false
        },
        "depends_on": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Names of other plugins in this registry that this plugin depends on"
        },
        "contract_summary": {
          "$ref": "#/$defs/contractSummary"
        }
      }
    },
    "source": {
      "type": "object",
      "required": ["type", "repo"],
      "additionalProperties": false,
      "properties": {
        "type": {
          "type": "string",
          "enum": ["github", "git-subdir", "npm", "local"],
          "description": "Source type"
        },
        "repo": {
          "type": "string",
          "description": "Repository identifier (e.g., owner/repo)"
        },
        "ref": {
          "type": "string",
          "description": "Git branch, tag, or ref"
        },
        "sha": {
          "type": "string",
          "pattern": "^[0-9a-f]{40}$",
          "description": "Exact commit SHA"
        },
        "path": {
          "type": "string",
          "description": "Subdirectory path (for git-subdir type)"
        }
      }
    },
    "skill": {
      "type": "object",
      "required": ["name", "description"],
      "additionalProperties": false,
      "properties": {
        "name": {
          "type": "string",
          "description": "Skill name (matches directory name)"
        },
        "description": {
          "type": "string",
          "description": "What this skill does"
        },
        "user-invocable": {
          "type": "boolean",
          "default": true,
          "description": "Whether the skill can be invoked directly by the user via /skill-name. Mirrors the native Claude Code SKILL.md frontmatter field — see https://code.claude.com/docs/en/skills#frontmatter-reference. Set to false for internal skills called only by other skills/agents in the background. Note: the registry value is catalog-only; the actual invocation behavior is governed by the SKILL.md in the source repo."
        },
        "contract": {
          "$ref": "#/$defs/contract"
        }
      }
    },
    "agent": {
      "type": "object",
      "required": ["name", "description"],
      "additionalProperties": false,
      "properties": {
        "name": {
          "type": "string",
          "description": "Agent name (matches file name without extension)"
        },
        "description": {
          "type": "string",
          "description": "What this agent does"
        }
      }
    }
  }
}
